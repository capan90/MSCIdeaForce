@page "/problems"
@rendermode InteractiveServer

@using MSC.IdeaForge.Application.Agents
@inject MSC.IdeaForge.Application.Problems.Queries.GetProblemsHandler GetProblemsHandler
@inject MSC.IdeaForge.Application.Problems.Commands.CreateProblemHandler CreateProblemHandler
@inject MSC.IdeaForge.Application.Opportunities.Queries.GetOpportunityByProblemHandler GetOpportunityByProblemHandler
@inject MSC.IdeaForge.Application.Agents.AgentCoordinator AgentCoordinator

<PageTitle>Problemler</PageTitle>

<div class="container mt-4">
    @* Sayfa Başlığı *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="font-weight-bold text-dark mb-1" style="letter-spacing: -1px;">Problem Havuzu</h1>
            <p class="text-muted mb-0">Toplanan problemleri listeleyin, puanlayın ve yönetin.</p>
        </div>
    </div>

    @* Yeni Problem Ekleme Formu *@
    <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fcfcfc; border: 1px solid #e3e6f0 !important;">
        <div class="card-header bg-dark text-white py-2.5">
            <h6 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                <span class="bi bi-plus-circle-fill"></span> Yeni Problem Ekle
            </h6>
        </div>
        <div class="card-body p-3">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger py-2 mb-3 small">@errorMessage</div>
            }
            <div class="row g-2">
                <div class="col-md-3">
                    <input class="form-control form-control-sm" placeholder="Problem Başlığı..." @bind="newTitle" />
                </div>
                <div class="col-md-5">
                    <input class="form-control form-control-sm" placeholder="Problem Detayı ve Açıklaması..." @bind="newDescription" />
                </div>
                <div class="col-md-2">
                    <input class="form-control form-control-sm" placeholder="Sektör..." @bind="newSector" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary btn-sm w-100" @onclick="AddProblem">Problem Ekle</button>
                </div>
            </div>
        </div>
    </div>

    @* Gelişmiş Filtreler & Sıralama *@
    <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff; border: 1px solid #e3e6f0 !important;">
        <div class="card-body p-3">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1 font-weight-bold">Arama</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Başlık veya açıklamada ara..." @bind="searchQuery" @bind:event="oninput" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted mb-1 font-weight-bold">Sektör</label>
                    <select class="form-select form-select-sm" @bind="selectedSector">
                        <option value="">Tüm Sektörler</option>
                        @foreach (var sector in UniqueSectors)
                        {
                            <option value="@sector">@sector</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted mb-1 font-weight-bold">Durum</label>
                    <select class="form-select form-select-sm" @bind="selectedStatus">
                        <option value="">Tüm Durumlar</option>
                        <option value="Draft">Taslak</option>
                        <option value="Discovered">Keşfedildi</option>
                        <option value="Analyzed">Analiz Edildi</option>
                        <option value="Validated">Doğrulandı</option>
                        <option value="Archived">Arşivlendi</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted mb-1 font-weight-bold">Öncelik</label>
                    <select class="form-select form-select-sm" @bind="selectedPriority">
                        <option value="">Tüm Öncelikler</option>
                        <option value="Low">Düşük</option>
                        <option value="Medium">Orta</option>
                        <option value="High">Yüksek</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button class="btn btn-outline-secondary btn-sm w-50" @onclick="ToggleDateSort">
                        📅 Tarih @(sortColumn == "Date" ? (sortAsc ? "▲" : "▼") : "")
                    </button>
                    <button class="btn btn-outline-secondary btn-sm w-50" @onclick="ToggleScoreSort">
                        🔥 Fırsat @(sortColumn == "Score" ? (sortAsc ? "▲" : "▼") : "")
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* Toplu AI Analizi *@
    @if (selectedProblemIds.Any())
    {
        <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none !important;">
            <div class="card-body p-3 text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <strong>@selectedProblemIds.Count problem seçildi</strong>
                        <span class="ms-2 small opacity-75">Seçilenleri toplu AI ile analiz edebilirsiniz.</span>
                    </div>
                    <div class="d-flex gap-2">
                        @if (isBulkAnalyzing)
                        {
                            <button class="btn btn-light btn-sm d-flex align-items-center gap-2" disabled>
                                <span class="spinner-border spinner-border-sm" role="status"></span>
                                Analiz ediliyor... (@bulkProgressCurrent/@bulkProgressTotal)
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-light btn-sm font-weight-bold" @onclick="RunBulkAiAnalysis">
                                🤖 Seçilenleri AI ile Analiz Et
                            </button>
                        }
                        <button class="btn btn-outline-light btn-sm" @onclick="ClearSelection">
                            Seçimi Temizle
                        </button>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(bulkMessage))
                {
                    <div class="mt-2 small opacity-90">@bulkMessage</div>
                }
            </div>
        </div>
    }

    @* Problemler Tablosu *@
    @if (problems is null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted small">Problemler yükleniyor...</p>
        </div>
    }
    else if (!problems.Any())
    {
        <div class="alert alert-light text-center py-5 border shadow-sm" style="border-radius: 12px;">
            Hiç problem eklenmemiş. Yeni bir problem ekleyerek başlayın.
        </div>
    }
    else if (!FilteredProblems.Any())
    {
        <div class="alert alert-light text-center py-5 border shadow-sm" style="border-radius: 12px;">
            Filtreleme kriterlerine uygun problem bulunamadı.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 mb-5" style="border-radius: 12px; overflow: hidden; border: 1px solid #e3e6f0 !important;">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size: 0.9rem;">
                    <thead class="table-light text-muted small text-uppercase">
                        <tr>
                            <th style="width: 5%;" class="text-center">
                                <input type="checkbox" @onchange="ToggleSelectAll" checked="@IsAllSelected" />
                            </th>
                            <th style="width: 22%;">Problem Başlığı</th>
                            <th style="width: 9%;">Sektör</th>
                            <th style="width: 10%;">Durum</th>
                            <th style="width: 11%;">Fikir Durumu</th>
                            <th style="width: 9%;">Öncelik</th>
                            <th style="width: 10%;" class="text-center">Fırsat Skoru</th>
                            <th style="width: 9%;">Eklenme Tarihi</th>
                            <th style="width: 11%;" class="text-center">Hızlı Analiz</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in FilteredProblems)
                        {
                            <tr>
                                <td class="text-center">
                                    <input type="checkbox" checked="@selectedProblemIds.Contains(p.Id)" @onchange="() => ToggleProblemSelection(p.Id)" />
                                </td>
                                <td>
                                    <a href="/problems/@p.Id" class="font-weight-bold text-primary text-decoration-none">
                                        @p.Title
                                    </a>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border">
                                        @(string.IsNullOrEmpty(p.Sector) ? "-" : p.Sector)
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @GetStatusBadgeClass(p.Status)">
                                        @GetStatusText(p.Status)
                                    </span>
                                </td>
                                <td>
                                    @* Fikir yaşam döngüsü durumu (IdeaStatus) *@
                                    <span class="badge text-white" style="background-color: @GetIdeaStatusColor(p.IdeaStatus); font-size: 0.7rem;">
                                        @GetIdeaStatusText(p.IdeaStatus)
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-light text-secondary border">
                                        @GetPriorityText(p.Priority)
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (opportunityScores.TryGetValue(p.Id, out var score) && score > 0)
                                    {
                                        @* Skora göre renklendirilmiş mini gösterge *@
                                        <span class="badge @GetScoreBadgeClass(score) text-white px-2.5 py-1.5" style="font-size: 0.85rem;">
                                            @score.ToString("0.0") / 10
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted border" style="font-size: 0.75rem;">Puanlanmadı</span>
                                    }
                                </td>
                                <td class="font-mono text-muted small">
                                    @p.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")
                                </td>
                                <td class="text-center">
                                    @if (quickAnalyzingProblemId == p.Id)
                                    {
                                        <button class="btn btn-outline-primary btn-sm py-0 px-2" disabled>
                                            <span class="spinner-border spinner-border-sm" role="status" style="width: 0.8rem; height: 0.8rem;"></span>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-primary btn-sm py-0 px-2" style="font-size: 0.78rem;"
                                                @onclick="() => RunQuickAnalysis(p.Id)" disabled="@(quickAnalyzingProblemId is not null)">
                                            ▶ Hızlı Analiz
                                        </button>
                                    }
                                </td>
                            </tr>

                            @* Hızlı analiz sırasında satır altında ilerleme göster *@
                            @if (quickAnalyzingProblemId == p.Id && quickAnalysisProgress is not null)
                            {
                                <tr>
                                    <td colspan="9" class="bg-light">
                                        <div class="d-flex flex-wrap gap-2 py-2 px-1">
                                            @foreach (var step in quickAnalysisProgress)
                                            {
                                                <span class="badge d-flex align-items-center gap-1 @GetStepBadgeClass(step.Status)" style="font-size: 0.72rem;">
                                                    @GetStepIcon(step.Status) @step.Step
                                                </span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private IEnumerable<MSC.IdeaForge.Application.Problems.DTOs.ProblemDto>? problems;
    private Dictionary<Guid, double> opportunityScores = new();

    // Filtre & Arama State
    private string searchQuery = "";
    private string selectedSector = "";
    private string selectedStatus = "";
    private string selectedPriority = "";
    private string sortColumn = "Date"; // Date or Score
    private bool sortAsc = false;

    // Form State
    private string newTitle = "";
    private string newDescription = "";
    private string newSector = "";
    private string errorMessage = "";

    // Toplu AI Analizi State
    private HashSet<Guid> selectedProblemIds = new();
    private bool isBulkAnalyzing = false;
    private int bulkProgressCurrent = 0;
    private int bulkProgressTotal = 0;
    private string bulkMessage = "";

    // Satır bazlı Hızlı Analiz State
    private Guid? quickAnalyzingProblemId;
    private List<AgentProgress>? quickAnalysisProgress;

    protected override async Task OnInitializedAsync()
    {
        await LoadProblems();
    }

    private async Task LoadProblems()
    {
        try
        {
            var list = await GetProblemsHandler.HandleAsync();
            problems = list;

            opportunityScores.Clear();
            foreach (var p in list)
            {
                var opp = await GetOpportunityByProblemHandler.HandleAsync(p.Id);
                if (opp is not null)
                {
                    opportunityScores[p.Id] = opp.TotalScore;
                }
                else
                {
                    opportunityScores[p.Id] = 0;
                }
            }
        }
        catch
        {
            problems = new List<MSC.IdeaForge.Application.Problems.DTOs.ProblemDto>();
        }
    }

    private async Task AddProblem()
    {
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(newTitle) || string.IsNullOrWhiteSpace(newDescription))
        {
            errorMessage = "Başlık ve açıklama zorunludur.";
            return;
        }

        try
        {
            var command = new MSC.IdeaForge.Application.Problems.Commands.CreateProblemCommand
            {
                Title = newTitle,
                Description = newDescription,
                Sector = newSector
            };

            await CreateProblemHandler.HandleAsync(command);
            newTitle = "";
            newDescription = "";
            newSector = "";
            await LoadProblems();
        }
        catch (Exception ex)
        {
            errorMessage = $"Hata: {ex.Message}";
        }
    }

    // Toplu Seçim İşlemleri
    private void ToggleProblemSelection(Guid id)
    {
        if (selectedProblemIds.Contains(id))
        {
            selectedProblemIds.Remove(id);
        }
        else
        {
            selectedProblemIds.Add(id);
        }
    }

    private bool IsAllSelected => problems is not null && FilteredProblems.Any() && FilteredProblems.All(p => selectedProblemIds.Contains(p.Id));

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        if (IsAllSelected)
        {
            foreach (var p in FilteredProblems)
            {
                selectedProblemIds.Remove(p.Id);
            }
        }
        else
        {
            foreach (var p in FilteredProblems)
            {
                selectedProblemIds.Add(p.Id);
            }
        }
    }

    private void ClearSelection()
    {
        selectedProblemIds.Clear();
    }

    /// <summary>
    /// Seçili problemlere sırayla AI Coordinator tam analizi çalıştırır.
    /// </summary>
    private async Task RunBulkAiAnalysis()
    {
        if (!selectedProblemIds.Any()) return;

        isBulkAnalyzing = true;
        bulkProgressCurrent = 0;
        bulkProgressTotal = selectedProblemIds.Count;
        bulkMessage = "";

        var ids = selectedProblemIds.ToList();

        try
        {
            foreach (var problemId in ids)
            {
                bulkProgressCurrent++;
                bulkMessage = $"Problem {bulkProgressCurrent}/{bulkProgressTotal} analiz ediliyor...";
                StateHasChanged();

                try
                {
                    await AgentCoordinator.RunFullAnalysisAsync(problemId);
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Toplu analiz hatası (ProblemId: {problemId}): {ex.Message}");
                }
            }

            bulkMessage = $"✅ {bulkProgressTotal} problem başarıyla analiz edildi!";
            selectedProblemIds.Clear();
            await LoadProblems();
        }
        catch (Exception ex)
        {
            bulkMessage = $"⚠️ Toplu analiz sırasında hata oluştu: {ex.Message}";
        }
        finally
        {
            isBulkAnalyzing = false;
            StateHasChanged();
        }
    }

    // Client-side Filtreleme & Sıralama
    private IEnumerable<MSC.IdeaForge.Application.Problems.DTOs.ProblemDto> FilteredProblems
    {
        get
        {
            if (problems is null) return Enumerable.Empty<MSC.IdeaForge.Application.Problems.DTOs.ProblemDto>();

            var result = problems;

            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var q = searchQuery.ToLower();
                result = result.Where(p => p.Title.ToLower().Contains(q) || p.Description.ToLower().Contains(q));
            }

            if (!string.IsNullOrWhiteSpace(selectedSector))
            {
                result = result.Where(p => p.Sector == selectedSector);
            }

            if (!string.IsNullOrWhiteSpace(selectedStatus))
            {
                result = result.Where(p => p.Status == selectedStatus);
            }

            if (!string.IsNullOrWhiteSpace(selectedPriority))
            {
                result = result.Where(p => p.Priority == selectedPriority);
            }

            if (sortColumn == "Score")
            {
                result = sortAsc
                    ? result.OrderBy(p => opportunityScores.GetValueOrDefault(p.Id, 0.0))
                    : result.OrderByDescending(p => opportunityScores.GetValueOrDefault(p.Id, 0.0));
            }
            else
            {
                result = sortAsc
                    ? result.OrderBy(p => p.CreatedAt)
                    : result.OrderByDescending(p => p.CreatedAt);
            }

            return result;
        }
    }

    private IEnumerable<string> UniqueSectors
    {
        get
        {
            if (problems is null) return Enumerable.Empty<string>();
            return problems
                .Select(p => p.Sector)
                .Where(s => !string.IsNullOrWhiteSpace(s))
                .Distinct()!;
        }
    }

    private void ToggleDateSort()
    {
        if (sortColumn == "Date") { sortAsc = !sortAsc; }
        else { sortColumn = "Date"; sortAsc = false; }
    }

    private void ToggleScoreSort()
    {
        if (sortColumn == "Score") { sortAsc = !sortAsc; }
        else { sortColumn = "Score"; sortAsc = false; }
    }

    private string GetStatusText(string status) => status switch
    {
        "Draft" => "Taslak",
        "Discovered" => "Keşfedildi",
        "Analyzed" => "Analiz Edildi",
        "Validated" => "Doğrulandı",
        "Archived" => "Arşivlendi",
        _ => status
    };

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Draft" => "bg-secondary text-white",
        "Discovered" => "bg-info text-dark",
        "Analyzed" => "bg-primary text-white",
        "Validated" => "bg-success text-white",
        "Archived" => "bg-dark text-white",
        _ => "bg-secondary"
    };

    private string GetPriorityText(string priority) => priority switch
    {
        "Low" => "Düşük",
        "Medium" => "Orta",
        "High" => "Yüksek",
        _ => priority
    };

    // Fırsat skoruna göre renk: 8-10 yeşil, 6-7.9 sarı, 0-5.9 kırmızı
    private string GetScoreBadgeClass(double score) => score switch
    {
        >= 8 => "bg-success",
        >= 6 => "bg-warning",
        _ => "bg-danger"
    };

    // Fikir yaşam döngüsü durumu → Türkçe etiket
    private string GetIdeaStatusText(string ideaStatus) => ideaStatus switch
    {
        "Raw" => "Ham",
        "Analyzed" => "Analiz Edildi",
        "Validated" => "Doğrulandı",
        "MVPCandidate" => "MVP Adayı",
        "Development" => "Geliştirme",
        "Pilot" => "Pilot",
        "Released" => "Yayınlandı",
        "Parked" => "Park Edildi",
        "Archived" => "Arşivlendi",
        "Killed" => "İptal",
        _ => ideaStatus
    };

    // Fikir yaşam döngüsü durumu → renk kodu
    private string GetIdeaStatusColor(string ideaStatus) => ideaStatus switch
    {
        "Raw" => "#6c757d",
        "Analyzed" => "#0d6efd",
        "Validated" => "#0dcaf0",
        "MVPCandidate" => "#6f42c1",
        "Development" => "#fd7e14",
        "Pilot" => "#20c997",
        "Released" => "#198754",
        "Parked" => "#ffc107",
        "Archived" => "#343a40",
        "Killed" => "#dc3545",
        _ => "#6c757d"
    };

    /// <summary>
    /// Tek bir problem için tüm AI Ajan Koordinatör analizini çalıştırır ve ilerlemeyi satır altında canlı gösterir.
    /// </summary>
    private async Task RunQuickAnalysis(Guid problemId)
    {
        if (quickAnalyzingProblemId is not null) return;

        quickAnalyzingProblemId = problemId;
        quickAnalysisProgress = null;
        StateHasChanged();

        try
        {
            // Her adım güncellemesinde arayüzü yeniliyoruz
            await AgentCoordinator.RunFullAnalysisAsync(problemId, steps =>
            {
                quickAnalysisProgress = steps.ToList();
                InvokeAsync(StateHasChanged);
            });

            // Skorların güncellenmesi için problemleri yeniden yüklüyoruz
            await LoadProblems();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Hızlı analiz hatası (ProblemId: {problemId}): {ex.Message}");
        }
        finally
        {
            quickAnalyzingProblemId = null;
            quickAnalysisProgress = null;
            StateHasChanged();
        }
    }

    // Koordinatör adım durumuna göre rozet rengi
    private string GetStepBadgeClass(AgentStepStatus status) => status switch
    {
        AgentStepStatus.Completed => "bg-success",
        AgentStepStatus.Running => "bg-primary",
        AgentStepStatus.Failed => "bg-danger",
        _ => "bg-secondary"
    };

    // Koordinatör adım durumuna göre ikon
    private string GetStepIcon(AgentStepStatus status) => status switch
    {
        AgentStepStatus.Completed => "✅",
        AgentStepStatus.Running => "⏳",
        AgentStepStatus.Failed => "⚠️",
        _ => "•"
    };
}
