@page "/grant-finder"
@rendermode InteractiveServer

@using MSC.IdeaForge.Domain.Interfaces
@using MSC.IdeaForge.Domain.ValueObjects
@inject MSC.IdeaForge.Application.Problems.Queries.GetProblemsHandler GetProblemsHandler
@inject IAIProvider AIProvider

<PageTitle>Hibe Bulucu</PageTitle>

<div class="container mt-4" style="max-width: 1000px;">
    @* Sayfa Başlığı *@
    <div class="mb-4">
        <h1 class="font-weight-bold text-dark mb-1" style="letter-spacing: -1px;">Hibe Bulucu (Grant Finder)</h1>
        <p class="text-muted mb-0">Seçilen problem/proje için Türkiye'deki uygun hibe, destek ve teşvik programlarını yapay zeka ile bulun.</p>
    </div>

    <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff; border: 1px solid #e3e6f0 !important;">
        <div class="card-body p-3">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger py-2 mb-3 small">@errorMessage</div>
            }
            <div class="row g-2 align-items-end">
                <div class="col-md-9">
                    <label class="form-label small text-muted mb-1 font-weight-bold">Problem Seçin</label>
                    <select class="form-select form-select-sm" value="@selectedProblemId" @onchange="OnProblemSelected">
                        <option value="">-- Problem seçin --</option>
                        @if (problems is not null)
                        {
                            @foreach (var p in problems)
                            {
                                <option value="@p.Id">@p.Title</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    @if (isSearching)
                    {
                        <button class="btn btn-primary btn-sm w-100 d-flex align-items-center justify-content-center gap-2" disabled>
                            <span class="spinner-border spinner-border-sm" role="status"></span> Aranıyor...
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-primary btn-sm w-100" @onclick="FindGrants" disabled="@(selectedProblemId == Guid.Empty)">
                            🔍 Hibe Bul
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    @* Sonuçlar *@
    @if (grants is not null)
    {
        @if (!grants.Any())
        {
            <div class="alert alert-light text-center py-4 border shadow-sm" style="border-radius: 8px;">
                Bu proje için uygun hibe/destek programı bulunamadı.
            </div>
        }
        else
        {
            <div class="mb-3">
                <h4 class="font-weight-bold text-dark mb-0"><span class="bi bi-cash-stack text-success"></span> Bulunan Programlar (@grants.Count)</h4>
            </div>
            <div class="row g-3">
                @foreach (var g in grants.OrderByDescending(g => g.MatchScore))
                {
                    <div class="col-12">
                        <div class="card shadow-sm border-0" style="border-radius: 12px; border-left: 4px solid @GetMatchColor(g.MatchScore) !important;">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                                    <div>
                                        <h5 class="font-weight-bold text-dark m-0">@g.Name</h5>
                                        <span class="text-muted small"><span class="bi bi-building"></span> @g.Organization</span>
                                    </div>
                                    <div class="text-center">
                                        <span class="badge text-white px-3 py-2" style="background-color: @GetMatchColor(g.MatchScore); font-size: 0.9rem;">
                                            %@g.MatchScore Uygun
                                        </span>
                                    </div>
                                </div>
                                <p class="text-dark small mb-2" style="white-space: pre-line;">@g.Description</p>
                                <div class="row g-2 mb-2">
                                    <div class="col-md-6">
                                        <span class="text-muted small d-block"><span class="bi bi-wallet2"></span> Tutar</span>
                                        <span class="text-dark small font-weight-bold">@DisplayValue(g.Amount)</span>
                                    </div>
                                    <div class="col-md-6">
                                        <span class="text-muted small d-block"><span class="bi bi-calendar-x"></span> Son Başvuru</span>
                                        <span class="text-dark small font-weight-bold">@DisplayValue(g.Deadline)</span>
                                    </div>
                                    <div class="col-12">
                                        <span class="text-muted small d-block"><span class="bi bi-check2-square"></span> Uygunluk Kriterleri</span>
                                        <span class="text-dark small">@DisplayValue(g.EligibilityCriteria)</span>
                                    </div>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(g.ApplicationUrl))
                                {
                                    <a href="@g.ApplicationUrl" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary btn-sm py-0 px-2" style="font-size: 0.78rem;">
                                        Başvuru / Bilgi →
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private IEnumerable<MSC.IdeaForge.Application.Problems.DTOs.ProblemDto>? problems;
    private Guid selectedProblemId = Guid.Empty;
    private List<Grant>? grants;
    private bool isSearching = false;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        problems = await GetProblemsHandler.HandleAsync();
    }

    private void OnProblemSelected(ChangeEventArgs e)
    {
        grants = null;
        errorMessage = "";
        selectedProblemId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : Guid.Empty;
    }

    /// <summary>
    /// Seçili problem için yapay zeka ile uygun hibe programlarını arar.
    /// </summary>
    private async Task FindGrants()
    {
        if (selectedProblemId == Guid.Empty) return;

        var problem = problems?.FirstOrDefault(p => p.Id == selectedProblemId);
        if (problem is null) return;

        errorMessage = "";
        isSearching = true;
        grants = null;
        StateHasChanged();
        try
        {
            grants = await AIProvider.FindGrantsAsync(problem.Title, problem.Description, problem.Sector);
        }
        catch (Exception ex)
        {
            errorMessage = $"Hibe araması sırasında bir hata oluştu: {ex.Message}";
        }
        finally
        {
            isSearching = false;
            StateHasChanged();
        }
    }

    // Match skoruna göre renk: yüksek yeşil, orta sarı, düşük kırmızı
    private string GetMatchColor(int score) => score switch
    {
        >= 70 => "#198754",
        >= 40 => "#ffc107",
        _ => "#dc3545"
    };

    private static string DisplayValue(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
}
