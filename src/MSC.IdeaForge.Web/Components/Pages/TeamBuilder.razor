@page "/team-builder"
@rendermode InteractiveServer
@using MSC.IdeaForge.Domain.Interfaces
@using MSC.IdeaForge.Domain.ValueObjects
@inject MSC.IdeaForge.Application.Problems.Queries.GetProblemsHandler GetProblemsHandler
@inject IAIProvider AIProvider
@inject MSC.IdeaForge.Application.FounderProfiles.Queries.GetFounderProfileHandler GetFounderProfileHandler

<PageTitle>Ekip Oluşturucu</PageTitle>

<div class="container mt-4" style="max-width: 1000px;">
    <div class="mb-4">
        <h1 class="font-weight-bold text-dark mb-1" style="letter-spacing: -1px;">Ekip Oluşturucu (Team Builder)</h1>
        <p class="text-muted mb-0">Seçilen proje için gerekli ekip rollerini yapay zeka ile analiz edin ve kurucu profiliyle karşılaştırın.</p>
    </div>

    <div class="card shadow-sm border-0 mb-3" style="border-radius: 12px; background-color: #fff; border: 1px solid #e3e6f0 !important;">
        <div class="card-body p-3">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger py-2 mb-3 small">@errorMessage</div>
            }
            <div class="row g-2 align-items-end">
                <div class="col-md-8">
                    <label class="form-label small text-muted mb-1 font-weight-bold">Problem Seçin</label>
                    <select class="form-select form-select-sm" value="@selectedProblemId" @onchange="OnProblemSelected">
                        <option value="">-- Problem seçin --</option>
                        @if (problems is not null)
                        {
                            @foreach (var p in problems)
                            {
                                <option value="@p.Id">@p.Title</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    @if (isAnalyzing)
                    {
                        <button class="btn btn-primary btn-sm w-100 d-flex align-items-center justify-content-center gap-2" disabled>
                            <span class="spinner-border spinner-border-sm" role="status"></span> Analiz ediliyor...
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-primary btn-sm w-100" @onclick="Analyze" disabled="@(selectedProblemId == Guid.Empty)">
                            🤖 AI ile Ekip Analizi Yap
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (roles is not null)
    {
        @* Kurucu profili karşılaştırma özeti *@
        <div class="card shadow-sm border-0 mb-3" style="border-radius: 12px; border-left: 4px solid #4f46e5 !important;">
            <div class="card-body p-3">
                <h6 class="font-weight-bold mb-1" style="color: #4f46e5;">👤 Kurucu Profili Karşılaştırması</h6>
                @if (founder is null)
                {
                    <p class="mb-0 text-muted small">Henüz bir kurucu profili tanımlanmamış. <a href="/founder-profile">Kurucu Profili</a> sayfasından ekleyebilirsiniz.</p>
                }
                else
                {
                    <p class="mb-1 text-dark small"><strong>Yetenekler:</strong> @(string.IsNullOrWhiteSpace(founder.Skills) ? "-" : founder.Skills)</p>
                    <p class="mb-0 text-success small"><strong>@roles.Count(r => r.IsFounderCanHandle)</strong> / @roles.Count rolü kurucu üstlenebilir; kalan <strong>@roles.Count(r => !r.IsFounderCanHandle)</strong> rol için işe alım önerilir.</p>
                }
            </div>
        </div>

        @if (!roles.Any())
        {
            <div class="alert alert-light text-center py-4 border shadow-sm" style="border-radius: 8px;">Ekip rolü önerisi bulunamadı.</div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var r in roles)
                {
                    <div class="col-md-6">
                        <div class="card h-100 shadow-sm border-0" style="border-radius: 12px; border-left: 4px solid @(r.IsFounderCanHandle ? "#198754" : "#fd7e14") !important;">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                                    <h5 class="font-weight-bold text-dark m-0">@r.Role</h5>
                                    <span class="badge @GetPriorityBadge(r.Priority)">@DisplayValue(r.Priority)</span>
                                </div>
                                <p class="text-dark small mb-2">@DisplayValue(r.Description)</p>
                                <div class="mb-2">
                                    <span class="text-muted small font-weight-bold d-block">🛠️ Gerekli Yetenekler</span>
                                    <span class="text-dark small">@DisplayValue(r.Skills)</span>
                                </div>
                                <div class="d-flex flex-wrap gap-2 mb-2">
                                    @if (r.IsFounderCanHandle)
                                    {
                                        <span class="badge bg-success text-white">✔ Kurucu Halledebilir</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">✖ İşe Alım Gerekli</span>
                                    }
                                </div>
                                <div class="row g-2">
                                    <div class="col-6">
                                        <span class="text-muted small d-block">💰 Tahmini Maliyet</span>
                                        <span class="text-dark small font-weight-bold">@DisplayValue(r.EstimatedCost)</span>
                                    </div>
                                    <div class="col-6">
                                        <span class="text-muted small d-block">📅 İşe Alım Zamanı</span>
                                        <span class="text-dark small font-weight-bold">@DisplayValue(r.HiringTimeline)</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private IEnumerable<MSC.IdeaForge.Application.Problems.DTOs.ProblemDto>? problems;
    private Guid selectedProblemId = Guid.Empty;
    private List<TeamRole>? roles;
    private MSC.IdeaForge.Application.FounderProfiles.DTOs.FounderProfileDto? founder;
    private bool isAnalyzing = false;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        problems = await GetProblemsHandler.HandleAsync();
        founder = await GetFounderProfileHandler.HandleAsync();
    }

    private void OnProblemSelected(ChangeEventArgs e)
    {
        roles = null;
        errorMessage = "";
        selectedProblemId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : Guid.Empty;
    }

    /// <summary>
    /// Seçili proje için yapay zeka ile ekip ihtiyaç analizini çalıştırır.
    /// </summary>
    private async Task Analyze()
    {
        var problem = problems?.FirstOrDefault(p => p.Id == selectedProblemId);
        if (problem is null) return;

        errorMessage = "";
        isAnalyzing = true;
        roles = null;
        StateHasChanged();
        try
        {
            // Çözüm tipi opsiyoneldir; bu sayfada bağlam olarak geçilmiyor
            roles = await AIProvider.AnalyzeTeamNeedsAsync(problem.Title, problem.Description, problem.Sector, null);
        }
        catch (Exception ex)
        {
            errorMessage = $"Ekip analizi sırasında bir hata oluştu: {ex.Message}";
        }
        finally
        {
            isAnalyzing = false;
            StateHasChanged();
        }
    }

    private string GetPriorityBadge(string priority) => priority?.ToLower() switch
    {
        var p when p != null && (p.Contains("yüksek") || p.Contains("high")) => "bg-danger text-white",
        var p when p != null && (p.Contains("orta") || p.Contains("medium")) => "bg-warning text-dark",
        var p when p != null && (p.Contains("düşük") || p.Contains("low")) => "bg-secondary text-white",
        _ => "bg-info text-dark"
    };

    private static string DisplayValue(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
}
