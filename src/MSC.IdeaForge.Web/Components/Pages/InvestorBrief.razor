@page "/investor-brief"
@rendermode InteractiveServer

@using System.Text
@using MSC.IdeaForge.Application.InvestorBriefs.DTOs
@inject MSC.IdeaForge.Application.Problems.Queries.GetProblemsHandler GetProblemsHandler
@inject MSC.IdeaForge.Application.InvestorBriefs.Commands.GenerateInvestorBriefHandler GenerateInvestorBriefHandler
@inject MSC.IdeaForge.Application.InvestorBriefs.Queries.GetInvestorBriefHandler GetInvestorBriefHandler
@inject IJSRuntime JsRuntime

<PageTitle>Yatırımcı Briefingi</PageTitle>

<div class="container mt-4" style="max-width: 900px;">
    @* Başlık + Kontroller (yazdırırken gizlenir) *@
    <div class="mb-4 d-print-none">
        <h1 class="font-weight-bold text-dark mb-1" style="letter-spacing: -1px;">Yatırımcı Briefingi</h1>
        <p class="text-muted mb-0">Seçilen problem için profesyonel bir yatırımcı sunum özeti oluşturun.</p>
    </div>

    <div class="card shadow-sm border-0 mb-4 d-print-none" style="border-radius: 12px; background-color: #fff; border: 1px solid #e3e6f0 !important;">
        <div class="card-body p-3">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger py-2 mb-3 small">@errorMessage</div>
            }
            <div class="row g-2 align-items-end">
                <div class="col-md-7">
                    <label class="form-label small text-muted mb-1 font-weight-bold">Problem Seçin</label>
                    <select class="form-select form-select-sm" value="@selectedProblemId" @onchange="OnProblemSelected">
                        <option value="">-- Problem seçin --</option>
                        @if (problems is not null)
                        {
                            @foreach (var p in problems)
                            {
                                <option value="@p.Id">@p.Title</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-5 d-flex gap-2">
                    @if (isGenerating)
                    {
                        <button class="btn btn-primary btn-sm flex-grow-1 d-flex align-items-center justify-content-center gap-2" disabled>
                            <span class="spinner-border spinner-border-sm" role="status"></span> Oluşturuluyor...
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-primary btn-sm flex-grow-1" @onclick="GenerateBrief" disabled="@(selectedProblemId == Guid.Empty)">
                            🤖 AI ile Brief Oluştur
                        </button>
                    }
                    @if (brief is not null)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="CopyBrief" title="Kopyala">📋</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="PrintBrief" title="Yazdır">🖨️</button>
                    }
                </div>
            </div>
            @if (!string.IsNullOrEmpty(copyMessage))
            {
                <div class="text-success small font-weight-bold mt-2">@copyMessage</div>
            }
        </div>
    </div>

    @* Briefing Sonucu (profesyonel sunum formatı) *@
    @if (brief is not null)
    {
        <div class="card shadow-sm border-0" style="border-radius: 12px; border: 1px solid #e3e6f0;">
            <div class="card-body p-4">
                <div class="text-center mb-4 pb-3" style="border-bottom: 2px solid #0d6efd;">
                    <h2 class="font-weight-bold text-dark mb-1">@selectedProblemTitle</h2>
                    <span class="text-muted small">Yatırımcı Briefingi — @brief.GeneratedAt.ToLocalTime().ToString("yyyy-MM-dd")</span>
                </div>

                @RenderSection("Yönetici Özeti", brief.ExecutiveSummary, "#0d6efd")
                @RenderSection("Problem Tanımı", brief.ProblemStatement, "#dc3545")
                @RenderSection("Pazar Fırsatı", brief.MarketOpportunity, "#198754")
                @RenderSection("Çözüm", brief.Solution, "#6f42c1")
                @RenderSection("İş Modeli", brief.BusinessModel, "#fd7e14")
                @RenderSection("Rekabet Avantajı", brief.CompetitiveAdvantage, "#20c997")
                @RenderSection("Mevcut İlerleme (Traction)", brief.Traction, "#0dcaf0")

                <div class="row g-3 mt-2">
                    <div class="col-md-6">
                        <div class="p-3 rounded h-100" style="background-color: #f0fdf4; border: 1px solid #bbf7d0;">
                            <h6 class="font-weight-bold text-success mb-1">💰 Talep Edilen Yatırım</h6>
                            <p class="mb-0 text-dark" style="white-space: pre-line;">@DisplayValue(brief.AskAmount)</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 rounded h-100" style="background-color: #eff6ff; border: 1px solid #bfdbfe;">
                            <h6 class="font-weight-bold text-primary mb-1">📊 Fonların Kullanımı</h6>
                            <p class="mb-0 text-dark" style="white-space: pre-line;">@DisplayValue(brief.UseOfFunds)</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (selectedProblemId != Guid.Empty && !isGenerating)
    {
        <div class="alert alert-light text-center py-4 border shadow-sm d-print-none" style="border-radius: 8px;">
            Bu problem için henüz bir yatırımcı briefingi oluşturulmamış. Yukarıdaki buton ile oluşturabilirsiniz.
        </div>
    }
</div>

@code {
    private IEnumerable<MSC.IdeaForge.Application.Problems.DTOs.ProblemDto>? problems;
    private Guid selectedProblemId = Guid.Empty;
    private string selectedProblemTitle = "";
    private InvestorBriefDto? brief;
    private bool isGenerating = false;
    private string errorMessage = "";
    private string copyMessage = "";

    protected override async Task OnInitializedAsync()
    {
        problems = await GetProblemsHandler.HandleAsync();
    }

    private async Task OnProblemSelected(ChangeEventArgs e)
    {
        brief = null;
        errorMessage = "";
        copyMessage = "";

        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            selectedProblemId = id;
            selectedProblemTitle = problems?.FirstOrDefault(p => p.Id == id)?.Title ?? "";
            brief = await GetInvestorBriefHandler.HandleAsync(id);
        }
        else
        {
            selectedProblemId = Guid.Empty;
        }
    }

    /// <summary>
    /// Seçili problem için yapay zeka yatırımcı briefingini üretir.
    /// </summary>
    private void GenerateBrief()
    {
        if (selectedProblemId == Guid.Empty) return;

        errorMessage = "";
        copyMessage = "";
        isGenerating = true;
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            try
            {
                brief = await GenerateInvestorBriefHandler.HandleAsync(
                    new MSC.IdeaForge.Application.InvestorBriefs.Commands.GenerateInvestorBriefCommand { ProblemId = selectedProblemId });
            }
            catch (Exception ex)
            {
                errorMessage = $"Briefing oluşturulurken bir hata oluştu: {ex.Message}";
            }
            finally
            {
                isGenerating = false;
                await InvokeAsync(StateHasChanged);
            }
        });
    }

    /// <summary>
    /// Briefing metnini panoya kopyalar.
    /// </summary>
    private async Task CopyBrief()
    {
        if (brief is null) return;

        var sb = new StringBuilder();
        sb.AppendLine($"YATIRIMCI BRIEFINGI — {selectedProblemTitle}");
        sb.AppendLine();
        sb.AppendLine($"Yönetici Özeti: {brief.ExecutiveSummary}");
        sb.AppendLine($"Problem Tanımı: {brief.ProblemStatement}");
        sb.AppendLine($"Pazar Fırsatı: {brief.MarketOpportunity}");
        sb.AppendLine($"Çözüm: {brief.Solution}");
        sb.AppendLine($"İş Modeli: {brief.BusinessModel}");
        sb.AppendLine($"Rekabet Avantajı: {brief.CompetitiveAdvantage}");
        sb.AppendLine($"Traction: {brief.Traction}");
        sb.AppendLine($"Talep Edilen Yatırım: {brief.AskAmount}");
        sb.AppendLine($"Fonların Kullanımı: {brief.UseOfFunds}");

        try
        {
            await JsRuntime.InvokeVoidAsync("appInterop.copyToClipboard", sb.ToString());
            copyMessage = "Kopyalandı!";
        }
        catch
        {
            copyMessage = "Kopyalanamadı.";
        }
    }

    // Yazdırma diyaloğunu açar
    private async Task PrintBrief() => await JsRuntime.InvokeVoidAsync("window.print");

    // Tek bir briefing bölümünü render eder
    private RenderFragment RenderSection(string title, string content, string color) => @<div class="mb-3">
        <h6 class="font-weight-bold mb-1" style="color: @color;">@title</h6>
        <p class="mb-0 text-dark" style="white-space: pre-line;">@DisplayValue(content)</p>
    </div>;

    private static string DisplayValue(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
}
