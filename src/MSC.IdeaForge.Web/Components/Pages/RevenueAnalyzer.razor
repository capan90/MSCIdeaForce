@page "/revenue-analyzer"

@using MSC.IdeaForge.Application.Revenues.DTOs
@inject MSC.IdeaForge.Application.Problems.Queries.GetProblemsHandler GetProblemsHandler
@inject MSC.IdeaForge.Application.Revenues.Commands.AnalyzeRevenueHandler AnalyzeRevenueHandler
@inject MSC.IdeaForge.Application.Revenues.Queries.GetRevenueAnalysisHandler GetRevenueAnalysisHandler

<PageTitle>Gelir Analizörü</PageTitle>

<div class="container mt-4">
    @* Sayfa Başlığı *@
    <div class="mb-4">
        <h1 class="font-weight-bold text-dark mb-1" style="letter-spacing: -1px;">Gelir Analizörü (Revenue Analyzer)</h1>
        <p class="text-muted mb-0">Bir problemi seçin ve yapay zeka ile gelir modelini, fiyatlandırma stratejisini ve gelir potansiyelini analiz edin.</p>
    </div>

    @* Problem Seçim ve Analiz Formu *@
    <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff; border: 1px solid #e3e6f0 !important;">
        <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #059669, #10b981); border-bottom: none;">
            <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                <span class="bi bi-cash-coin"></span> Gelir Modeli Analizi
            </h5>
        </div>
        <div class="card-body p-4">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger py-2 mb-3 small">@errorMessage</div>
            }

            <div class="row g-3 align-items-end">
                <div class="col-md-9">
                    <label class="form-label small text-muted mb-1 font-weight-bold">Problem Seçin</label>
                    <select class="form-select form-select-sm" value="@selectedProblemId" @onchange="OnProblemSelected">
                        <option value="">-- Problem seçin --</option>
                        @if (problems is not null)
                        {
                            @foreach (var p in problems)
                            {
                                <option value="@p.Id">@p.Title</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    @if (isAnalyzing)
                    {
                        <button class="btn btn-success btn-sm w-100 d-flex align-items-center justify-content-center gap-2" disabled>
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                            Analiz ediliyor...
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-success btn-sm w-100" @onclick="RunRevenueAnalysis" disabled="@(selectedProblemId == Guid.Empty)">
                            💰 AI ile Gelir Analizi Yap
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    @* Analiz Sonuçları *@
    @if (result is not null)
    {
        <RevenueAnalysisView Result="result" />
    }
    else if (selectedProblemId != Guid.Empty && !isAnalyzing)
    {
        <div class="alert alert-light text-center py-4 border shadow-sm" style="border-radius: 8px;">
            Bu problem için henüz bir gelir analizi yapılmamış. Yukarıdaki butonla analizi başlatabilirsiniz.
        </div>
    }
</div>

@code {
    private IEnumerable<MSC.IdeaForge.Application.Problems.DTOs.ProblemDto>? problems;
    private Guid selectedProblemId = Guid.Empty;
    private RevenueAnalysisDto? result;
    private bool isAnalyzing = false;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        problems = await GetProblemsHandler.HandleAsync();
    }

    /// <summary>
    /// Dropdown'dan problem seçildiğinde varsa mevcut analizi yükler.
    /// </summary>
    private async Task OnProblemSelected(ChangeEventArgs e)
    {
        result = null;
        errorMessage = "";

        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            selectedProblemId = id;
            result = await GetRevenueAnalysisHandler.HandleAsync(id);
        }
        else
        {
            selectedProblemId = Guid.Empty;
        }
    }

    /// <summary>
    /// Seçili problem için yapay zeka gelir analizini çalıştırır ve sonucu kaydeder.
    /// </summary>
    private async Task RunRevenueAnalysis()
    {
        if (selectedProblemId == Guid.Empty) return;

        errorMessage = "";
        isAnalyzing = true;
        StateHasChanged();

        try
        {
            result = await AnalyzeRevenueHandler.HandleAsync(
                new MSC.IdeaForge.Application.Revenues.Commands.AnalyzeRevenueCommand { ProblemId = selectedProblemId });
        }
        catch (Exception ex)
        {
            errorMessage = $"Gelir analizi sırasında bir hata oluştu: {ex.Message}";
        }
        finally
        {
            isAnalyzing = false;
            StateHasChanged();
        }
    }
}
