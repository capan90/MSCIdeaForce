@page "/"
@rendermode InteractiveServer

@inject MSC.IdeaForge.Application.Dashboard.DashboardQueryHandler DashboardQueryHandler
@inject NavigationManager NavigationManager
@inject MSC.IdeaForge.Application.Problems.Queries.GetProblemsHandler GetProblemsHandler
@inject MSC.IdeaForge.Application.Problems.Commands.CreateProblemHandler CreateProblemHandler
@inject MSC.IdeaForge.Application.Decisions.Queries.GetAllDecisionsHandler GetAllDecisionsHandler
@inject MSC.IdeaForge.Application.Signals.Queries.GetImportedSignalsHandler GetImportedSignalsHandler

<PageTitle>Dashboard - MSC IdeaForge</PageTitle>

<div class="container-fluid py-4" style="max-width: 1200px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 font-weight-bold text-dark mb-1">Yönetim Paneli</h1>
            <p class="text-muted small mb-0">MSC IdeaForge genel durum göstergeleri ve özet verileri</p>
        </div>
    </div>

    @* Hızlı Problem Ekleme Formu *@
    <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; border: 1px solid #e3e6f0 !important; background-color: #f8f9fc;">
        <div class="card-body py-2.5 px-3">
            <div class="row g-2 align-items-center">
                <div class="col-md-1">
                    <span class="bi bi-lightning-charge-fill text-warning" style="font-size: 1.2rem;"></span>
                </div>
                <div class="col-md-4">
                    <input class="form-control form-control-sm" placeholder="Problem başlığı..." @bind="quickTitle" />
                </div>
                <div class="col-md-3">
                    <input class="form-control form-control-sm" placeholder="Sektör (opsiyonel)" @bind="quickSector" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary btn-sm w-100" @onclick="QuickAddProblem" disabled="@isQuickAdding">
                        @if (isQuickAdding)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                        }
                        else
                        {
                            <span>⚡ Hızlı Ekle</span>
                        }
                    </button>
                </div>
                <div class="col-md-2">
                    @if (!string.IsNullOrEmpty(quickMessage))
                    {
                        <span class="text-success small">@quickMessage</span>
                    }
                    @if (!string.IsNullOrEmpty(quickError))
                    {
                        <span class="text-danger small">@quickError</span>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Veriler yükleniyor...</p>
        </div>
    }
    else if (data is null)
    {
        <div class="alert alert-danger text-center">
            Dashboard verileri yüklenirken bir hata oluştu.
        </div>
    }
    else
    {
        @* KPI Kartları *@
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card shadow-sm border-0 h-100 p-3" style="border-radius: 12px; background: linear-gradient(135deg, #f8f9fc, #ffffff); border-left: 4px solid #0d6efd !important;">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted text-uppercase small font-weight-bold">Toplam Problem</span>
                            <h2 class="font-weight-bold text-dark m-0 mt-1">@data.TotalProblemsCount</h2>
                        </div>
                        <span class="bi bi-lightbulb-fill text-primary" style="font-size: 1.8rem;"></span>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="card shadow-sm border-0 h-100 p-3" style="border-radius: 12px; background: linear-gradient(135deg, #f8f9fc, #ffffff); border-left: 4px solid #6f42c1 !important;">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted text-uppercase small font-weight-bold">Analiz Edildi</span>
                            <h2 class="font-weight-bold text-dark m-0 mt-1">@data.AnalyzedProblemsCount</h2>
                        </div>
                        <span class="bi bi-cpu-fill" style="font-size: 1.8rem; color: #6f42c1;"></span>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="card shadow-sm border-0 h-100 p-3" style="border-radius: 12px; background: linear-gradient(135deg, #f8f9fc, #ffffff); border-left: 4px solid #198754 !important;">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted text-uppercase small font-weight-bold">Doğrulandı</span>
                            <h2 class="font-weight-bold text-dark m-0 mt-1">@data.ValidatedProblemsCount</h2>
                        </div>
                        <span class="bi bi-shield-fill-check text-success" style="font-size: 1.8rem;"></span>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="card shadow-sm border-0 h-100 p-3" style="border-radius: 12px; background: linear-gradient(135deg, #f8f9fc, #ffffff); border-left: 4px solid #0dcaf0 !important;">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted text-uppercase small font-weight-bold">Toplam Sinyal</span>
                            <h2 class="font-weight-bold text-dark m-0 mt-1">@data.TotalSignalsCount</h2>
                        </div>
                        <span class="bi bi-broadcast-pin text-info" style="font-size: 1.8rem;"></span>
                    </div>
                </div>
            </div>

            @* Toplam AI Analizi sayısı *@
            <div class="col-6 col-md-3">
                <div class="card shadow-sm border-0 h-100 p-3" style="border-radius: 12px; background: linear-gradient(135deg, #f8f9fc, #ffffff); border-left: 4px solid #fd7e14 !important;">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted text-uppercase small font-weight-bold">Toplam AI Analizi</span>
                            <h2 class="font-weight-bold text-dark m-0 mt-1">@data.TotalAiAnalysisCount</h2>
                        </div>
                        <span class="bi bi-robot" style="font-size: 1.8rem; color: #fd7e14;"></span>
                    </div>
                </div>
            </div>

            @* Ortalama Fırsat Skoru *@
            <div class="col-6 col-md-3">
                <div class="card shadow-sm border-0 h-100 p-3" style="border-radius: 12px; background: linear-gradient(135deg, #f8f9fc, #ffffff); border-left: 4px solid #ffc107 !important;">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-muted text-uppercase small font-weight-bold">Ort. Fırsat Skoru</span>
                            <h2 class="font-weight-bold text-dark m-0 mt-1">@data.AverageOpportunityScore.ToString("0.0") <span class="text-muted" style="font-size: 1rem;">/ 10</span></h2>
                        </div>
                        <span class="bi bi-star-fill text-warning" style="font-size: 1.8rem;"></span>
                    </div>
                </div>
            </div>
        </div>

        @* Grafikler & Dağılımlar Paneli *@
        <div class="row g-3 mb-4">
            @* Sektör Dağılımı Bar Chart *@
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100 p-3" style="border-radius: 12px; background-color: #fff; border: 1px solid #e3e6f0;">
                    <h6 class="font-weight-bold text-dark mb-3"><span class="bi bi-pie-chart-fill text-primary"></span> Sektör Dağılımı</h6>
                    <div class="d-flex flex-column gap-2.5">
                        @if (sectorDistribution is null || !sectorDistribution.Any())
                        {
                            <span class="text-muted small italic">Veri bulunamadı.</span>
                        }
                        else
                        {
                            @foreach (var (sector, count) in sectorDistribution)
                            {
                                var pct = totalProblems > 0 ? (int)Math.Round((double)count / totalProblems * 100) : 0;
                                <div>
                                    <div class="d-flex justify-content-between mb-1 small text-dark">
                                        <span class="text-truncate" style="max-width: 150px;">@sector</span>
                                        <strong>@count problem (%@pct)</strong>
                                    </div>
                                    <div class="progress" style="height: 8px; border-radius: 4px;">
                                        <div class="progress-bar bg-primary" role="progressbar" style="width: @pct%;"></div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            @* Problem Durum Dağılımı Progress Bar *@
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100 p-3" style="border-radius: 12px; background-color: #fff; border: 1px solid #e3e6f0;">
                    <h6 class="font-weight-bold text-dark mb-3"><span class="bi bi-activity text-success"></span> Problem Durum Dağılımı</h6>
                    <div class="d-flex flex-column gap-2.5">
                        @foreach (var (status, count) in statusDistribution)
                        {
                            var pct = totalProblems > 0 ? (int)Math.Round((double)count / totalProblems * 100) : 0;
                            <div>
                                <div class="d-flex justify-content-between mb-1 small text-dark">
                                    <span>@GetStatusText(status)</span>
                                    <strong>@count (%@pct)</strong>
                                </div>
                                <div class="progress" style="height: 8px; border-radius: 4px;">
                                    <div class="progress-bar @GetStatusProgressClass(status)" role="progressbar" style="width: @pct%;"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* En Yüksek 5 Fırsat Skoru Bar Chart *@
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100 p-3" style="border-radius: 12px; background-color: #fff; border: 1px solid #e3e6f0;">
                    <h6 class="font-weight-bold text-dark mb-3"><span class="bi bi-bar-chart-fill text-danger"></span> En Yüksek Fırsat Skorları</h6>
                    <div class="d-flex flex-column gap-2.5">
                        @if (data.TopOpportunityProblems is null || !data.TopOpportunityProblems.Any())
                        {
                            <span class="text-muted small italic">Henüz skorlanmış problem yok.</span>
                        }
                        else
                        {
                            @foreach (var opp in data.TopOpportunityProblems)
                            {
                                var pct = (int)Math.Round(opp.OpportunityScore * 10);
                                <div>
                                    <div class="d-flex justify-content-between mb-1 small text-dark">
                                        <span class="text-truncate" style="max-width: 150px;">@opp.Title</span>
                                        <strong>@opp.OpportunityScore.ToString("0.0") / 10</strong>
                                    </div>
                                    <div class="progress" style="height: 8px; border-radius: 4px;">
                                        <div class="progress-bar bg-danger" role="progressbar" style="width: @pct%;"></div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Detay Listeleri ve Tablolar *@
        <div class="row g-4">
            @* Sol Kolon: Fırsatlar ve Son Eklenenler *@
            <div class="col-lg-8 d-flex flex-column gap-4">
                @* En Yüksek Fırsat Skoru Tablosu *@
                <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
                    <div class="card-header bg-success text-white py-3 border-bottom-0">
                        <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                            <span class="bi bi-star-fill"></span> En Yüksek Fırsat Skorlu Problemler (İlk 5)
                        </h5>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col" style="width: 60%;">Problem</th>
                                    <th scope="col" class="text-center" style="width: 20%;">Durum</th>
                                    <th scope="col" class="text-end" style="width: 20%;">Fırsat Skoru</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (data.TopOpportunityProblems == null || !data.TopOpportunityProblems.Any())
                                {
                                    <tr>
                                        <td colspan="3" class="text-center text-muted py-4">Henüz puanlanmış bir fırsat bulunmuyor.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var opportunity in data.TopOpportunityProblems)
                                    {
                                        <tr @onclick="() => NavigateToProblem(opportunity.Id)" style="cursor: pointer;">
                                            <td>
                                                <span class="font-weight-bold text-dark d-block">@opportunity.Title</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge @GetStatusBadgeClass(opportunity.Status)">@GetStatusText(opportunity.Status)</span>
                                            </td>
                                            <td class="text-end">
                                                <span class="badge bg-success font-weight-bold text-white px-2 py-1.5" style="font-size: 0.9rem;">
                                                    @opportunity.OpportunityScore.ToString("F1")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                @* Son Eklenen Problemler Tablosu *@
                <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
                    <div class="card-header bg-primary text-white py-3 border-bottom-0">
                        <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                            <span class="bi bi-clock-history"></span> Son Eklenen Problemler
                        </h5>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col" style="width: 45%;">Problem</th>
                                    <th scope="col" class="text-center" style="width: 20%;">Öncelik</th>
                                    <th scope="col" class="text-center" style="width: 20%;">Durum</th>
                                    <th scope="col" class="text-end" style="width: 15%;">Eklenme</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!data.RecentProblems.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-4">Sistemde kayıtlı problem bulunmuyor.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var problem in data.RecentProblems)
                                    {
                                        <tr @onclick="() => NavigateToProblem(problem.Id)" style="cursor: pointer;">
                                            <td>
                                                <span class="font-weight-bold text-dark d-block text-truncate" style="max-width: 280px;">@problem.Title</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge @GetPriorityBadgeClass(problem.Priority)">@GetPriorityText(problem.Priority)</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge @GetStatusBadgeClass(problem.Status)">@GetStatusText(problem.Status)</span>
                                            </td>
                                            <td class="text-end text-muted small">
                                                @FormatRelativeTime(problem.CreatedAt)
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            @* Sağ Kolon: Doğrulama Bekleyenler *@
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 h-100" style="border-radius: 12px; overflow: hidden;">
                    <div class="card-header bg-warning text-dark py-3 border-bottom-0">
                        <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                            <span class="bi bi-shield-exclamation"></span> Doğrulama Bekleyenler
                        </h5>
                    </div>
                    <div class="card-body p-3">
                        @if (!data.ValidationPendingProblems.Any())
                        {
                            <div class="alert alert-light text-center text-muted py-4 border shadow-none mb-0">
                                Harika! Doğrulama bekleyen hiçbir problem bulunmuyor.
                            </div>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-2" style="max-height: 520px; overflow-y: auto;">
                                @foreach (var pending in data.ValidationPendingProblems)
                                {
                                    <div class="p-3 bg-light rounded hover-shadow cursor-pointer transition" @onclick="() => NavigateToProblem(pending.Id)" style="border-left: 4px solid #ffc107; cursor: pointer; border: 1px solid #e3e6f0; border-left-width: 4px;">
                                        <span class="font-weight-bold text-dark d-block text-truncate" style="font-size: 0.9rem;">@pending.Title</span>
                                        <div class="d-flex justify-content-between align-items-center mt-2">
                                            <span class="badge @GetPriorityBadgeClass(pending.Priority)" style="font-size: 0.75rem;">@GetPriorityText(pending.Priority)</span>
                                            <span class="text-muted small" style="font-size: 0.75rem;">@FormatRelativeTime(pending.CreatedAt)</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Fikir Yaşam Döngüsü Dağılımı + Öne Çıkan Fikirler *@
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card shadow-sm border-0 h-100" style="border-radius: 12px; border: 1px solid #e3e6f0;">
                    <div class="card-header bg-white border-0 py-3">
                        <h6 class="m-0 font-weight-bold text-dark"><span class="bi bi-diagram-3-fill text-primary"></span> Fikir Yaşam Döngüsü Dağılımı</h6>
                    </div>
                    <div class="card-body p-3 d-flex flex-wrap gap-2 align-content-start">
                        @foreach (var status in ideaStatusOrder)
                        {
                            <span class="badge d-flex align-items-center gap-1 text-white" style="background-color: @GetIdeaStatusColor(status); font-size: 0.78rem;">
                                @GetIdeaStatusText(status)
                                <span class="badge bg-white text-dark ms-1">@ideaStatusDistribution.GetValueOrDefault(status)</span>
                            </span>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm border-0 h-100" style="border-radius: 12px; border: 2px solid #6f42c1;">
                    <div class="card-header bg-white border-0 py-3">
                        <h6 class="m-0 font-weight-bold" style="color: #6f42c1;"><span class="bi bi-stars"></span> Öne Çıkan Fikirler (MVP Adayı & Geliştirme)</h6>
                    </div>
                    <div class="card-body p-3">
                        @if (!highlightedIdeas.Any())
                        {
                            <div class="text-muted small italic text-center py-3">Şu an MVP Adayı veya Geliştirme aşamasında fikir yok.</div>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-2" style="max-height: 220px; overflow-y: auto;">
                                @foreach (var idea in highlightedIdeas)
                                {
                                    <div class="d-flex justify-content-between align-items-center p-2 rounded bg-light border cursor-pointer" style="cursor: pointer;" @onclick="() => NavigateToProblem(idea.Id)">
                                        <span class="font-weight-bold text-dark small text-truncate" style="max-width: 70%;">@idea.Title</span>
                                        <span class="badge text-white" style="background-color: @GetIdeaStatusColor(idea.IdeaStatus); font-size: 0.7rem;">@GetIdeaStatusText(idea.IdeaStatus)</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Son Aktiviteler *@
        <div class="row g-3 mb-4">
            <div class="col-12">
                <div class="card shadow-sm border-0" style="border-radius: 12px; border: 1px solid #e3e6f0;">
                    <div class="card-header bg-white border-0 py-3">
                        <h5 class="m-0 font-weight-bold text-dark d-flex align-items-center gap-2">
                            <span class="bi bi-clock-history text-primary"></span> Son Aktiviteler
                        </h5>
                    </div>
                    <div class="card-body p-3">
                        @if (!recentActivities.Any())
                        {
                            <div class="text-muted small text-center py-3 italic">Henüz kayıtlı aktivite yok.</div>
                        }
                        else
                        {
                            <div class="d-flex flex-column">
                                @foreach (var activity in recentActivities)
                                {
                                    <div class="d-flex align-items-center gap-3 py-2 border-bottom">
                                        <span style="font-size: 1.2rem;">@activity.Icon</span>
                                        <span class="flex-grow-1 text-dark small">@activity.Description</span>
                                        <span class="text-muted small font-mono" style="white-space: nowrap;">@FormatRelativeTime(activity.Timestamp)</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Bu Hafta Özeti *@
        <div class="row g-3 mb-4">
            <div class="col-12">
                <div class="card shadow-sm border-0" style="border-radius: 12px; border: 2px solid #0d6efd;">
                    <div class="card-header bg-white border-0 py-3">
                        <h5 class="m-0 font-weight-bold text-dark"><span class="bi bi-calendar-week text-primary"></span> Bu Hafta (Son 7 Gün)</h5>
                    </div>
                    <div class="card-body p-3">
                        <div class="row g-3 text-center">
                            <div class="col-6 col-md-3">
                                <div class="p-2 rounded bg-light">
                                    <div class="h4 font-weight-bold text-primary mb-0">@weeklyProblemCount</div>
                                    <span class="text-muted small">Yeni Problem</span>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="p-2 rounded bg-light">
                                    <div class="h4 font-weight-bold mb-0" style="color:#6f42c1;">@weeklyAiAnalysisCount</div>
                                    <span class="text-muted small">AI Analizi</span>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="p-2 rounded bg-light">
                                    <div class="h4 font-weight-bold text-success mb-0">@weeklyDecisionCount</div>
                                    <span class="text-muted small">Karar</span>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="p-2 rounded bg-light">
                                    <div class="h6 font-weight-bold text-dark mb-0 text-truncate">@weeklyMostActiveSector</div>
                                    <span class="text-muted small">En Aktif Sektör</span>
                                </div>
                            </div>
                        </div>
                        @if (data.UnscoredProblemsCount > 0)
                        {
                            <div class="alert alert-warning d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3 mb-0 py-2">
                                <span class="small">💡 Şu an <strong>@data.UnscoredProblemsCount</strong> puanlanmamış problem var, puanlamak ister misiniz?</span>
                                <button class="btn btn-sm btn-primary" @onclick='() => NavigationManager.NavigateTo("/problems")'>Problemlere Git</button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private MSC.IdeaForge.Application.Dashboard.DashboardDto? data;
    private int totalProblems = 0;
    private Dictionary<string, int> sectorDistribution = new();
    private Dictionary<string, int> statusDistribution = new();

    private bool isQuickAdding = false;
    private string quickTitle = "";
    private string quickSector = "";
    private string quickMessage = "";
    private string quickError = "";

    // Son Aktiviteler beslemesi
    private List<ActivityItem> recentActivities = new();

    // Bu hafta özeti
    private int weeklyProblemCount = 0;
    private int weeklyAiAnalysisCount = 0;
    private int weeklyDecisionCount = 0;
    private string weeklyMostActiveSector = "Belirtilmemiş";

    /// <summary>
    /// Son 7 günün özetini mevcut verilerden hesaplar (eklenen problem, AI analizi, karar, en aktif sektör).
    /// </summary>
    private async Task BuildWeeklySummary(IEnumerable<MSC.IdeaForge.Application.Problems.DTOs.ProblemDto> allProblems)
    {
        var threshold = DateTime.UtcNow.AddDays(-7);

        weeklyProblemCount = allProblems.Count(p => p.CreatedAt >= threshold);
        // AI analizi yaklaşık: bu hafta eklenip Analiz Edildi/Doğrulandı durumuna gelen problemler
        weeklyAiAnalysisCount = allProblems.Count(p => (p.Status == "Analyzed" || p.Status == "Validated") && p.CreatedAt >= threshold);

        try
        {
            var decisions = await GetAllDecisionsHandler.HandleAsync();
            weeklyDecisionCount = decisions.Count(d => d.DecisionDate >= threshold);
        }
        catch { weeklyDecisionCount = 0; }

        // En aktif sektör: öncelikle bu haftanın problemleri, yoksa genel dağılım
        var weekProblems = allProblems.Where(p => p.CreatedAt >= threshold).ToList();
        var source = weekProblems.Any() ? weekProblems : allProblems.ToList();
        weeklyMostActiveSector = source
            .Where(p => !string.IsNullOrWhiteSpace(p.Sector))
            .GroupBy(p => p.Sector!)
            .OrderByDescending(g => g.Count())
            .Select(g => g.Key)
            .FirstOrDefault() ?? "Belirtilmemiş";
    }

