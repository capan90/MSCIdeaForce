    protected override async Task OnInitializedAsync()
    {
        try
        {
            data = await DashboardQueryHandler.HandleAsync(new MSC.IdeaForge.Application.Dashboard.DashboardQuery());
            
            var allProblems = await GetProblemsHandler.HandleAsync();
            totalProblems = allProblems.Count();

            sectorDistribution = allProblems
                .GroupBy(p => string.IsNullOrWhiteSpace(p.Sector) ? "Belirtilmemiş" : p.Sector)
                .ToDictionary(g => g.Key, g => g.Count());

            statusDistribution = new Dictionary<string, int>
            {
                { "Draft", allProblems.Count(p => p.Status == "Draft") },
                { "Discovered", allProblems.Count(p => p.Status == "Discovered") },
                { "Analyzed", allProblems.Count(p => p.Status == "Analyzed") },
                { "Validated", allProblems.Count(p => p.Status == "Validated") },
                { "Archived", allProblems.Count(p => p.Status == "Archived") }
            };

            BuildIdeaStatusData(allProblems);
            await BuildRecentActivities(allProblems);
            await BuildWeeklySummary(allProblems);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Dashboard error: {ex.Message}");
            data = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Dashboard üzerinden hızlı problem ekleme işlemi.
    /// </summary>
    private async Task QuickAddProblem()
    {
        quickMessage = "";
        quickError = "";

        if (string.IsNullOrWhiteSpace(quickTitle))
        {
            quickError = "Başlık zorunludur.";
            return;
        }

        isQuickAdding = true;
        try
        {
            var command = new MSC.IdeaForge.Application.Problems.Commands.CreateProblemCommand
            {
                Title = quickTitle,
                Description = quickTitle, // Hızlı ekleme için başlığı açıklama olarak da kullanıyoruz
                Sector = quickSector
            };
            await CreateProblemHandler.HandleAsync(command);
            quickTitle = "";
            quickSector = "";
            quickMessage = "Eklendi ✓";

            // Dashboard verilerini yeniden yükle
            data = await DashboardQueryHandler.HandleAsync(new MSC.IdeaForge.Application.Dashboard.DashboardQuery());
            var allProblems = await GetProblemsHandler.HandleAsync();
            totalProblems = allProblems.Count();
            sectorDistribution = allProblems
                .GroupBy(p => string.IsNullOrWhiteSpace(p.Sector) ? "Belirtilmemiş" : p.Sector)
                .ToDictionary(g => g.Key, g => g.Count());
            statusDistribution = new Dictionary<string, int>
            {
                { "Draft", allProblems.Count(p => p.Status == "Draft") },
                { "Discovered", allProblems.Count(p => p.Status == "Discovered") },
                { "Analyzed", allProblems.Count(p => p.Status == "Analyzed") },
                { "Validated", allProblems.Count(p => p.Status == "Validated") },
                { "Archived", allProblems.Count(p => p.Status == "Archived") }
            };

            BuildIdeaStatusData(allProblems);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            quickError = $"Hata: {ex.Message}";
        }
        finally
        {
            isQuickAdding = false;
        }
    }

