    private string FormatRelativeTime(DateTime dateTime)
    {
        var span = DateTime.UtcNow - dateTime.ToUniversalTime();
        if (span.TotalDays > 365) return $"{Math.Floor(span.TotalDays / 365)} yıl önce";
        if (span.TotalDays > 30) return $"{Math.Floor(span.TotalDays / 30)} ay önce";
        if (span.TotalDays > 1) return $"{Math.Floor(span.TotalDays)} gün önce";
        if (span.TotalHours > 1) return $"{Math.Floor(span.TotalHours)} saat önce";
        if (span.TotalMinutes > 1) return $"{Math.Floor(span.TotalMinutes)} dakika önce";
        return "Az önce";
    }
