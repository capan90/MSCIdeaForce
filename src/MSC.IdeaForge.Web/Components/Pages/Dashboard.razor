    /// <summary>
    /// Dashboard "Son Aktiviteler" beslemesindeki tek bir aktivite öğesi.
    /// </summary>
    private record ActivityItem(string Icon, string Description, DateTime Timestamp, string ColorClass);

    /// <summary>
    /// Mevcut verilerden (problem, karar, sinyal, AI analizi) son 10 aktiviteyi timestamp'e göre birleştirir.
    /// </summary>
    private async Task BuildRecentActivities(IEnumerable<MSC.IdeaForge.Application.Problems.DTOs.ProblemDto> allProblems)
    {
        var activities = new List<ActivityItem>();

        // Problem eklendi
        foreach (var p in allProblems)
        {
            activities.Add(new ActivityItem("💡", $"Problem eklendi: {p.Title}", p.CreatedAt, "text-primary"));
        }

        // AI analizi yapıldı (analiz edilmiş/doğrulanmış problemler baz alınır)
        foreach (var p in allProblems.Where(p => p.Status == "Analyzed" || p.Status == "Validated"))
        {
            activities.Add(new ActivityItem("🤖", $"AI analizi yapıldı: {p.Title}", p.CreatedAt, "text-purple"));
        }

        // Karar verildi
        try
        {
            var decisions = await GetAllDecisionsHandler.HandleAsync();
            foreach (var d in decisions)
            {
                activities.Add(new ActivityItem("📋", $"Karar verildi ({GetDecisionText(d.DecisionType)}): {d.ProblemTitle}", d.DecisionDate, "text-success"));
            }
        }
        catch { /* karar verisi yoksa yok sayılır */ }

        // Sinyal içe aktarıldı
        try
        {
            var signals = await GetImportedSignalsHandler.HandleAsync();
            foreach (var s in signals)
            {
                activities.Add(new ActivityItem("📡", $"Sinyal içe aktarıldı: {s.Title}", s.ImportedAt, "text-info"));
            }
        }
        catch { /* sinyal verisi yoksa yok sayılır */ }

        // En yeni 10 aktiviteyi alıyoruz
        recentActivities = activities
            .OrderByDescending(a => a.Timestamp)
            .Take(10)
            .ToList();
    }

