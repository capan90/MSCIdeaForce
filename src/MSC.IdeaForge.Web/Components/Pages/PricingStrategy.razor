@page "/pricing-strategy"
@rendermode InteractiveServer

@using MSC.IdeaForge.Domain.Interfaces
@using MSC.IdeaForge.Domain.ValueObjects
@inject MSC.IdeaForge.Application.Problems.Queries.GetProblemsHandler GetProblemsHandler
@inject IAIProvider AIProvider

<PageTitle>Fiyatlandırma Stratejisi</PageTitle>

<div class="container mt-4" style="max-width: 1050px;">
    <div class="mb-4">
        <h1 class="font-weight-bold text-dark mb-1" style="letter-spacing: -1px;">Fiyatlandırma Stratejisi</h1>
        <p class="text-muted mb-0">Seçilen ürün için yapay zeka ile detaylı fiyatlandırma stratejisi oluşturun.</p>
    </div>

    <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff; border: 1px solid #e3e6f0 !important;">
        <div class="card-body p-3">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger py-2 mb-3 small">@errorMessage</div>
            }
            <div class="row g-2 align-items-end">
                <div class="col-md-9">
                    <label class="form-label small text-muted mb-1 font-weight-bold">Problem Seçin</label>
                    <select class="form-select form-select-sm" value="@selectedProblemId" @onchange="OnProblemSelected">
                        <option value="">-- Problem seçin --</option>
                        @if (problems is not null)
                        {
                            @foreach (var p in problems)
                            {
                                <option value="@p.Id">@p.Title</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    @if (isGenerating)
                    {
                        <button class="btn btn-primary btn-sm w-100 d-flex align-items-center justify-content-center gap-2" disabled>
                            <span class="spinner-border spinner-border-sm" role="status"></span> Oluşturuluyor...
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-primary btn-sm w-100" @onclick="Generate" disabled="@(selectedProblemId == Guid.Empty)">
                            🤖 Strateji Oluştur
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (result is not null)
    {
        @* Önerilen model *@
        <div class="text-center mb-4">
            <span class="text-muted small d-block">Önerilen Fiyatlandırma Modeli</span>
            <span class="badge bg-primary px-4 py-2" style="font-size: 1.1rem;">@DisplayValue(result.RecommendedModel)</span>
        </div>

        @* Fiyatlandırma kademeleri (yan yana) *@
        @if (result.PricingTiers.Any())
        {
            <div class="row g-3 mb-4">
                @foreach (var tier in result.PricingTiers)
                {
                    <div class="col-md-@(Math.Max(3, 12 / Math.Max(1, result.PricingTiers.Count)))">
                        <div class="card h-100 shadow-sm border-0 text-center" style="border-radius: 12px; border-top: 4px solid #0d6efd !important;">
                            <div class="card-body p-3">
                                <h5 class="font-weight-bold text-dark mb-1">@tier.TierName</h5>
                                <div class="h4 font-weight-bold text-primary mb-2">@DisplayValue(tier.Price)</div>
                                <p class="text-dark small mb-2" style="white-space: pre-line;">@DisplayValue(tier.Features)</p>
                                <span class="badge bg-light text-dark border" style="font-size: 0.7rem;">@DisplayValue(tier.TargetSegment)</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        @* Diğer strateji bölümleri *@
        <div class="row g-3">
            <div class="col-md-6">@RenderBox("🎁 Ücretsiz Deneme Stratejisi", result.FreeTrialStrategy, "#198754")</div>
            <div class="col-md-6">@RenderBox("🏷️ İndirim Stratejisi", result.DiscountStrategy, "#fd7e14")</div>
            <div class="col-md-6">@RenderBox("⚔️ Rakip Fiyatlandırma", result.CompetitorPricing, "#dc3545")</div>
            <div class="col-md-6">@RenderBox("🧠 Psikolojik Fiyatlandırma İpuçları", result.PsychologicalPricingTips, "#6f42c1")</div>
            <div class="col-12">@RenderBox("📈 Gelir Projeksiyonu", result.RevenueProjection, "#0dcaf0")</div>
        </div>
    }
</div>

@code {
    private IEnumerable<MSC.IdeaForge.Application.Problems.DTOs.ProblemDto>? problems;
    private Guid selectedProblemId = Guid.Empty;
    private PricingStrategyResult? result;
    private bool isGenerating = false;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        problems = await GetProblemsHandler.HandleAsync();
    }

    private void OnProblemSelected(ChangeEventArgs e)
    {
        result = null;
        errorMessage = "";
        selectedProblemId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : Guid.Empty;
    }

    /// <summary>
    /// Seçili ürün için yapay zeka ile fiyatlandırma stratejisi üretir.
    /// </summary>
    private async Task Generate()
    {
        var problem = problems?.FirstOrDefault(p => p.Id == selectedProblemId);
        if (problem is null) return;

        errorMessage = "";
        isGenerating = true;
        result = null;
        StateHasChanged();
        try
        {
            // Çözüm tipi ve hedef müşteri bu sayfada bağlam olarak geçilmiyor (opsiyonel)
            result = await AIProvider.GeneratePricingStrategyAsync(problem.Title, problem.Description, problem.Sector, null, null);
        }
        catch (Exception ex)
        {
            errorMessage = $"Fiyatlandırma stratejisi oluşturulurken bir hata oluştu: {ex.Message}";
        }
        finally
        {
            isGenerating = false;
            StateHasChanged();
        }
    }

    // Etiketli metin kutusu render eder
    private RenderFragment RenderBox(string title, string content, string color) => @<div class="card shadow-sm border-0 h-100" style="border-radius: 12px; border-left: 4px solid @color !important;">
        <div class="card-body p-3">
            <h6 class="font-weight-bold mb-1" style="color: @color;">@title</h6>
            <p class="mb-0 text-dark small" style="white-space: pre-line;">@DisplayValue(content)</p>
        </div>
    </div>;

    private static string DisplayValue(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
}
