@page "/competitor-analysis"

@using MSC.IdeaForge.Application.CompetitorAnalyses.DTOs
@inject MSC.IdeaForge.Application.Problems.Queries.GetProblemsHandler GetProblemsHandler
@inject MSC.IdeaForge.Application.Researches.Queries.GetResearchByProblemHandler GetResearchByProblemHandler
@inject MSC.IdeaForge.Application.CompetitorAnalyses.Commands.AnalyzeCompetitorsHandler AnalyzeCompetitorsHandler
@inject MSC.IdeaForge.Application.CompetitorAnalyses.Queries.GetCompetitorAnalysisHandler GetCompetitorAnalysisHandler

<PageTitle>Rakip Analizi</PageTitle>

<div class="container mt-4" style="max-width: 1000px;">
    @* Sayfa Başlığı *@
    <div class="mb-4">
        <h1 class="font-weight-bold text-dark mb-1" style="letter-spacing: -1px;">Rakip Analizi (Competitor Analysis)</h1>
        <p class="text-muted mb-0">Bir problem seçin, araştırma verisindeki rakip özetini görün ve yapay zeka ile detaylı rakip analizi yapın.</p>
    </div>

    @* Problem Seçim ve Analiz Formu *@
    <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff; border: 1px solid #e3e6f0 !important;">
        <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #b91c1c, #ef4444); border-bottom: none;">
            <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                <span class="bi bi-people-fill"></span> Rekabet İstihbaratı
            </h5>
        </div>
        <div class="card-body p-4">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger py-2 mb-3 small">@errorMessage</div>
            }

            <div class="row g-3 align-items-end">
                <div class="col-md-9">
                    <label class="form-label small text-muted mb-1 font-weight-bold">Problem Seçin</label>
                    <select class="form-select form-select-sm" value="@selectedProblemId" @onchange="OnProblemSelected">
                        <option value="">-- Problem seçin --</option>
                        @if (problems is not null)
                        {
                            @foreach (var p in problems)
                            {
                                <option value="@p.Id">@p.Title</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    @if (isAnalyzing)
                    {
                        <button class="btn btn-danger btn-sm w-100 d-flex align-items-center justify-content-center gap-2" disabled>
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                            Analiz ediliyor...
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-danger btn-sm w-100" @onclick="RunCompetitorAnalysis" disabled="@(selectedProblemId == Guid.Empty)">
                            🔍 AI ile Detaylı Analiz
                        </button>
                    }
                </div>
            </div>

            @* Araştırma verisindeki rakip özeti *@
            @if (selectedProblemId != Guid.Empty)
            {
                <div class="mt-3 p-3 bg-light rounded">
                    <h6 class="font-weight-bold text-dark mb-1"><span class="bi bi-journal-text"></span> Araştırmadaki Rakip Özeti</h6>
                    @if (!string.IsNullOrWhiteSpace(researchCompetitorSummary))
                    {
                        <p class="mb-0 text-dark small" style="white-space: pre-line;">@researchCompetitorSummary</p>
                    }
                    else
                    {
                        <p class="mb-0 text-muted small italic">Bu problem için araştırma verisinde rakip özeti bulunmuyor. Problem detayındaki "Araştırma" sekmesinden AI ile araştırma yapabilirsiniz.</p>
                    }
                </div>
            }
        </div>
    </div>

    @* AI Rakip Analizi Sonuçları *@
    @if (result is not null && result.Competitors.Any())
    {
        <div class="mb-3 d-flex justify-content-between align-items-center">
            <h4 class="font-weight-bold text-dark mb-0"><span class="bi bi-graph-up text-danger"></span> Tespit Edilen Rakipler (@result.Competitors.Count)</h4>
            <span class="text-muted small">Son analiz: @result.AnalyzedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
        </div>

        <div class="row g-3">
            @foreach (var c in result.Competitors)
            {
                <div class="col-12">
                    <div class="card shadow-sm border-0" style="border-radius: 12px; border-left: 4px solid #ef4444 !important;">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                                <h5 class="font-weight-bold text-dark m-0">@c.Name</h5>
                                <span class="badge bg-dark">Pazar Payı: @DisplayValue(c.MarketShare)</span>
                            </div>
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <div class="p-2 rounded h-100" style="background-color: #f0fdf4;">
                                        <span class="text-success small font-weight-bold d-block">＋ Güçlü Yönler</span>
                                        <span class="text-dark small">@DisplayValue(c.Strengths)</span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="p-2 rounded h-100" style="background-color: #fef2f2;">
                                        <span class="text-danger small font-weight-bold d-block">－ Zayıf Yönler</span>
                                        <span class="text-dark small">@DisplayValue(c.Weaknesses)</span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="p-2 rounded h-100" style="background-color: #eff6ff;">
                                        <span class="text-primary small font-weight-bold d-block">💲 Fiyatlandırma</span>
                                        <span class="text-dark small">@DisplayValue(c.Pricing)</span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="p-2 rounded h-100" style="background-color: #faf5ff;">
                                        <span class="small font-weight-bold d-block" style="color: #7c3aed;">★ Bizim Avantajımız</span>
                                        <span class="text-dark small">@DisplayValue(c.OurAdvantage)</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else if (selectedProblemId != Guid.Empty && !isAnalyzing && result is null)
    {
        <div class="alert alert-light text-center py-4 border shadow-sm" style="border-radius: 8px;">
            Bu problem için henüz detaylı AI rakip analizi yapılmamış. Yukarıdaki buton ile başlatabilirsiniz.
        </div>
    }
</div>

@code {
    private IEnumerable<MSC.IdeaForge.Application.Problems.DTOs.ProblemDto>? problems;
    private Guid selectedProblemId = Guid.Empty;
    private string researchCompetitorSummary = "";
    private CompetitorAnalysisDto? result;
    private bool isAnalyzing = false;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        problems = await GetProblemsHandler.HandleAsync();
    }

    /// <summary>
    /// Problem seçildiğinde araştırmadaki rakip özetini ve varsa mevcut AI rakip analizini yükler.
    /// </summary>
    private async Task OnProblemSelected(ChangeEventArgs e)
    {
        result = null;
        researchCompetitorSummary = "";
        errorMessage = "";

        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            selectedProblemId = id;
            var research = await GetResearchByProblemHandler.HandleAsync(id);
            researchCompetitorSummary = research?.CompetitorSummary ?? "";
            result = await GetCompetitorAnalysisHandler.HandleAsync(id);
        }
        else
        {
            selectedProblemId = Guid.Empty;
        }
    }

    /// <summary>
    /// Seçili problem için yapay zeka rakip analizini çalıştırır ve sonucu kaydeder.
    /// </summary>
    private async Task RunCompetitorAnalysis()
    {
        if (selectedProblemId == Guid.Empty) return;

        errorMessage = "";
        isAnalyzing = true;
        StateHasChanged();

        try
        {
            result = await AnalyzeCompetitorsHandler.HandleAsync(
                new MSC.IdeaForge.Application.CompetitorAnalyses.Commands.AnalyzeCompetitorsCommand { ProblemId = selectedProblemId });
        }
        catch (Exception ex)
        {
            errorMessage = $"Rakip analizi sırasında bir hata oluştu: {ex.Message}";
        }
        finally
        {
            isAnalyzing = false;
            StateHasChanged();
        }
    }

    // Boş alanlar için tire gösteriyoruz
    private static string DisplayValue(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
}
