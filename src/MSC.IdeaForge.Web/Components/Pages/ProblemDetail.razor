@page "/problems/{Id:guid}"
@rendermode InteractiveServer
@using MSC.IdeaForge.Domain.Enums
@inject MSC.IdeaForge.Application.Problems.Queries.GetProblemByIdHandler GetProblemByIdHandler
@inject MSC.IdeaForge.Application.Problems.Commands.DeleteProblemHandler DeleteProblemHandler
@inject MSC.IdeaForge.Application.Problems.Commands.UpdateProblemStatusHandler UpdateProblemStatusHandler
@inject MSC.IdeaForge.Application.Signals.Queries.GetSignalsByProblemHandler GetSignalsByProblemHandler
@inject MSC.IdeaForge.Application.Signals.Commands.CreateSignalHandler CreateSignalHandler
@inject MSC.IdeaForge.Application.Problems.Commands.AnalyzeProblemHandler AnalyzeProblemHandler
@inject MSC.IdeaForge.Application.Problems.Queries.GetProblemAnalysisHandler GetProblemAnalysisHandler
@inject MSC.IdeaForge.Application.Opportunities.Queries.GetOpportunityByProblemHandler GetOpportunityByProblemHandler
@inject MSC.IdeaForge.Application.Opportunities.Commands.ScoreOpportunityHandler ScoreOpportunityHandler
@inject MSC.IdeaForge.Application.Opportunities.Commands.AIScoreOpportunityHandler AIScoreOpportunityHandler
@inject MSC.IdeaForge.Application.Validations.Queries.GetValidationByProblemHandler GetValidationByProblemHandler
@inject MSC.IdeaForge.Application.Validations.Commands.SaveValidationHandler SaveValidationHandler
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime

<PageTitle>Problem Detayı</PageTitle>

<div class="container mt-4" style="max-width: 800px;">
    @* Geri dönme bağlantısı ve Sil butonu *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a href="/problems" class="btn btn-outline-secondary" style="text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem;">
            <span>&larr;</span> Geri Dön
        </a>
        @if (!isLoading && problem is not null)
        {
            @* Silme butonu *@
            <button class="btn btn-danger" @onclick="DeleteProblem" style="display: inline-flex; align-items: center; gap: 0.5rem;">
                <span class="bi bi-trash-fill" aria-hidden="true"></span> Sil
            </button>
        }
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Problem yükleniyor...</p>
        </div>
    }
    else if (problem is null)
    {
        @* Problem bulunamadığında gösterilecek mesaj *@
        <div class="alert alert-warning text-center shadow-sm" role="alert" style="border-radius: 8px; padding: 2rem;">
            <h4 class="alert-heading text-warning">Problem bulunamadı.</h4>
            <p class="mb-0 text-muted">Aradığınız kimliğe sahip bir problem kaydı mevcut değil veya silinmiş olabilir.</p>
        </div>
    }
    else
    {
        @* Sekme yapısı (Problem Detayı vs Sinyaller vs Fırsat Skoru vs Doğrulama vs AI Analizi) *@
        <ul class="nav nav-tabs mb-4">
            <li class="nav-item">
                <button class="nav-link @(activeTab == "detail" ? "active font-weight-bold" : "")" @onclick='() => SetActiveTab("detail")'>Detay Bilgileri</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "signals" ? "active font-weight-bold" : "")" @onclick='() => SetActiveTab("signals")'>Kaynak Sinyaller (@(signals?.Count() ?? 0))</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "opportunity" ? "active font-weight-bold" : "")" @onclick='() => SetActiveTab("opportunity")'>Fırsat Skoru</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "validation" ? "active font-weight-bold" : "")" @onclick='() => SetActiveTab("validation")'>Doğrulama</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "ai_analysis" ? "active font-weight-bold" : "")" @onclick='() => SetActiveTab("ai_analysis")'>AI Analizi</button>
            </li>
        </ul>

        if (activeTab == "detail")
        {
            @* Problem detay bilgileri *@
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; overflow: hidden; background: linear-gradient(to bottom, #ffffff, #fcfcfc);">
                <div class="card-header bg-primary text-white p-4" style="border-bottom: none;">
                    <span class="text-uppercase tracking-wider small opacity-75 d-block mb-1">PROBLEM DETAYI</span>
                    <h2 class="card-title m-0 font-weight-bold" style="letter-spacing: -0.5px;">@problem.Title</h2>
                </div>
                <div class="card-body p-4">
                    @* Açıklama Bölümü *@
                    <div class="mb-4">
                        <h5 class="text-primary font-weight-bold mb-2">Açıklama</h5>
                        <div class="p-3 bg-light rounded" style="white-space: pre-wrap; line-height: 1.6; border-left: 4px solid #0d6efd; color: #495057;">
                            @problem.Description
                        </div>
                    </div>

                    @* Detay Parametre Tablosu / Grid *@
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="p-3 bg-light rounded h-100">
                                <span class="text-muted d-block small">Durum</span>
                                @* Durum değiştirme açılır kutusu (dropdown) *@
                                <select class="form-select form-select-sm mt-1" value="@problem.Status" @onchange="OnStatusChanged" style="max-width: 180px;">
                                    <option value="Draft">Taslak</option>
                                    <option value="Discovered">Keşfedildi</option>
                                    <option value="Analyzed">Analiz Edildi</option>
                                    <option value="Validated">Doğrulandı</option>
                                    <option value="Archived">Arşivlendi</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 bg-light rounded h-100">
                                <span class="text-muted d-block small">Öncelik</span>
                                <span class="badge bg-info text-dark mt-1 px-2.5 py-1.5" style="font-size: 0.9rem;">@GetPriorityText(problem.Priority)</span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 bg-light rounded h-100">
                                <span class="text-muted d-block small">Sektör</span>
                                <span class="font-weight-bold text-dark mt-1 d-block">@(string.IsNullOrWhiteSpace(problem.Sector) ? "-" : problem.Sector)</span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 bg-light rounded h-100">
                                <span class="text-muted d-block small">Kaynak</span>
                                <span class="font-weight-bold text-dark mt-1 d-block">@(string.IsNullOrWhiteSpace(problem.Source) ? "-" : problem.Source)</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="p-3 bg-light rounded">
                                <span class="text-muted d-block small">Eklenme Tarihi</span>
                                <span class="text-dark mt-1 d-block font-mono">@problem.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (activeTab == "signals")
        {
            @* Yeni Sinyal Ekleme Formu *@
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fcfcfc;">
                <div class="card-header bg-secondary text-white py-3">
                    <h5 class="m-0 font-weight-bold">Yeni Kaynak Sinyal Ekle</h5>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(signalErrorMessage))
                    {
                        <div class="alert alert-danger py-2 small">@signalErrorMessage</div>
                    }
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small text-muted mb-1">Sinyal Başlığı</label>
                            <input class="form-control form-control-sm" placeholder="Örn: Müşteri Şikayeti / PDF Analizi" @bind="newSignalTitle" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small text-muted mb-1">Sinyal Türü</label>
                            <select class="form-select form-select-sm" @bind="newSignalType">
                                <option value="@SignalType.Manual">Manuel</option>
                                <option value="@SignalType.Reddit">Reddit</option>
                                <option value="@SignalType.PDF">PDF</option>
                                <option value="@SignalType.Excel">Excel</option>
                                <option value="@SignalType.Voice">Ses</option>
                                <option value="@SignalType.Image">Resim</option>
                                <option value="@SignalType.ERP">ERP</option>
                                <option value="@SignalType.Field">Saha</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small text-muted mb-1">Önem Derecesi</label>
                            <select class="form-select form-select-sm" @bind="newSeverity">
                                <option value="@SeverityLevel.Low">Düşük</option>
                                <option value="@SeverityLevel.Medium">Orta</option>
                                <option value="@SeverityLevel.High">Yüksek</option>
                                <option value="@SeverityLevel.Critical">Kritik</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label small text-muted mb-1">Sinyal Açıklaması</label>
                            <textarea class="form-control form-control-sm" rows="3" placeholder="Sinyal içeriği veya detayları..." @bind="newSignalDescription"></textarea>
                        </div>
                        <div class="col-12 text-end">
                            <button class="btn btn-primary btn-sm px-4" @onclick="AddSignal">Sinyal Ekle</button>
                        </div>
                    </div>
                </div>
            </div>

            @* Sinyal Listesi *@
            @if (signals is null)
            {
                <div class="text-center py-4">
                    <div class="spinner-border text-secondary" role="status"></div>
                    <p class="mt-2 text-muted small">Sinyaller yükleniyor...</p>
                </div>
            }
            else if (!signals.Any())
            {
                <div class="alert alert-light text-center py-4 border shadow-sm" style="border-radius: 8px;">
                    Bu probleme ait henüz bir kaynak sinyal eklenmemiş.
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var sig in signals)
                    {
                        <div class="card shadow-sm border-0" style="border-radius: 8px; border-left: 5px solid #0d6efd !important; background-color: #fff;">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="font-weight-bold m-0 text-dark">@sig.Title</h6>
                                    <div class="d-flex gap-2">
                                        <span class="badge bg-secondary">@GetSignalTypeText(sig.SignalType)</span>
                                        <span class="badge bg-info text-dark">@GetSeverityText(sig.Severity)</span>
                                    </div>
                                </div>
                                <p class="text-muted small mb-2" style="white-space: pre-wrap; line-height: 1.5;">@sig.Description</p>
                                <div class="text-end">
                                    <span class="text-muted font-mono" style="font-size: 0.75rem;">Tarih: @sig.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else if (activeTab == "opportunity")
        {
            @* Fırsat Değerlendirme Bölümü *@
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff;">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #198754, #20c997); border-bottom: none;">
                    <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                        <span class="bi bi-star-fill"></span> Fırsat Değerlendirme &amp; Skorlama
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (opportunitySuccessMessage != "")
                    {
                        <div class="alert alert-success py-2 mb-3 small">@opportunitySuccessMessage</div>
                    }
                    @if (opportunityErrorMessage != "")
                    {
                        <div class="alert alert-danger py-2 mb-3 small">@opportunityErrorMessage</div>
                    }

                    @* AI ile Otomatik Puanlama Butonu *@
                    <div class="mb-4">
                        @if (isAiOpportunityScoring)
                        {
                            <button class="btn btn-outline-success btn-sm d-flex align-items-center gap-2" disabled>
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                Yapay Zeka analiz ediyor...
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-success btn-sm d-flex align-items-center gap-2" @onclick="RunAiOpportunityScoring">
                                <span class="bi bi-cpu-fill"></span> AI ile Otomatik Puanla
                            </button>
                        }
                    </div>

                    <div class="row g-4">
                        <div class="col-md-7">
                            @* Kriterler Listesi *@
                            <div class="d-flex flex-column gap-3">
                                <div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <label class="form-label font-weight-bold m-0 small">Problem Şiddeti (Ağırlık: x3)</label>
                                        <span class="badge bg-secondary">@severityScore / 10</span>
                                    </div>
                                    <input type="range" class="form-range" min="1" max="10" step="1" @bind="severityScore" />
                                    @if (!string.IsNullOrEmpty(severityReason))
                                    {
                                        <div class="text-muted small mt-1 ps-2" style="border-left: 2px solid #198754; font-size: 0.8rem; font-style: italic;">
                                            @severityReason
                                        </div>
                                    }
                                </div>

                                <div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <label class="form-label font-weight-bold m-0 small">Pazar Büyüklüğü (Ağırlık: x2)</label>
                                        <span class="badge bg-secondary">@marketSizeScore / 10</span>
                                    </div>
                                    <input type="range" class="form-range" min="1" max="10" step="1" @bind="marketSizeScore" />
                                    @if (!string.IsNullOrEmpty(marketSizeReason))
                                    {
                                        <div class="text-muted small mt-1 ps-2" style="border-left: 2px solid #198754; font-size: 0.8rem; font-style: italic;">
                                            @marketSizeReason
                                        </div>
                                    }
                                </div>

                                <div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <label class="form-label font-weight-bold m-0 small">Kurucu Uyumu (Ağırlık: x2)</label>
                                        <span class="badge bg-secondary">@founderFitScore / 10</span>
                                    </div>
                                    <input type="range" class="form-range" min="1" max="10" step="1" @bind="founderFitScore" />
                                    @if (!string.IsNullOrEmpty(founderFitReason))
                                    {
                                        <div class="text-muted small mt-1 ps-2" style="border-left: 2px solid #198754; font-size: 0.8rem; font-style: italic;">
                                            @founderFitReason
                                        </div>
                                    }
                                </div>

                                <div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <label class="form-label font-weight-bold m-0 small">Risk (Ağırlık: x1)</label>
                                        <span class="badge bg-secondary">@riskScore / 10</span>
                                    </div>
                                    <input type="range" class="form-range" min="1" max="10" step="1" @bind="riskScore" />
                                    @if (!string.IsNullOrEmpty(riskReason))
                                    {
                                        <div class="text-muted small mt-1 ps-2" style="border-left: 2px solid #198754; font-size: 0.8rem; font-style: italic;">
                                            @riskReason
                                        </div>
                                    }
                                </div>

                                <div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <label class="form-label font-weight-bold m-0 small">Teknik Uygulanabilirlik (Ağırlık: x2)</label>
                                        <span class="badge bg-secondary">@feasibilityScore / 10</span>
                                    </div>
                                    <input type="range" class="form-range" min="1" max="10" step="1" @bind="feasibilityScore" />
                                    @if (!string.IsNullOrEmpty(feasibilityReason))
                                    {
                                        <div class="text-muted small mt-1 ps-2" style="border-left: 2px solid #198754; font-size: 0.8rem; font-style: italic;">
                                            @feasibilityReason
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="col-md-5">
                            @* Toplam Skor Gösterimi *@
                            <div class="p-4 bg-light rounded text-center mb-3 h-100 d-flex flex-column justify-content-center align-items-center" style="border: 1px solid #e3e6f0;">
                                <span class="text-muted small text-uppercase font-weight-bold">Toplam Fırsat Skoru</span>
                                <div class="display-3 font-weight-bold text-success my-2">@CalculateCurrentTotalScore().ToString("F1")</div>
                                <span class="text-muted small">Maksimum Skor: 10.0</span>
                                @if (opportunity is not null)
                                {
                                    <span class="badge bg-success mt-2">Durum: @GetOpportunityStatusText(opportunity.Status)</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary mt-2">Durum: Taslak</span>
                                }
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label small text-muted mb-1">Değerlendirme Notları</label>
                            <textarea class="form-control form-control-sm" rows="3" placeholder="Fırsat ile ilgili değerlendirme notlarınız..." @bind="opportunityNotes"></textarea>
                        </div>

                        <div class="col-12 text-end">
                            <button class="btn btn-success btn-sm px-4" @onclick="SaveOpportunity">Kaydet</button>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (activeTab == "validation")
        {
            @* Doğrulama Değerlendirme Bölümü *@
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff;">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #0dcaf0, #0d6efd); border-bottom: none;">
                    <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                        <span class="bi bi-shield-check"></span> Problem Doğrulama (Validation)
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (validationSuccessMessage != "")
                    {
                        <div class="alert alert-success py-2 mb-3 small">@validationSuccessMessage</div>
                    }
                    @if (validationErrorMessage != "")
                    {
                        <div class="alert alert-danger py-2 mb-3 small">@validationErrorMessage</div>
                    }

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label small text-muted mb-1">Görüşme Sayısı</label>
                            <input type="number" class="form-control form-control-sm" min="0" @bind="interviewCount" @bind:after="OnValidationCountChanged" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-muted mb-1">Doğrulayan Kişi Sayısı</label>
                            <input type="number" class="form-control form-control-sm" min="0" max="@interviewCount" @bind="validatedUserCount" @bind:after="OnValidationCountChanged" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-muted mb-1">Ödeme İsteği Sayısı</label>
                            <input type="number" class="form-control form-control-sm" min="0" max="@validatedUserCount" @bind="willingToPayCount" @bind:after="OnValidationCountChanged" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small text-muted mb-1">Güven Skoru (%): @confidenceScore</label>
                            <input type="range" class="form-range" min="1" max="100" @bind="confidenceScore" disabled />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small text-muted mb-1">Doğrulama Durumu</label>
                            <select class="form-select form-select-sm" @bind="validationStatus">
                                <option value="@ValidationStatus.NotStarted">Başlatılmadı</option>
                                <option value="@ValidationStatus.InProgress">Devam Ediyor</option>
                                <option value="@ValidationStatus.Validated">Doğrulandı</option>
                                <option value="@ValidationStatus.Rejected">Reddedildi</option>
                            </select>
                        </div>

                        <div class="col-12">
                            @* Doğrulama oranı gösterimi *@
                            <div class="p-3 bg-light rounded d-flex justify-content-between align-items-center">
                                <span class="font-weight-bold text-muted small text-uppercase">Doğrulama Oranı</span>
                                <span class="h4 font-weight-bold text-primary mb-0">
                                    @(interviewCount > 0 ? $"% {Math.Round((double)validatedUserCount / interviewCount * 100, 1)}" : "% 0")
                                </span>
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label small text-muted mb-1">Riskler</label>
                            <textarea class="form-control form-control-sm" rows="3" placeholder="Sürece dair riskler ve engeller..." @bind="validationRisks"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label small text-muted mb-1">Doğrulama Notları</label>
                            <textarea class="form-control form-control-sm" rows="3" placeholder="Görüşmelerden edinilen geri bildirim notları..." @bind="validationNotes"></textarea>
                        </div>

                        <div class="col-12 text-end">
                            <button class="btn btn-primary btn-sm px-4" @onclick="SaveValidation">Kaydet</button>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (activeTab == "ai_analysis")
        {
            @* AI Analiz Bölümü *@
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff;">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #6f42c1, #8553d1); border-bottom: none;">
                    <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                        <span class="bi bi-cpu-fill"></span> Yapay Zeka Analizi
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (isAnalyzing)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border" role="status" style="color: #6f42c1;"></div>
                            <p class="mt-2 text-muted">Yapay zeka problemi analiz ediyor, lütfen bekleyin...</p>
                        </div>
                    }
                    else if (problemAnalysis is null)
                    {
                        <div class="text-center py-5">
                            @if (!string.IsNullOrEmpty(aiErrorMessage))
                            {
                                <div class="alert alert-danger py-2 mb-3 small" style="max-width: 500px; margin: 0 auto 1.5rem auto;">@aiErrorMessage</div>
                            }
                            <p class="text-muted">Bu problem için henüz yapay zeka analizi yapılmamış.</p>
                            <button class="btn btn-primary px-4" @onclick="RunAiAnalysis" style="background-color: #6f42c1; border-color: #6f42c1;">
                                <span class="bi bi-play-fill"></span> Analiz Et
                            </button>
                        </div>
                    }
                    else
                    {
                        @if (!string.IsNullOrEmpty(aiErrorMessage))
                        {
                            <div class="alert alert-danger py-2 mb-3 small">@aiErrorMessage</div>
                        }

                        <div class="mb-4">
                            <h6 class="font-weight-bold mb-2" style="color: #6f42c1;">Yapay Zeka Özeti</h6>
                            <div class="p-3 bg-light rounded" style="line-height: 1.6; border-left: 4px solid #6f42c1; color: #495057;">
                                @problemAnalysis.Summary
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-sm-6">
                                <div class="p-3 bg-light rounded h-100">
                                    <span class="text-muted d-block small">Önerilen Kategori</span>
                                    <span class="font-weight-bold text-dark mt-1 d-block">@problemAnalysis.SuggestedCategory</span>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 bg-light rounded h-100">
                                    <span class="text-muted d-block small">Önerilen Etiketler</span>
                                    <span class="font-weight-bold text-dark mt-1 d-block">@problemAnalysis.SuggestedTags</span>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 bg-light rounded h-100">
                                    <span class="text-muted d-block small">Risk Seviyesi</span>
                                    <span class="badge @GetRiskLevelBadgeClass(problemAnalysis.RiskLevel) mt-1 px-2.5 py-1.5" style="font-size: 0.9rem;">
                                        @GetRiskLevelText(problemAnalysis.RiskLevel)
                                    </span>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 bg-light rounded h-100">
                                    <span class="text-muted d-block small">Güven Skoru</span>
                                    <span class="font-weight-bold text-dark mt-1 d-block">%@(Math.Round(problemAnalysis.ConfidenceScore * 100))</span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="p-3 bg-light rounded">
                                    <span class="text-muted d-block small">Çözüm Tipi Önerisi</span>
                                    <span class="font-weight-bold text-dark mt-1 d-block" style="white-space: pre-wrap; line-height: 1.5;">@problemAnalysis.SolutionTypeSuggestion</span>
                                </div>
                            </div>
                            <div class="col-12">
                                <span class="text-muted small" style="font-size: 0.8rem;">Son Analiz Tarihi: @problemAnalysis.AnalyzedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
                            </div>
                        </div>

                        <div class="text-end">
                            <button class="btn btn-outline-secondary btn-sm" @onclick="RunAiAnalysis">
                                <span class="bi bi-arrow-clockwise"></span> Yeniden Analiz Et
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private MSC.IdeaForge.Application.Problems.DTOs.ProblemDto? problem;
    private IEnumerable<MSC.IdeaForge.Application.Signals.DTOs.SignalDto>? signals;
    private MSC.IdeaForge.Application.Opportunities.DTOs.OpportunityDto? opportunity;
    private MSC.IdeaForge.Application.Validations.DTOs.ValidationDto? validationDto;
    private MSC.IdeaForge.Domain.Entities.ProblemAnalysis? problemAnalysis;
    private bool isLoading = true;
    private bool isAnalyzing = false;
    private bool isAiOpportunityScoring = false;
    private string activeTab = "detail";

    // Yeni sinyal form alanları
    private string newSignalTitle = "";
    private string newSignalDescription = "";
    private SignalType newSignalType = SignalType.Manual;
    private SeverityLevel newSeverity = SeverityLevel.Medium;
    private string signalErrorMessage = "";
    private string aiErrorMessage = "";

    // Fırsat puanlama form alanları
    private int severityScore = 5;
    private int marketSizeScore = 5;
    private int founderFitScore = 5;
    private int riskScore = 5;
    private int feasibilityScore = 5;
    private string opportunityNotes = "";
    private string opportunityErrorMessage = "";
    private string opportunitySuccessMessage = "";

    // Yapay zeka gerekçeleri
    private string severityReason = "";
    private string marketSizeReason = "";
    private string founderFitReason = "";
    private string riskReason = "";
    private string feasibilityReason = "";

    // Doğrulama form alanları
    private int interviewCount = 0;
    private int validatedUserCount = 0;
    private int willingToPayCount = 0;
    private int confidenceScore = 1;
    private string validationNotes = "";
    private string validationRisks = "";
    private ValidationStatus validationStatus = ValidationStatus.NotStarted;
    private string validationSuccessMessage = "";
    private string validationErrorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        // Sayfa yüklendiğinde problemi, sinyalleri, fırsat skorlarını, doğrulama ve AI analiz verilerini getirmek için sorguları tetikliyoruz.
        try
        {
            problem = await GetProblemByIdHandler.HandleAsync(Id);
            await LoadSignals();
            await LoadOpportunity();
            await LoadValidation();
            await LoadProblemAnalysis();
        }
        catch
        {
            problem = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SetActiveTab(string tab)
    {
        activeTab = tab;
        opportunitySuccessMessage = "";
        opportunityErrorMessage = "";
        validationSuccessMessage = "";
        validationErrorMessage = "";
    }

    private async Task LoadSignals()
    {
        try
        {
            signals = await GetSignalsByProblemHandler.HandleAsync(Id);
        }
        catch
        {
            signals = new List<MSC.IdeaForge.Application.Signals.DTOs.SignalDto>();
        }
    }

    private async Task LoadOpportunity()
    {
        try
        {
            opportunity = await GetOpportunityByProblemHandler.HandleAsync(Id);
            if (opportunity is not null)
            {
                severityScore = opportunity.ProblemSeverity;
                marketSizeScore = opportunity.MarketSize;
                founderFitScore = opportunity.FounderFit;
                riskScore = opportunity.RiskScore;
                feasibilityScore = opportunity.TechnicalFeasibility;
                opportunityNotes = opportunity.Notes ?? "";
            }
        }
        catch
        {
            opportunity = null;
        }
    }

    private async Task LoadValidation()
    {
        try
        {
            validationDto = await GetValidationByProblemHandler.HandleAsync(Id);
            if (validationDto is not null)
            {
                interviewCount = validationDto.InterviewCount;
                validatedUserCount = validationDto.ValidatedUserCount;
                willingToPayCount = validationDto.WillingToPayCount;
                confidenceScore = validationDto.ConfidenceScore;
                validationNotes = validationDto.Notes ?? "";
                validationRisks = validationDto.Risks ?? "";
                if (Enum.TryParse<ValidationStatus>(validationDto.Status, out var status))
                {
                    validationStatus = status;
                }
            }
        }
        catch
        {
            validationDto = null;
        }
    }

    private async Task LoadProblemAnalysis()
    {
        try
        {
            problemAnalysis = await GetProblemAnalysisHandler.HandleAsync(Id);
        }
        catch
        {
            problemAnalysis = null;
        }
    }

    /// <summary>
    /// Yapay Zeka ile otomatik fırsat skorlarını ve gerekçelerini oluşturur.
    /// </summary>
    private async Task RunAiOpportunityScoring()
    {
        isAiOpportunityScoring = true;
        opportunityErrorMessage = "";
        opportunitySuccessMessage = "";

        try
        {
            var command = new MSC.IdeaForge.Application.Opportunities.Commands.AIScoreOpportunityCommand
            {
                ProblemId = Id
            };

            var result = await AIScoreOpportunityHandler.HandleAsync(command);

            // Yapay zekanın önerdiği puanlar form alanlarına atanıyor.
            severityScore = result.ProblemSeverity;
            marketSizeScore = result.MarketSize;
            founderFitScore = result.FounderFit;
            riskScore = result.RiskScore;
            feasibilityScore = result.TechnicalFeasibility;

            // Yapay zeka gerekçeleri atanıyor.
            severityReason = result.ProblemSeverityReason;
            marketSizeReason = result.MarketSizeReason;
            founderFitReason = result.FounderFitReason;
            riskReason = result.RiskScoreReason;
            feasibilityReason = result.TechnicalFeasibilityReason;

            opportunitySuccessMessage = "Yapay zeka kriterleri analiz etti ve skorları önerdi. Skorları kontrol edip kaydedebilirsiniz.";
        }
        catch (Exception ex)
        {
            opportunityErrorMessage = $"Yapay zeka otomatik skorlaması sırasında hata oluştu: {ex.Message}";
        }
        finally
        {
            isAiOpportunityScoring = false;
        }
    }

    /// <summary>
    /// Fırsat puanlama formunu kaydeder.
    /// </summary>
    private async Task SaveOpportunity()
    {
        opportunityErrorMessage = "";
        opportunitySuccessMessage = "";

        try
        {
            var command = new MSC.IdeaForge.Application.Opportunities.Commands.ScoreOpportunityCommand
            {
                ProblemId = Id,
                ProblemSeverity = severityScore,
                MarketSize = marketSizeScore,
                FounderFit = founderFitScore,
                RiskScore = riskScore,
                TechnicalFeasibility = feasibilityScore,
                Notes = opportunityNotes
            };

            await ScoreOpportunityHandler.HandleAsync(command);
            opportunitySuccessMessage = "Fırsat skoru başarıyla kaydedildi.";
            await LoadOpportunity();
        }
        catch (Exception ex)
        {
            opportunityErrorMessage = $"Fırsat skoru kaydedilirken hata oluştu: {ex.Message}";
        }
    }

    /// <summary>
    /// Doğrulama değerleri değiştiğinde sınır kontrollerini yapıp otomatik güven skorunu günceller.
    /// </summary>
    private void OnValidationCountChanged()
    {
        if (interviewCount < 0) interviewCount = 0;
        if (validatedUserCount < 0) validatedUserCount = 0;
        if (willingToPayCount < 0) willingToPayCount = 0;

        if (validatedUserCount > interviewCount) validatedUserCount = interviewCount;
        if (willingToPayCount > validatedUserCount) willingToPayCount = validatedUserCount;

        if (interviewCount > 0)
        {
            confidenceScore = (int)Math.Round((double)validatedUserCount / interviewCount * 100);
            if (confidenceScore < 1) confidenceScore = 1;
            if (confidenceScore > 100) confidenceScore = 100;
        }
        else
        {
            confidenceScore = 1;
        }
    }

    /// <summary>
    /// Doğrulama bilgilerini kaydeder.
    /// </summary>
    private async Task SaveValidation()
    {
        validationSuccessMessage = "";
        validationErrorMessage = "";

        // Değer sınırlarını kontrol ediyoruz.
        OnValidationCountChanged();

        try
        {
            var command = new MSC.IdeaForge.Application.Validations.Commands.SaveValidationCommand
            {
                ProblemId = Id,
                InterviewCount = interviewCount,
                ValidatedUserCount = validatedUserCount,
                WillingToPayCount = willingToPayCount,
                ConfidenceScore = confidenceScore,
                Notes = validationNotes,
                Risks = validationRisks,
                Status = validationStatus
            };

            await SaveValidationHandler.HandleAsync(command);
            validationSuccessMessage = "Doğrulama verileri başarıyla kaydedildi.";
            await LoadValidation();
        }
        catch (Exception ex)
        {
            validationErrorMessage = $"Doğrulama verileri kaydedilirken hata oluştu: {ex.Message}";
        }
    }

    /// <summary>
    /// Kriter puanlarının ağırlıklı ortalamasını hesaplar.
    /// </summary>
    private double CalculateCurrentTotalScore()
    {
        return (severityScore * 3 + marketSizeScore * 2 + founderFitScore * 2 + riskScore * 1 + feasibilityScore * 2) / 10.0;
    }

    /// <summary>
    /// Yapay Zeka analizini başlatır ve veritabanına kaydeder.
    /// </summary>
    private async Task RunAiAnalysis()
    {
        isAnalyzing = true;
        aiErrorMessage = "";
        try
        {
            await AnalyzeProblemHandler.HandleAsync(Id);
            await LoadProblemAnalysis();
        }
        catch (Exception ex)
        {
            aiErrorMessage = $"Analiz sırasında hata oluştu: {ex.Message}";
        }
        finally
        {
            isAnalyzing = false;
        }
    }

    /// <summary>
    /// Problemi silmek için kullanıcıdan onay alır ve silme komutunu çağırır.
    /// </summary>
    private async Task DeleteProblem()
    {
        var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", "Bu problemi silmek istediğinize emin misiniz?");
        if (confirmed)
        {
            try
            {
                await DeleteProblemHandler.HandleAsync(Id);
                // Başarılı silme işleminden sonra ana listeye yönlendiriyoruz.
                NavigationManager.NavigateTo("/problems");
            }
            catch (Exception ex)
            {
                await JsRuntime.InvokeVoidAsync("alert", $"Silme işlemi sırasında hata oluştu: {ex.Message}");
            }
        }
    }

    /// <summary>
    /// Açılır kutudan yeni durum seçildiğinde veritabanındaki durumu günceller.
    /// </summary>
    private async Task OnStatusChanged(ChangeEventArgs e)
    {
        var statusStr = e.Value?.ToString();
        if (Enum.TryParse<MSC.IdeaForge.Domain.Enums.ProblemStatus>(statusStr, out var newStatus))
        {
            try
            {
                await UpdateProblemStatusHandler.HandleAsync(Id, newStatus);
                if (problem is not null)
                {
                    problem.Status = newStatus.ToString();
                }
            }
            catch (Exception ex)
            {
                await JsRuntime.InvokeVoidAsync("alert", $"Durum güncellenirken hata oluştu: {ex.Message}");
            }
        }
    }

    /// <summary>
    /// Yeni bir kaynak sinyal oluşturur ve listeyi yeniler.
    /// </summary>
    private async Task AddSignal()
    {
        signalErrorMessage = "";

        if (string.IsNullOrWhiteSpace(newSignalTitle) || string.IsNullOrWhiteSpace(newSignalDescription))
        {
            signalErrorMessage = "Başlık ve açıklama alanları zorunludur.";
            return;
        }

        try
        {
            var command = new MSC.IdeaForge.Application.Signals.Commands.CreateSignalCommand
            {
                ProblemId = Id,
                Title = newSignalTitle,
                Description = newSignalDescription,
                SignalType = newSignalType,
                Severity = newSeverity
            };

            await CreateSignalHandler.HandleAsync(command);

            // Form alanlarını temizliyoruz.
            newSignalTitle = "";
            newSignalDescription = "";
            newSignalType = SignalType.Manual;
            newSeverity = SeverityLevel.Medium;

            // Sinyal listesini güncelliyoruz.
            await LoadSignals();
        }
        catch (Exception ex)
        {
            signalErrorMessage = $"Sinyal eklenirken hata oluştu: {ex.Message}";
        }
    }

    /// <summary>
    /// Öncelik seviyesini Türkçe metne dönüştürür.
    /// </summary>
    private string GetPriorityText(string priority) => priority switch
    {
        "Low" => "Düşük",
        "Medium" => "Orta",
        "High" => "Yüksek",
        "Critical" => "Kritik",
        _ => priority
    };

    /// <summary>
    /// Sinyal türünü Türkçe metne dönüştürür.
    /// </summary>
    private string GetSignalTypeText(string type) => type switch
    {
        "Manual" => "Manuel",
        "Reddit" => "Reddit",
        "PDF" => "PDF",
        "Excel" => "Excel",
        "Voice" => "Ses",
        "Image" => "Resim",
        "ERP" => "ERP",
        "Field" => "Saha",
        _ => type
    };

    /// <summary>
    /// Sinyal önem derecesini Türkçe metne dönüştürür.
    /// </summary>
    private string GetSeverityText(string severity) => severity switch
    {
        "Low" => "Düşük",
        "Medium" => "Orta",
        "High" => "Yüksek",
        "Critical" => "Kritik",
        _ => severity
    };

    /// <summary>
    /// Risk seviyesini Türkçe metne dönüştürür.
    /// </summary>
    private string GetRiskLevelText(string riskLevel) => riskLevel switch
    {
        "Low" => "Düşük",
        "Medium" => "Orta",
        "High" => "Yüksek",
        "Critical" => "Kritik",
        _ => riskLevel
    };

    /// <summary>
    /// Risk seviyesine uygun Bootstrap rozet sınıfını döner.
    /// </summary>
    private string GetRiskLevelBadgeClass(string riskLevel) => riskLevel switch
    {
        "Low" => "bg-success text-white",
        "Medium" => "bg-warning text-dark",
        "High" => "bg-danger text-white",
        "Critical" => "bg-dark text-white",
        _ => "bg-secondary text-white"
    };

    /// <summary>
    /// Fırsat durumuna uygun Türkçe metin döner.
    /// </summary>
    private string GetOpportunityStatusText(string status) => status switch
    {
        "Draft" => "Taslak",
        "Scored" => "Puanlandı",
        "Approved" => "Onaylandı",
        "Rejected" => "Reddedildi",
        _ => status
    };
}
