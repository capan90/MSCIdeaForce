        var p when p != null && (p.Contains("orta") || p.Contains("medium")) => "bg-warning text-dark",
        var p when p != null && (p.Contains("düşük") || p.Contains("low")) => "bg-secondary text-white",
        _ => "bg-info text-dark"
    };

    /// <summary>
