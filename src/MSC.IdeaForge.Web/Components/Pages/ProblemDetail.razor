@page "/problems/{Id:guid}"
@rendermode InteractiveServer
@using MSC.IdeaForge.Domain.Enums
@inject MSC.IdeaForge.Application.Problems.Queries.GetProblemByIdHandler GetProblemByIdHandler
@inject MSC.IdeaForge.Application.Problems.Commands.DeleteProblemHandler DeleteProblemHandler
@inject MSC.IdeaForge.Application.Problems.Commands.UpdateProblemStatusHandler UpdateProblemStatusHandler
@inject MSC.IdeaForge.Application.Signals.Queries.GetSignalsByProblemHandler GetSignalsByProblemHandler
@inject MSC.IdeaForge.Application.Signals.Commands.CreateSignalHandler CreateSignalHandler
@inject MSC.IdeaForge.Application.Problems.Commands.AnalyzeProblemHandler AnalyzeProblemHandler
@inject MSC.IdeaForge.Application.Problems.Queries.GetProblemAnalysisHandler GetProblemAnalysisHandler
@inject MSC.IdeaForge.Application.Opportunities.Queries.GetOpportunityByProblemHandler GetOpportunityByProblemHandler
@inject MSC.IdeaForge.Application.Opportunities.Commands.ScoreOpportunityHandler ScoreOpportunityHandler
@inject MSC.IdeaForge.Application.Opportunities.Commands.AIScoreOpportunityHandler AIScoreOpportunityHandler
@inject MSC.IdeaForge.Application.Validations.Queries.GetValidationByProblemHandler GetValidationByProblemHandler
@inject MSC.IdeaForge.Application.Validations.Commands.SaveValidationHandler SaveValidationHandler
@inject MSC.IdeaForge.Application.Researches.Commands.SaveResearchHandler SaveResearchHandler
@inject MSC.IdeaForge.Application.Researches.Commands.AIResearchHandler AIResearchHandler
@inject MSC.IdeaForge.Application.Researches.Queries.GetResearchByProblemHandler GetResearchByProblemHandler
@inject MSC.IdeaForge.Application.Solutions.Commands.SaveSolutionHandler SaveSolutionHandler
@inject MSC.IdeaForge.Application.Solutions.Commands.DeleteSolutionHandler DeleteSolutionHandler
@inject MSC.IdeaForge.Application.Solutions.Commands.AISuggestSolutionsHandler AISuggestSolutionsHandler
@inject MSC.IdeaForge.Application.Solutions.Queries.GetSolutionsByProblemHandler GetSolutionsByProblemHandler
@inject MSC.IdeaForge.Application.MVPPlans.Commands.SaveMVPPlanHandler SaveMVPPlanHandler
@inject MSC.IdeaForge.Application.MVPPlans.Commands.GenerateMVPPlanHandler GenerateMVPPlanHandler
@inject MSC.IdeaForge.Application.MVPPlans.Queries.GetMVPPlanByProblemHandler GetMVPPlanByProblemHandler
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime
@using MSC.IdeaForge.Application.Agents
@using MSC.IdeaForge.Application.Decisions.DTOs
@using MSC.IdeaForge.Application.Validations.DTOs
@using System.Text.Json
@inject MSC.IdeaForge.Application.Agents.AgentCoordinator AgentCoordinator
@inject MSC.IdeaForge.Application.Problems.Commands.UpdateProblemHandler UpdateProblemHandler
@inject MSC.IdeaForge.Application.Decisions.Commands.CreateDecisionHandler CreateDecisionHandler
@inject MSC.IdeaForge.Application.Decisions.Queries.GetDecisionsByProblemHandler GetDecisionsByProblemHandler
@inject MSC.IdeaForge.Application.Problems.Commands.UpdateProblemPriorityHandler UpdateProblemPriorityHandler
@inject MSC.IdeaForge.Application.Revenues.Commands.AnalyzeRevenueHandler AnalyzeRevenueHandler
@inject MSC.IdeaForge.Application.Revenues.Queries.GetRevenueAnalysisHandler GetRevenueAnalysisHandler
@inject MSC.IdeaForge.Application.Validations.Commands.GenerateValidationQuestionsHandler GenerateValidationQuestionsHandler
@inject MSC.IdeaForge.Application.Validations.Commands.SaveValidationQuestionsHandler SaveValidationQuestionsHandler
@inject MSC.IdeaForge.Application.ProblemNotes.Commands.CreateProblemNoteHandler CreateProblemNoteHandler
@inject MSC.IdeaForge.Application.ProblemNotes.Commands.DeleteProblemNoteHandler DeleteProblemNoteHandler
@inject MSC.IdeaForge.Application.ProblemNotes.Queries.GetProblemNotesHandler GetProblemNotesHandler
@inject MSC.IdeaForge.Domain.Interfaces.IAIProvider AIProvider
@inject MSC.IdeaForge.Application.Problems.Queries.GetProblemsHandler GetProblemsHandler
@inject MSC.IdeaForge.Application.ActionPlans.Commands.GenerateActionPlanHandler GenerateActionPlanHandler
@inject MSC.IdeaForge.Application.ActionPlans.Queries.GetActionPlanHandler GetActionPlanHandler

<PageTitle>Problem Detayı</PageTitle>

@* Sekmelerin mobil uyumlu ve kaydırılabilir olması için stiller *@
<style>
    /* Çok sekme olduğunda yatay kaydırma; sekmeler alt satıra kırılmaz */
    .problem-detail-tabs {
        flex-wrap: nowrap;
        overflow-x: auto;
        overflow-y: hidden;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: thin;
    }
    .problem-detail-tabs .nav-item {
        flex: 0 0 auto;
    }
    .problem-detail-tabs .nav-link {
        white-space: nowrap;
    }
    /* İnce kaydırma çubuğu görünümü */
    .problem-detail-tabs::-webkit-scrollbar {
        height: 6px;
    }
    .problem-detail-tabs::-webkit-scrollbar-thumb {
        background: #ced4da;
        border-radius: 3px;
    }
</style>

<div class="container-fluid mt-4" style="max-width: 1140px;">
    @* Geri dönme bağlantısı ve Sil butonu *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a href="/problems" class="btn btn-outline-secondary" style="text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem;">
            <span>&larr;</span> Geri Dön
        </a>
        @if (!isLoading && problem is not null)
        {
            <div class="d-flex align-items-center gap-2">
                @if (!string.IsNullOrEmpty(copyMessage))
                {
                    <span class="text-success small font-weight-bold">@copyMessage</span>
                }
                @* Özeti panoya kopyala butonu *@
                <button class="btn btn-outline-primary" @onclick="CopySummary" style="display: inline-flex; align-items: center; gap: 0.5rem;">
                    📋 Özet Kopyala
                </button>
                @* Silme butonu *@
                <button class="btn btn-danger" @onclick="DeleteProblem" style="display: inline-flex; align-items: center; gap: 0.5rem;">
                    <span class="bi bi-trash-fill" aria-hidden="true"></span> Sil
                </button>
            </div>
        }
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Problem yükleniyor...</p>
        </div>
    }
    else if (problem is null)
    {
        @* Problem bulunamadığında gösterilecek mesaj *@
        <div class="alert alert-warning text-center shadow-sm" role="alert" style="border-radius: 8px; padding: 2rem;">
            <h4 class="alert-heading text-warning">Problem bulunamadı.</h4>
            <p class="mb-0 text-muted">Aradığınız kimliğe sahip bir problem kaydı mevcut değil veya silinmiş olabilir.</p>
        </div>
    }
    else
    {
        @* Sekme yapısı (Problem Detayı vs Sinyaller vs Fırsat Skoru vs Doğrulama vs Araştırma vs Çözüm Önerileri vs MVP Planı vs AI Analizi) *@
        <ul class="nav nav-tabs mb-4 problem-detail-tabs flex-nowrap">
            <li class="nav-item">
                <button class="nav-link @(activeTab == "detail" ? "active font-weight-bold" : "")" @onclick='() => SetActiveTab("detail")'>Detay Bilgileri</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "signals" ? "active font-weight-bold" : "")" @onclick='() => SetActiveTab("signals")'>Kaynak Sinyaller (@(signals?.Count() ?? 0))</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "opportunity" ? "active font-weight-bold" : "")" @onclick='() => SetActiveTab("opportunity")'>Fırsat Skoru</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "validation" ? "active font-weight-bold" : "")" @onclick='() => SetActiveTab("validation")'>Doğrulama</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "research" ? "active font-weight-bold" : "")" @onclick='() => SetActiveTab("research")'>Araştırma</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "solutions" ? "active font-weight-bold" : "")" @onclick='() => SetActiveTab("solutions")'>Çözüm Önerileri</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "mvp" ? "active font-weight-bold" : "")" @onclick='() => SetActiveTab("mvp")'>MVP Planı</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "revenue" ? "active font-weight-bold" : "")" @onclick='() => SetActiveTab("revenue")'>Gelir Analizi</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "notes" ? "active font-weight-bold" : "")" @onclick='() => SetActiveTab("notes")'>Notlar (@(problemNotes?.Count ?? 0))</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "action_plan" ? "active font-weight-bold" : "")" @onclick='() => SetActiveTab("action_plan")'>Aksiyon Planı</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "ai_analysis" ? "active font-weight-bold" : "")" @onclick='() => SetActiveTab("ai_analysis")'>AI Analizi</button>
            </li>
        </ul>

        if (activeTab == "detail")
        {
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; overflow: hidden; background: linear-gradient(to bottom, #ffffff, #fcfcfc);">
                @if (isEditingProblem)
                {
                    <div class="card-header bg-warning text-dark p-4">
                        <span class="text-uppercase tracking-wider small opacity-75 d-block mb-1">PROBLEMİ DÜZENLE</span>
                        <input type="text" class="form-control" @bind="editProblemTitle" placeholder="Problem başlığı..." />
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Açıklama</label>
                            <textarea class="form-control" rows="6" @bind="editProblemDescription" placeholder="Problem açıklaması..."></textarea>
                        </div>
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <label class="form-label font-weight-bold">Sektör</label>
                                <input type="text" class="form-control form-control-sm" @bind="editProblemSector" placeholder="Sektör..." />
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label font-weight-bold">Kaynak</label>
                                <input type="text" class="form-control form-control-sm" @bind="editProblemSource" placeholder="Kaynak..." />
                            </div>
                        </div>
                        <div class="mt-4 text-end d-flex justify-content-end gap-2">
                            <button class="btn btn-primary btn-sm px-4" @onclick="SaveProblemEdit">Kaydet</button>
                            <button class="btn btn-secondary btn-sm px-4" @onclick="CancelProblemEdit">İptal</button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card-header bg-primary text-white p-4" style="border-bottom: none;">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span class="text-uppercase tracking-wider small opacity-75 d-block mb-1">PROBLEM DETAYI</span>
                                <h2 class="card-title m-0 font-weight-bold" style="letter-spacing: -0.5px;">@problem.Title</h2>
                            </div>
                            <button class="btn btn-outline-light btn-sm" @onclick="StartProblemEdit">
                                <span class="bi bi-pencil-fill"></span> Düzenle
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-4">
                        @* Açıklama Bölümü *@
                        <div class="mb-4">
                            <h5 class="text-primary font-weight-bold mb-2">Açıklama</h5>
                            <div class="p-3 bg-light rounded" style="white-space: pre-wrap; line-height: 1.6; border-left: 4px solid #0d6efd; color: #495057;">
                                @problem.Description
                            </div>
                        </div>

                        @* Detay Parametre Tablosu / Grid *@
                        <div class="row g-3 mb-4">
                            <div class="col-sm-6">
                                <div class="p-3 bg-light rounded h-100">
                                    <span class="text-muted d-block small">Durum</span>
                                    <select class="form-select form-select-sm mt-1" value="@problem.Status" @onchange="OnStatusChanged" style="max-width: 180px;">
                                        <option value="Draft">Taslak</option>
                                        <option value="Discovered">Keşfedildi</option>
                                        <option value="Analyzed">Analiz Edildi</option>
                                        <option value="Validated">Doğrulandı</option>
                                        <option value="Archived">Arşivlendi</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 bg-light rounded h-100">
                                    <span class="text-muted d-block small">Öncelik</span>
                                    <select class="form-select form-select-sm mt-1" value="@problem.Priority" @onchange="OnPriorityChanged" style="max-width: 180px;">
                                        <option value="Low">Düşük</option>
                                        <option value="Medium">Orta</option>
                                        <option value="High">Yüksek</option>
                                        <option value="Critical">Kritik</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 bg-light rounded h-100">
                                    <span class="text-muted d-block small">Sektör</span>
                                    <span class="font-weight-bold text-dark mt-1 d-block">@(string.IsNullOrWhiteSpace(problem.Sector) ? "-" : problem.Sector)</span>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 bg-light rounded h-100">
                                    <span class="text-muted d-block small">Kaynak</span>
                                    <span class="font-weight-bold text-dark mt-1 d-block">@(string.IsNullOrWhiteSpace(problem.Source) ? "-" : problem.Source)</span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="p-3 bg-light rounded">
                                    <span class="text-muted d-block small">Eklenme Tarihi</span>
                                    <span class="text-dark mt-1 d-block font-mono">@problem.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                </div>
                            </div>
                        </div>

                        @* TAM AI AJAN ANALİZİ PANELİ *@
                        <div class="mt-4 p-3 border rounded bg-white shadow-sm" style="border-radius: 12px;">
                            <h6 class="font-weight-bold text-dark mb-2">🤖 Tam AI Ajan Analizi (Coordinator Pattern)</h6>
                            <p class="text-muted small mb-3">Problemi analiz etmek, araştırmak, fırsat puanı belirlemek, çözüm üretmek ve MVP planı oluşturmak için tüm otonom ajanları sırayla çalıştırın.</p>
                            
                            @if (isFullAnalysisRunning)
                            {
                                <button class="btn btn-primary btn-sm d-flex align-items-center gap-2 mb-3" disabled>
                                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                    Ajanlar sırayla analiz ediyor...
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-primary btn-sm d-flex align-items-center gap-2 mb-3" @onclick="StartFullAiAnalysis">
                                    <span class="bi bi-play-circle-fill"></span> Tam AI Analizi Başlat
                                </button>
                            }

                            @if (coordinatorProgress is not null && coordinatorProgress.Any())
                            {
                                <div class="d-flex flex-column gap-2 mb-2">
                                    @foreach (var progress in coordinatorProgress)
                                    {
                                        <div class="d-flex align-items-center justify-content-between p-2 rounded bg-light border small" style="font-size: 0.85rem;">
                                            <div class="d-flex align-items-center gap-2">
                                                @if (progress.Status == AgentStepStatus.Pending)
                                                {
                                                    <span class="text-muted">⏳</span>
                                                }
                                                else if (progress.Status == AgentStepStatus.Running)
                                                {
                                                    <span class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></span>
                                                }
                                                else if (progress.Status == AgentStepStatus.Completed)
                                                {
                                                    <span class="text-success">✅</span>
                                                }
                                                else if (progress.Status == AgentStepStatus.Failed)
                                                {
                                                    <span class="text-danger">⚠️</span>
                                                }
                                                <span class="@(progress.Status == AgentStepStatus.Running ? "font-weight-bold text-primary" : "")">@progress.Step</span>
                                            </div>
                                            <div>
                                                @if (progress.Status == AgentStepStatus.Running)
                                                {
                                                    <span class="badge bg-primary text-white">Çalışıyor</span>
                                                }
                                                else if (progress.Status == AgentStepStatus.Completed)
                                                {
                                                    <span class="badge bg-success text-white">Tamamlandı</span>
                                                }
                                                else if (progress.Status == AgentStepStatus.Failed)
                                                {
                                                    <span class="badge bg-danger text-white">Hata</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary text-white">Bekliyor</span>
                                                }
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(progress.ErrorMessage))
                                        {
                                            <div class="text-danger small ps-4 font-mono mb-2" style="font-size: 0.75rem;">
                                                Hata detayı: @progress.ErrorMessage
                                            </div>
                                        }
                                    }
                                </div>
                                
                                @if (coordinatorProgress.All(p => p.Status == AgentStepStatus.Completed || p.Status == AgentStepStatus.Failed))
                                {
                                    <div class="alert alert-info py-2 small mt-2 mb-0">
                                        <strong>Analiz Tamamlandı!</strong> Tam AI Ajan Analizi sonlandı. Sayfadaki diğer sekmeleri yenileyerek güncel analizleri görebilirsiniz.
                                    </div>
                                }
                            }
                        </div>

                        @* KARAR GÜNLÜĞÜ PANELİ *@
                        <div class="mt-4 p-3 border rounded bg-white shadow-sm" style="border-radius: 12px;">
                            <h6 class="font-weight-bold text-dark mb-2">📋 Problem Karar Günlüğü</h6>
                            <p class="text-muted small mb-3">Bu problem hakkında alınan kararları ve gerekçelerini yönetin.</p>
                            
                            @if (decisions is not null && decisions.Any())
                            {
                                <div class="d-flex flex-column gap-2 mb-3">
                                    @foreach (var dec in decisions)
                                    {
                                        <div class="p-2.5 rounded bg-light border small">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <span class="badge @GetDecisionBadgeClass(dec.DecisionType) text-white">@GetDecisionTypeText(dec.DecisionType)</span>
                                                <span class="text-muted font-mono" style="font-size: 0.75rem;">@dec.DecisionDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                            </div>
                                            <div class="text-dark" style="line-height: 1.4;">@dec.Reason</div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-muted small mb-3 italic">Bu problem için henüz alınmış bir karar kaydedilmemiş.</div>
                            }

                            @if (isAddingDecision)
                            {
                                <div class="p-3 border rounded bg-light mb-3">
                                    <div class="row g-2 mb-2">
                                        <div class="col-sm-6">
                                            <label class="form-label small text-muted mb-0 font-weight-bold">Karar Türü</label>
                                            <select class="form-select form-select-sm" @bind="newDecisionType">
                                                <option value="@DecisionType.Approved">Onaylandı (Approved)</option>
                                                <option value="@DecisionType.Rejected">Reddedildi (Rejected)</option>
                                                <option value="@DecisionType.Parked">Park Edildi (Parked)</option>
                                                <option value="@DecisionType.Continue">Devam Ediliyor (Continue)</option>
                                                <option value="@DecisionType.Archive">Arşivlendi (Archive)</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="mb-2">
                                        <label class="form-label small text-muted mb-0 font-weight-bold">Gerekçe / Detaylar</label>
                                        <textarea class="form-control form-control-sm" rows="3" placeholder="Bu kararın alınmasının arkasındaki gerekçeyi yazın..." @bind="newDecisionReason"></textarea>
                                    </div>
                                    <div class="text-end d-flex justify-content-end gap-1.5">
                                        <button class="btn btn-primary btn-sm py-1 px-3" @onclick="SaveNewDecision" style="font-size: 0.8rem;">Kaydet</button>
                                        <button class="btn btn-secondary btn-sm py-1 px-3" @onclick="CancelAddingDecision" style="font-size: 0.8rem;">İptal</button>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-outline-dark btn-sm d-flex align-items-center gap-1.5" @onclick="StartAddingDecision">
                                    <span class="bi bi-plus-circle"></span> Karar Ekle
                                </button>
                            }
                        </div>

                        @* AKTİVİTE AKIŞI PANELİ *@
                        <div class="mt-4 p-3 border rounded bg-white shadow-sm" style="border-radius: 12px;">
                            <h6 class="font-weight-bold text-dark mb-3">🕒 Aktivite Akışı</h6>
                            @{
                                var activities = BuildActivityFlow();
                            }
                            @if (!activities.Any())
                            {
                                <div class="text-muted small italic">Bu problem için henüz bir aktivite bulunmuyor.</div>
                            }
                            else
                            {
                                <div class="position-relative ps-4" style="border-left: 2px solid #e3e6f0;">
                                    @foreach (var a in activities)
                                    {
                                        <div class="mb-3 position-relative">
                                            <span class="position-absolute" style="left: -1.65rem; top: 0.2rem; width: 0.7rem; height: 0.7rem; border-radius: 50%; background-color: @a.Color;"></span>
                                            <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                                                <span class="small text-dark">@a.Icon @a.Label</span>
                                                <span class="text-muted font-mono" style="font-size: 0.72rem; white-space: nowrap;">@a.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        @* BAĞLANTILI PROBLEMLER PANELİ *@
                        <div class="mt-4 p-3 border rounded bg-white shadow-sm" style="border-radius: 12px;">
                            <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                                <h6 class="font-weight-bold text-dark m-0">🔗 Bağlantılı Problemler</h6>
                                @if (isFindingRelated)
                                {
                                    <button class="btn btn-outline-primary btn-sm d-flex align-items-center gap-2" disabled>
                                        <span class="spinner-border spinner-border-sm" role="status"></span> Aranıyor...
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-outline-primary btn-sm" @onclick="FindRelatedProblems">
                                        <span class="bi bi-search"></span> Benzer Problemler Bul
                                    </button>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(relatedError))
                            {
                                <div class="alert alert-danger py-2 small mb-2">@relatedError</div>
                            }
                            @if (relatedProblems is not null)
                            {
                                @if (!relatedProblems.Any())
                                {
                                    <div class="text-muted small italic">Bağlantılı problem bulunamadı.</div>
                                }
                                else
                                {
                                    <div class="d-flex flex-column gap-2">
                                        @foreach (var rel in relatedProblems)
                                        {
                                            var relId = FindProblemIdByTitle(rel.Title);
                                            <div class="p-2 rounded border bg-light">
                                                <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                                                    <div>
                                                        @if (relId is not null)
                                                        {
                                                            <a href="/problems/@relId" class="font-weight-bold text-primary text-decoration-none small">@rel.Title</a>
                                                        }
                                                        else
                                                        {
                                                            <span class="font-weight-bold text-dark small">@rel.Title</span>
                                                        }
                                                        <span class="badge bg-secondary ms-1" style="font-size: 0.65rem;">@rel.RelationshipType</span>
                                                    </div>
                                                </div>
                                                <div class="text-muted small mt-1">@rel.Explanation</div>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else if (activeTab == "signals")
        {
            @* Yeni Sinyal Ekleme Formu *@
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fcfcfc;">
                <div class="card-header bg-secondary text-white py-3">
                    <h5 class="m-0 font-weight-bold">Yeni Kaynak Sinyal Ekle</h5>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(signalErrorMessage))
                    {
                        <div class="alert alert-danger py-2 small">@signalErrorMessage</div>
                    }
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small text-muted mb-1">Sinyal Başlığı</label>
                            <input class="form-control form-control-sm" placeholder="Örn: Müşteri Şikayeti / PDF Analizi" @bind="newSignalTitle" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small text-muted mb-1">Sinyal Türü</label>
                            <select class="form-select form-select-sm" @bind="newSignalType">
                                <option value="@SignalType.Manual">Manuel</option>
                                <option value="@SignalType.Reddit">Reddit</option>
                                <option value="@SignalType.PDF">PDF</option>
                                <option value="@SignalType.Excel">Excel</option>
                                <option value="@SignalType.Voice">Ses</option>
                                <option value="@SignalType.Image">Resim</option>
                                <option value="@SignalType.ERP">ERP</option>
                                <option value="@SignalType.Field">Saha</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small text-muted mb-1">Önem Derecesi</label>
                            <select class="form-select form-select-sm" @bind="newSeverity">
                                <option value="@SeverityLevel.Low">Düşük</option>
                                <option value="@SeverityLevel.Medium">Orta</option>
                                <option value="@SeverityLevel.High">Yüksek</option>
                                <option value="@SeverityLevel.Critical">Kritik</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label small text-muted mb-1">Sinyal Açıklaması</label>
                            <textarea class="form-control form-control-sm" rows="3" placeholder="Sinyal içeriği veya detayları..." @bind="newSignalDescription"></textarea>
                        </div>
                        <div class="col-12 text-end">
                            <button class="btn btn-primary btn-sm px-4" @onclick="AddSignal">Sinyal Ekle</button>
                        </div>
                    </div>
                </div>
            </div>

            @* Sinyal Listesi *@
            @if (signals is null)
            {
                <div class="text-center py-4">
                    <div class="spinner-border text-secondary" role="status"></div>
                    <p class="mt-2 text-muted small">Sinyaller yükleniyor...</p>
                </div>
            }
            else if (!signals.Any())
            {
                <div class="alert alert-light text-center py-4 border shadow-sm" style="border-radius: 8px;">
                    Bu probleme ait henüz bir kaynak sinyal eklenmemiş.
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var sig in signals)
                    {
                        <div class="card shadow-sm border-0" style="border-radius: 8px; border-left: 5px solid #0d6efd !important; background-color: #fff;">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="font-weight-bold m-0 text-dark">@sig.Title</h6>
                                    <div class="d-flex gap-2">
                                        <span class="badge bg-secondary">@GetSignalTypeText(sig.SignalType)</span>
                                        <span class="badge bg-info text-dark">@GetSeverityText(sig.Severity)</span>
                                    </div>
                                </div>
                                <p class="text-muted small mb-2" style="white-space: pre-wrap; line-height: 1.5;">@sig.Description</p>
                                <div class="text-end">
                                    <span class="text-muted font-mono" style="font-size: 0.75rem;">Tarih: @sig.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else if (activeTab == "opportunity")
        {
            @* Fırsat Değerlendirme Bölümü *@
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff;">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #198754, #20c997); border-bottom: none;">
                    <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                        <span class="bi bi-star-fill"></span> Fırsat Değerlendirme &amp; Skorlama
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (opportunitySuccessMessage != "")
                    {
                        <div class="alert alert-success py-2 mb-3 small">@opportunitySuccessMessage</div>
                    }
                    @if (opportunityErrorMessage != "")
                    {
                        <div class="alert alert-danger py-2 mb-3 small">@opportunityErrorMessage</div>
                    }

                    @* AI ile Otomatik Puanlama Butonu *@
                    <div class="mb-4">
                        @if (isAiOpportunityScoring)
                        {
                            <button class="btn btn-outline-success btn-sm d-flex align-items-center gap-2" disabled>
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                Yapay Zeka analiz ediyor...
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-success btn-sm d-flex align-items-center gap-2" @onclick="RunAiOpportunityScoring">
                                <span class="bi bi-cpu-fill"></span> AI ile Otomatik Puanla
                            </button>
                        }
                    </div>

                    <div class="row g-4">
                        <div class="col-md-7">
                            @* Kriterler Listesi *@
                            <div class="d-flex flex-column gap-3">
                                <div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <label class="form-label font-weight-bold m-0 small">Problem Şiddeti (Ağırlık: x3)</label>
                                        <span class="badge bg-secondary">@severityScore / 10</span>
                                    </div>
                                    <input type="range" class="form-range" min="1" max="10" step="1" @bind="severityScore" />
                                    @if (!string.IsNullOrEmpty(severityReason))
                                    {
                                        <div class="text-muted small mt-1 ps-2" style="border-left: 2px solid #198754; font-size: 0.8rem; font-style: italic;">
                                            @severityReason
                                        </div>
                                    }
                                </div>

                                <div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <label class="form-label font-weight-bold m-0 small">Pazar Büyüklüğü (Ağırlık: x2)</label>
                                        <span class="badge bg-secondary">@marketSizeScore / 10</span>
                                    </div>
                                    <input type="range" class="form-range" min="1" max="10" step="1" @bind="marketSizeScore" />
                                    @if (!string.IsNullOrEmpty(marketSizeReason))
                                    {
                                        <div class="text-muted small mt-1 ps-2" style="border-left: 2px solid #198754; font-size: 0.8rem; font-style: italic;">
                                            @marketSizeReason
                                        </div>
                                    }
                                </div>

                                <div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <label class="form-label font-weight-bold m-0 small">Kurucu Uyumu (Ağırlık: x2)</label>
                                        <span class="badge bg-secondary">@founderFitScore / 10</span>
                                    </div>
                                    <input type="range" class="form-range" min="1" max="10" step="1" @bind="founderFitScore" />
                                    @if (!string.IsNullOrEmpty(founderFitReason))
                                    {
                                        <div class="text-muted small mt-1 ps-2" style="border-left: 2px solid #198754; font-size: 0.8rem; font-style: italic;">
                                            @founderFitReason
                                        </div>
                                    }
                                </div>

                                <div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <label class="form-label font-weight-bold m-0 small">Risk (Ağırlık: x1)</label>
                                        <span class="badge bg-secondary">@riskScore / 10</span>
                                    </div>
                                    <input type="range" class="form-range" min="1" max="10" step="1" @bind="riskScore" />
                                    @if (!string.IsNullOrEmpty(riskReason))
                                    {
                                        <div class="text-muted small mt-1 ps-2" style="border-left: 2px solid #198754; font-size: 0.8rem; font-style: italic;">
                                            @riskReason
                                        </div>
                                    }
                                </div>

                                <div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <label class="form-label font-weight-bold m-0 small">Teknik Uygulanabilirlik (Ağırlık: x2)</label>
                                        <span class="badge bg-secondary">@feasibilityScore / 10</span>
                                    </div>
                                    <input type="range" class="form-range" min="1" max="10" step="1" @bind="feasibilityScore" />
                                    @if (!string.IsNullOrEmpty(feasibilityReason))
                                    {
                                        <div class="text-muted small mt-1 ps-2" style="border-left: 2px solid #198754; font-size: 0.8rem; font-style: italic;">
                                            @feasibilityReason
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="col-md-5">
                            @* Toplam Skor Gösterimi *@
                            <div class="p-4 bg-light rounded text-center mb-3 h-100 d-flex flex-column justify-content-center align-items-center" style="border: 1px solid #e3e6f0;">
                                <span class="text-muted small text-uppercase font-weight-bold">Toplam Fırsat Skoru</span>
                                <div class="display-3 font-weight-bold text-success my-2">@CalculateCurrentTotalScore().ToString("F1")</div>
                                <span class="text-muted small">Maksimum Skor: 10.0</span>
                                @if (opportunity is not null)
                                {
                                    <span class="badge bg-success mt-2">Durum: @GetOpportunityStatusText(opportunity.Status)</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary mt-2">Durum: Taslak</span>
                                }
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label small text-muted mb-1">Değerlendirme Notları</label>
                            <textarea class="form-control form-control-sm" rows="3" placeholder="Fırsat ile ilgili değerlendirme notlarınız..." @bind="opportunityNotes"></textarea>
                        </div>

                        <div class="col-12 text-end">
                            <button class="btn btn-success btn-sm px-4" @onclick="SaveOpportunity">Kaydet</button>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (activeTab == "validation")
        {
            @* Doğrulama Değerlendirme Bölümü *@
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff;">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #0dcaf0, #0d6efd); border-bottom: none;">
                    <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                        <span class="bi bi-shield-check"></span> Problem Doğrulama (Validation)
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (validationSuccessMessage != "")
                    {
                        <div class="alert alert-success py-2 mb-3 small">@validationSuccessMessage</div>
                    }
                    @if (validationErrorMessage != "")
                    {
                        <div class="alert alert-danger py-2 mb-3 small">@validationErrorMessage</div>
                    }

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label small text-muted mb-1">Görüşme Sayısı</label>
                            <input type="number" class="form-control form-control-sm" min="0" @bind="interviewCount" @bind:after="OnValidationCountChanged" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-muted mb-1">Doğrulayan Kişi Sayısı</label>
                            <input type="number" class="form-control form-control-sm" min="0" max="@interviewCount" @bind="validatedUserCount" @bind:after="OnValidationCountChanged" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-muted mb-1">Ödeme İsteği Sayısı</label>
                            <input type="number" class="form-control form-control-sm" min="0" max="@validatedUserCount" @bind="willingToPayCount" @bind:after="OnValidationCountChanged" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small text-muted mb-1">Güven Skoru (%): @confidenceScore</label>
                            <input type="range" class="form-range" min="1" max="100" @bind="confidenceScore" disabled />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small text-muted mb-1">Doğrulama Durumu</label>
                            <select class="form-select form-select-sm" @bind="validationStatus">
                                <option value="@ValidationStatus.NotStarted">Başlatılmadı</option>
                                <option value="@ValidationStatus.InProgress">Devam Ediyor</option>
                                <option value="@ValidationStatus.Validated">Doğrulandı</option>
                                <option value="@ValidationStatus.Rejected">Reddedildi</option>
                            </select>
                        </div>

                        <div class="col-12">
                            @* Doğrulama oranı gösterimi *@
                            <div class="p-3 bg-light rounded d-flex justify-content-between align-items-center">
                                <span class="font-weight-bold text-muted small text-uppercase">Doğrulama Oranı</span>
                                <span class="h4 font-weight-bold text-primary mb-0">
                                    @(interviewCount > 0 ? $"% {Math.Round((double)validatedUserCount / interviewCount * 100, 1)}" : "% 0")
                                </span>
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label small text-muted mb-1">Riskler</label>
                            <textarea class="form-control form-control-sm" rows="3" placeholder="Sürece dair riskler ve engeller..." @bind="validationRisks"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label small text-muted mb-1">Doğrulama Notları</label>
                            <textarea class="form-control form-control-sm" rows="3" placeholder="Görüşmelerden edinilen geri bildirim notları..." @bind="validationNotes"></textarea>
                        </div>

                        <div class="col-12 text-end">
                            <button class="btn btn-primary btn-sm px-4" @onclick="SaveValidation">Kaydet</button>
                        </div>
                    </div>
                </div>
            </div>

            @* AI Doğrulama Soruları Bölümü *@
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff;">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #6f42c1, #8b5cf6); border-bottom: none;">
                    <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                        <span class="bi bi-patch-question-fill"></span> AI Doğrulama Soruları
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (questionsErrorMessage != "")
                    {
                        <div class="alert alert-danger py-2 mb-3 small">@questionsErrorMessage</div>
                    }

                    <div class="mb-3">
                        @if (isGeneratingQuestions)
                        {
                            <button class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-2" disabled>
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                Yapay Zeka sorular üretiyor...
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-2" style="border-color: #6f42c1; color: #6f42c1;" @onclick="GenerateValidationQuestions">
                                <span class="bi bi-cpu-fill"></span> AI ile Doğrulama Soruları Üret
                            </button>
                        }
                    </div>

                    @if (validationQuestions.Any())
                    {
                        <p class="text-muted small mb-2">Potansiyel müşterilere bu soruları sorun ve sorduklarınızı işaretleyin:</p>
                        <div class="d-flex flex-column gap-2">
                            @for (int i = 0; i < validationQuestions.Count; i++)
                            {
                                var index = i;
                                <div class="form-check p-2.5 rounded bg-light border d-flex align-items-start gap-2" style="padding-left: 2.25rem;">
                                    <input class="form-check-input mt-1" type="checkbox" id="vq_@index"
                                           checked="@validationQuestions[index].IsAsked"
                                           @onchange="() => ToggleQuestionAsked(index)" />
                                    <label class="form-check-label small @(validationQuestions[index].IsAsked ? "text-muted text-decoration-line-through" : "text-dark")" for="vq_@index">
                                        @validationQuestions[index].Question
                                    </label>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small italic">Henüz doğrulama sorusu üretilmedi. AI ile 5 kritik doğrulama sorusu oluşturabilirsiniz.</div>
                    }
                </div>
            </div>
        }
        else if (activeTab == "research")
        {
            @* Araştırma Bölümü *@
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff;">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #0284c7, #0369a1); border-bottom: none;">
                    <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                        <span class="bi bi-search"></span> Pazar &amp; Teknoloji Araştırması (Research)
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (researchSuccessMessage != "")
                    {
                        <div class="alert alert-success py-2 mb-3 small">@researchSuccessMessage</div>
                    }
                    @if (researchErrorMessage != "")
                    {
                        <div class="alert alert-danger py-2 mb-3 small">@researchErrorMessage</div>
                    }

                    @* AI ile Araştırma Butonu *@
                    <div class="mb-4 d-flex justify-content-between align-items-center">
                        @if (isAiResearching)
                        {
                            <button class="btn btn-outline-info btn-sm d-flex align-items-center gap-2" disabled>
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                Yapay Zeka araştırıyor...
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-info btn-sm d-flex align-items-center gap-2" @onclick="RunAiResearch">
                                <span class="bi bi-cpu-fill"></span> AI ile Araştır
                            </button>
                        }

                        @if (researchDto?.ResearchedAt is not null)
                        {
                            <span class="text-muted small" style="font-size: 0.8rem;">Son Araştırma Tarihi: @researchDto.ResearchedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
                        }
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small text-muted mb-1 font-weight-bold">Pazar Analizi</label>
                            <textarea class="form-control form-control-sm" rows="4" placeholder="Pazar büyüklüğü, hedef kitle ve fırsat analizleri..." @bind="marketAnalysis"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label small text-muted mb-1 font-weight-bold">Rakip Özeti</label>
                            <textarea class="form-control form-control-sm" rows="4" placeholder="Doğrudan ve dolaylı rakipler, güçlü ve zayıf yönleri..." @bind="competitorSummary"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label small text-muted mb-1 font-weight-bold">Teknoloji Notları</label>
                            <textarea class="form-control form-control-sm" rows="4" placeholder="Kullanılacak teknolojiler, altyapı ve mimari alternatifleri..." @bind="technologyNotes"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label small text-muted mb-1 font-weight-bold">Trend Notları</label>
                            <textarea class="form-control form-control-sm" rows="4" placeholder="Sektörel trendler, büyüme oranları ve gelecek projeksiyonları..." @bind="trendNotes"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label small text-muted mb-1 font-weight-bold">Kaynaklar</label>
                            <textarea class="form-control form-control-sm" rows="3" placeholder="Referans linkler, raporlar ve dokümantasyon kaynakları..." @bind="researchSources"></textarea>
                        </div>

                        <div class="col-12 text-end">
                            <button class="btn btn-primary btn-sm px-4" style="background-color: #0284c7; border-color: #0284c7;" @onclick="SaveResearch">Kaydet</button>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (activeTab == "solutions")
        {
            @* Çözüm Önerileri Bölümü *@
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff;">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #198754, #0f5132); border-bottom: none;">
                    <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                        <span class="bi bi-lightbulb-fill"></span> Çözüm Önerileri (Solution Engine)
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (solutionSuccessMessage != "")
                    {
                        <div class="alert alert-success py-2 mb-3 small">@solutionSuccessMessage</div>
                    }
                    @if (solutionErrorMessage != "")
                    {
                        <div class="alert alert-danger py-2 mb-3 small">@solutionErrorMessage</div>
                    }

                    @* AI ile Çözüm Öner Butonu *@
                    <div class="mb-4">
                        @if (isAiSuggestingSolutions)
                        {
                            <button class="btn btn-outline-success btn-sm d-flex align-items-center gap-2" disabled>
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                Yapay Zeka çözüm alternatifleri geliştiriyor...
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-success btn-sm d-flex align-items-center gap-2" @onclick="RunAiSuggestSolutions">
                                <span class="bi bi-cpu-fill"></span> AI ile Çözüm Öner
                            </button>
                        }
                    </div>

                    @* Mevcut Çözüm Önerileri Kartları *@
                    @if (solutions is null)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-success" role="status"></div>
                            <p class="mt-2 text-muted small">Çözümler yükleniyor...</p>
                        </div>
                    }
                    else if (!solutions.Any())
                    {
                        <div class="alert alert-light text-center py-4 border shadow-sm" style="border-radius: 8px;">
                            Bu probleme ait henüz bir çözüm önerisi eklenmemiş. AI ile öneri alabilir veya manuel ekleyebilirsiniz.
                        </div>
                    }
                    else
                    {
                        <div class="row g-3 mb-4">
                            @foreach (var sol in solutions)
                            {
                                <div class="col-md-6">
                                    <div class="card h-100 shadow-sm border-0 position-relative" style="border-radius: 12px; border: 1px solid #e3e6f0; background-color: #fff; overflow: hidden; border-left: 5px solid @(sol.IsRecommended ? "#198754" : "#0d6efd") !important;">
                                        @if (sol.IsRecommended)
                                        {
                                            <div class="position-absolute top-0 end-0 m-2">
                                                <span class="badge bg-success px-2.5 py-1.5"><span class="bi bi-check-circle-fill"></span> Önerilen</span>
                                            </div>
                                        }
                                        <div class="card-body p-3">
                                            <h5 class="card-title font-weight-bold text-dark m-0 mb-2">@GetSolutionTypeText(sol.SolutionType)</h5>
                                            <p class="card-text text-muted small mb-3" style="line-height: 1.5;">@sol.Summary</p>

                                            <div class="row g-2 mb-3">
                                                <div class="col-6">
                                                    <span class="text-muted small d-block">Karmaşıklık</span>
                                                    <span class="badge @GetComplexityBadgeClass(sol.Complexity)">@GetComplexityText(sol.Complexity)</span>
                                                </div>
                                                <div class="col-6">
                                                    <span class="text-muted small d-block">Süre / Maliyet</span>
                                                    <span class="text-dark small font-weight-bold">@sol.EstimatedDurationMonths Ay / @(string.IsNullOrEmpty(sol.EstimatedCost) ? "-" : sol.EstimatedCost)</span>
                                                </div>
                                            </div>

                                            @if (!string.IsNullOrEmpty(sol.Pros))
                                            {
                                                <div class="mb-2">
                                                    <span class="text-success small font-weight-bold d-block">&plus; Artılar:</span>
                                                    <p class="text-muted small m-0">@sol.Pros</p>
                                                </div>
                                            }

                                            @if (!string.IsNullOrEmpty(sol.Cons))
                                            {
                                                <div class="mb-2">
                                                    <span class="text-danger small font-weight-bold d-block">&minus; Eksiler:</span>
                                                    <p class="text-muted small m-0">@sol.Cons</p>
                                                </div>
                                            }
                                        </div>
                                        <div class="card-footer bg-light border-0 text-end p-2">
                                            <button class="btn btn-outline-danger btn-sm py-1 px-2" @onclick="() => DeleteSolution(sol.Id)" style="font-size: 0.8rem;">
                                                <span class="bi bi-trash"></span> Sil
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    @* Yeni Manuel Çözüm Ekleme Formu *@
                    <div class="card border shadow-sm mb-0" style="border-radius: 12px; background-color: #fcfcfc;">
                        <div class="card-header bg-secondary text-white py-2">
                            <h6 class="m-0 font-weight-bold">Yeni Çözüm Alternatifi Ekle</h6>
                        </div>
                        <div class="card-body p-3">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label small text-muted mb-1">Çözüm Türü</label>
                                    <select class="form-select form-select-sm" @bind="newSolutionType">
                                        <option value="@SolutionType.WebApp">Web Uygulaması</option>
                                        <option value="@SolutionType.MobileApp">Mobil Uygulama</option>
                                        <option value="@SolutionType.DesktopApp">Masaüstü Uygulama</option>
                                        <option value="@SolutionType.SaaS">SaaS Platformu</option>
                                        <option value="@SolutionType.AIAgent">Yapay Zeka Ajanı</option>
                                        <option value="@SolutionType.BrowserExtension">Tarayıcı Eklentisi</option>
                                        <option value="@SolutionType.APIService">API Servisi</option>
                                        <option value="@SolutionType.ERPModule">ERP Modülü</option>
                                        <option value="@SolutionType.IoT">IoT</option>
                                        <option value="@SolutionType.PhysicalProduct">Fiziksel Ürün</option>
                                        <option value="@SolutionType.ProcessImprovement">Süreç İyileştirme</option>
                                        <option value="@SolutionType.Education">Eğitim</option>
                                        <option value="@SolutionType.Consulting">Danışmanlık</option>
                                        <option value="@SolutionType.Hybrid">Hibrit Model</option>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label small text-muted mb-1">Karmaşıklık Seviyesi</label>
                                    <select class="form-select form-select-sm" @bind="newComplexity">
                                        <option value="@ComplexityLevel.Low">Düşük</option>
                                        <option value="@ComplexityLevel.Medium">Orta</option>
                                        <option value="@ComplexityLevel.High">Yüksek</option>
                                        <option value="@ComplexityLevel.VeryHigh">Çok Yüksek</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label small text-muted mb-1">Tahmini Yapım Süresi (Ay)</label>
                                    <input type="number" class="form-control form-control-sm" min="1" @bind="newSolutionDuration" />
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label small text-muted mb-1">Tahmini Maliyet</label>
                                    <input type="text" class="form-control form-control-sm" placeholder="Örn: 50,000 TL / Aylık sunucu" @bind="newSolutionCost" />
                                </div>

                                <div class="col-md-4 d-flex align-items-end">
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" id="isRecCheck" @bind="newSolutionIsRecommended" />
                                        <label class="form-check-label small text-muted font-weight-bold" for="isRecCheck">
                                            Ana Çözüm Olarak Öner
                                        </label>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <label class="form-label small text-muted mb-1">Çözüm Özeti</label>
                                    <textarea class="form-control form-control-sm" rows="2" placeholder="Nasıl çalışacak, hangi problemi nasıl çözecek..." @bind="newSolutionSummary"></textarea>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label small text-muted mb-1 text-success font-weight-bold">&plus; Avantajlar (Artılar)</label>
                                    <textarea class="form-control form-control-sm" rows="2" placeholder="Hızlı entegrasyon, yüksek performans vb." @bind="newSolutionPros"></textarea>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label small text-muted mb-1 text-danger font-weight-bold">&minus; Dezavantajlar (Eksiler)</label>
                                    <textarea class="form-control form-control-sm" rows="2" placeholder="Yüksek bakım maliyeti, internet bağımlılığı vb." @bind="newSolutionCons"></textarea>
                                </div>

                                <div class="col-12 text-end">
                                    <button class="btn btn-primary btn-sm px-4" @onclick="SaveManualSolution">Çözüm Ekle</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (activeTab == "mvp")
        {
            @* MVP Planı Bölümü *@
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff;">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #4f46e5, #3730a3); border-bottom: none;">
                    <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                        <span class="bi bi-list-task"></span> MVP Planlayıcı (MVP Planner)
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (mvpSuccessMessage != "")
                    {
                        <div class="alert alert-success py-2 mb-3 small">@mvpSuccessMessage</div>
                    }
                    @if (mvpErrorMessage != "")
                    {
                        <div class="alert alert-danger py-2 mb-3 small">@mvpErrorMessage</div>
                    }

                    @* AI ile MVP Planı Oluştur Butonu *@
                    <div class="mb-4 d-flex justify-content-between align-items-center">
                        @if (isAiGeneratingMvp)
                        {
                            <button class="btn btn-outline-primary btn-sm d-flex align-items-center gap-2" disabled>
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                Yapay Zeka MVP planı hazırlıyor...
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-primary btn-sm d-flex align-items-center gap-2" @onclick="RunAiGenerateMVPPlan">
                                <span class="bi bi-cpu-fill"></span> AI ile MVP Planı Oluştur
                            </button>
                        }

                        @if (mvpPlanDto?.UpdatedAt is not null)
                        {
                            <span class="text-muted small" style="font-size: 0.8rem;">Son Güncelleme: @mvpPlanDto.UpdatedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
                        }
                        else if (mvpPlanDto?.CreatedAt is not null)
                        {
                            <span class="text-muted small" style="font-size: 0.8rem;">Son Güncelleme: @mvpPlanDto.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
                        }
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small text-muted mb-1 font-weight-bold">MVP Kapsamı Özeti</label>
                            <textarea class="form-control form-control-sm" rows="3" placeholder="MVP kapsamında yer alacak temel özellikler ve hedefler..." @bind="mvpScope"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label small text-muted mb-2 font-weight-bold d-block">Kullanıcı Hikayeleri (User Stories)</label>
                            @for (int i = 0; i < mvpUserStories.Count; i++)
                            {
                                var index = i;
                                <div class="input-group input-group-sm mb-2">
                                    <span class="input-group-text bg-light font-mono" style="font-size: 0.8rem;">Story #@(index+1)</span>
                                    <input class="form-control form-control-sm" placeholder="Kullanıcı olarak şunu yapmak istiyorum..." @bind="mvpUserStories[index]" />
                                    <button class="btn btn-outline-danger" type="button" @onclick="() => mvpUserStories.RemoveAt(index)">Sil</button>
                                </div>
                            }
                            <button class="btn btn-outline-secondary btn-sm mt-1" type="button" @onclick='() => mvpUserStories.Add("")'>
                                <span class="bi bi-plus"></span> Hikaye Ekle
                            </button>
                        </div>

                        <div class="col-12">
                            <label class="form-label small text-muted mb-2 font-weight-bold d-block">Sprint Planı (3 Sprint)</label>
                            @for (int i = 0; i < mvpSprintPlan.Count; i++)
                            {
                                var index = i;
                                <div class="input-group input-group-sm mb-2">
                                    <span class="input-group-text bg-light font-mono" style="font-size: 0.8rem;">Sprint #@(index+1)</span>
                                    <input class="form-control form-control-sm" placeholder="Sprint hedefleri ve teslimatları..." @bind="mvpSprintPlan[index]" />
                                    <button class="btn btn-outline-danger" type="button" @onclick="() => mvpSprintPlan.RemoveAt(index)">Sil</button>
                                </div>
                            }
                            <button class="btn btn-outline-secondary btn-sm mt-1" type="button" @onclick='() => mvpSprintPlan.Add("")'>
                                <span class="bi bi-plus"></span> Sprint Ekle
                            </button>
                        </div>

                        <div class="col-12">
                            <label class="form-label small text-muted mb-1 font-weight-bold">Teknoloji Önerileri (Tech Stack)</label>
                            <textarea class="form-control form-control-sm" rows="3" placeholder="Önerilen frontend, backend, database ve DevOps altyapıları..." @bind="mvpTechStack"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label small text-muted mb-1 font-weight-bold">Riskler</label>
                            <textarea class="form-control form-control-sm" rows="3" placeholder="Teknolojik veya süreçsel MVP riskleri..." @bind="mvpRisks"></textarea>
                        </div>

                        <div class="col-12">
                            <label class="form-label small text-muted mb-1 font-weight-bold">İlk Satış / Pazara Giriş Planı</label>
                            <textarea class="form-control form-control-sm" rows="3" placeholder="MVP'yi test edecek ilk müşterilere ulaşma stratejileri..." @bind="mvpFirstSalesPlan"></textarea>
                        </div>

                        <div class="col-12 text-end">
                            <button class="btn btn-primary btn-sm px-4" style="background-color: #4f46e5; border-color: #4f46e5;" @onclick="SaveMVPPlan">Kaydet</button>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (activeTab == "action_plan")
        {
            @* Aksiyon Planı Bölümü *@
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff;">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #1e3a8a, #3b82f6); border-bottom: none;">
                    <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                        <span class="bi bi-calendar-check"></span> 30-60-90 Günlük Aksiyon Planı
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(actionPlanError))
                    {
                        <div class="alert alert-danger py-2 mb-3 small">@actionPlanError</div>
                    }

                    <div class="mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
                        @if (isGeneratingActionPlan)
                        {
                            <button class="btn btn-outline-primary btn-sm d-flex align-items-center gap-2" disabled>
                                <span class="spinner-border spinner-border-sm" role="status"></span> Yapay Zeka plan oluşturuyor...
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-primary btn-sm d-flex align-items-center gap-2" @onclick="GenerateActionPlan">
                                <span class="bi bi-cpu-fill"></span> AI ile Aksiyon Planı Oluştur (Kaydeder)
                            </button>
                        }
                        @if (actionPlan is not null)
                        {
                            <span class="text-muted small">Son güncelleme: @actionPlan.GeneratedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                        }
                    </div>

                    @if (actionPlan is null)
                    {
                        <div class="alert alert-light text-center py-4 border shadow-sm mb-0" style="border-radius: 8px;">
                            Bu problem için henüz bir aksiyon planı oluşturulmamış.
                        </div>
                    }
                    else
                    {
                        @* 30 / 60 / 90 gün sütunları *@
                        <div class="row g-3 mb-4">
                            <div class="col-md-4">@RenderActionColumn("30 Gün", actionPlan.Day30, "#1d4ed8")</div>
                            <div class="col-md-4">@RenderActionColumn("60 Gün", actionPlan.Day60, "#7c3aed")</div>
                            <div class="col-md-4">@RenderActionColumn("90 Gün", actionPlan.Day90, "#059669")</div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="p-3 rounded h-100" style="background-color: #f0fdf4;">
                                    <h6 class="font-weight-bold text-success mb-2">🎯 Başarı Metrikleri</h6>
                                    @if (actionPlan.SuccessMetrics.Any())
                                    {
                                        <ul class="mb-0 ps-3 small text-dark">
                                            @foreach (var m in actionPlan.SuccessMetrics)
                                            {
                                                <li>@m</li>
                                            }
                                        </ul>
                                    }
                                    else { <span class="text-muted small">-</span> }
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="p-3 rounded h-100" style="background-color: #fefce8;">
                                    <h6 class="font-weight-bold text-warning mb-2">⚡ Hızlı Kazanımlar</h6>
                                    @if (actionPlan.QuickWins.Any())
                                    {
                                        <ul class="mb-0 ps-3 small text-dark">
                                            @foreach (var q in actionPlan.QuickWins)
                                            {
                                                <li>@q</li>
                                            }
                                        </ul>
                                    }
                                    else { <span class="text-muted small">-</span> }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else if (activeTab == "notes")
        {
            @* Notlar Bölümü *@
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff;">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #475569, #64748b); border-bottom: none;">
                    <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                        <span class="bi bi-sticky-fill"></span> Notlar
                    </h5>
                </div>
                <div class="card-body p-4">
                    @* Hızlı not ekleme *@
                    <div class="row g-2 mb-4">
                        <div class="col-md-3">
                            <label class="form-label small text-muted mb-1 font-weight-bold">Not Tipi</label>
                            <select class="form-select form-select-sm" @bind="newNoteType">
                                <option value="@NoteType.General">Genel</option>
                                <option value="@NoteType.Idea">Fikir</option>
                                <option value="@NoteType.Risk">Risk</option>
                                <option value="@NoteType.Action">Aksiyon</option>
                                <option value="@NoteType.Meeting">Toplantı</option>
                            </select>
                        </div>
                        <div class="col-md-9">
                            <label class="form-label small text-muted mb-1 font-weight-bold">İçerik</label>
                            <textarea class="form-control form-control-sm" rows="2" placeholder="Notunuzu yazın..." @bind="newNoteContent"></textarea>
                        </div>
                        <div class="col-12 text-end">
                            <button class="btn btn-sm text-white px-4" style="background-color: #475569;" @onclick="AddNote" disabled="@isAddingNote">
                                @if (isAddingNote)
                                {
                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                }
                                else
                                {
                                    <span>Ekle</span>
                                }
                            </button>
                        </div>
                    </div>

                    @* Notlar zaman çizelgesi (yeniden eskiye) *@
                    @if (problemNotes is null || !problemNotes.Any())
                    {
                        <div class="alert alert-light text-center py-4 border shadow-sm mb-0" style="border-radius: 8px;">
                            Bu probleme ait henüz bir not eklenmemiş.
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-2">
                            @foreach (var note in problemNotes)
                            {
                                <div class="p-3 rounded border" style="background-color: #fcfcfc; border-left: 4px solid @GetNoteTypeColor(note.NoteType) !important;">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="badge text-white" style="background-color: @GetNoteTypeColor(note.NoteType); font-size: 0.7rem;">@GetNoteTypeText(note.NoteType)</span>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="text-muted font-mono" style="font-size: 0.72rem;">@note.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                            <button class="btn btn-outline-danger btn-sm py-0 px-1" style="font-size: 0.7rem;" @onclick="() => DeleteNote(note.Id)" title="Sil">
                                                <span class="bi bi-trash"></span>
                                            </button>
                                        </div>
                                    </div>
                                    <p class="mb-0 text-dark small" style="white-space: pre-line;">@note.Content</p>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
        else if (activeTab == "revenue")
        {
            @* Gelir Analizi Bölümü *@
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff;">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #059669, #10b981); border-bottom: none;">
                    <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                        <span class="bi bi-cash-coin"></span> Gelir Analizi (Revenue Analyzer)
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (revenueSuccessMessage != "")
                    {
                        <div class="alert alert-success py-2 mb-3 small">@revenueSuccessMessage</div>
                    }
                    @if (revenueErrorMessage != "")
                    {
                        <div class="alert alert-danger py-2 mb-3 small">@revenueErrorMessage</div>
                    }

                    @* AI ile Gelir Analizi Butonu *@
                    <div class="mb-4 d-flex justify-content-between align-items-center">
                        @if (isRevenueAnalyzing)
                        {
                            <button class="btn btn-outline-success btn-sm d-flex align-items-center gap-2" disabled>
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                Yapay Zeka gelir modelini analiz ediyor...
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-success btn-sm d-flex align-items-center gap-2" @onclick="RunAiRevenueAnalysis">
                                <span class="bi bi-cpu-fill"></span> AI ile Gelir Analizi Yap
                            </button>
                        }

                        @if (revenueDto is not null)
                        {
                            <span class="text-muted small" style="font-size: 0.8rem;">Son Analiz: @revenueDto.AnalyzedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
                        }
                    </div>

                    @if (revenueDto is not null)
                    {
                        <RevenueAnalysisView Result="revenueDto" />
                    }
                    else
                    {
                        <div class="alert alert-light text-center py-4 border shadow-sm" style="border-radius: 8px;">
                            Bu problem için henüz bir gelir analizi yapılmamış. Yukarıdaki buton ile AI destekli gelir analizini başlatabilirsiniz.
                        </div>
                    }
                </div>
            </div>
        }
        else if (activeTab == "ai_analysis")
        {
            @* AI Analiz Bölümü *@
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff;">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #6f42c1, #8553d1); border-bottom: none;">
                    <h5 class="m-0 font-weight-bold d-flex align-items-center gap-2">
                        <span class="bi bi-cpu-fill"></span> Yapay Zeka Analizi
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (isAnalyzing)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border" role="status" style="color: #6f42c1;"></div>
                            <p class="mt-2 text-muted">Yapay zeka problemi analiz ediyor, lütfen bekleyin...</p>
                        </div>
                    }
                    else if (problemAnalysis is null)
                    {
                        <div class="text-center py-5">
                            @if (!string.IsNullOrEmpty(aiErrorMessage))
                            {
                                <div class="alert alert-danger py-2 mb-3 small" style="max-width: 500px; margin: 0 auto 1.5rem auto;">@aiErrorMessage</div>
                            }
                            <p class="text-muted">Bu problem için henüz yapay zeka analizi yapılmamış.</p>
                            <button class="btn btn-primary px-4" @onclick="RunAiAnalysis" style="background-color: #6f42c1; border-color: #6f42c1;">
                                <span class="bi bi-play-fill"></span> Analiz Et
                            </button>
                        </div>
                    }
                    else
                    {
                        @if (!string.IsNullOrEmpty(aiErrorMessage))
                        {
                            <div class="alert alert-danger py-2 mb-3 small">@aiErrorMessage</div>
                        }

                        <div class="mb-4">
                            <h6 class="font-weight-bold mb-2" style="color: #6f42c1;">Yapay Zeka Özeti</h6>
                            <div class="p-3 bg-light rounded" style="line-height: 1.6; border-left: 4px solid #6f42c1; color: #495057;">
                                @problemAnalysis.Summary
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-sm-6">
                                <div class="p-3 bg-light rounded h-100">
                                    <span class="text-muted d-block small">Önerilen Kategori</span>
                                    <span class="font-weight-bold text-dark mt-1 d-block">@problemAnalysis.SuggestedCategory</span>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 bg-light rounded h-100">
                                    <span class="text-muted d-block small">Önerilen Etiketler</span>
                                    <span class="font-weight-bold text-dark mt-1 d-block">@problemAnalysis.SuggestedTags</span>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 bg-light rounded h-100">
                                    <span class="text-muted d-block small">Risk Seviyesi</span>
