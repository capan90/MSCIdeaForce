    private record ActivityFlowItem(string Icon, string Label, DateTime Timestamp, string Color);

    private List<ActivityFlowItem> BuildActivityFlow()
    {
        var list = new List<ActivityFlowItem>();

        if (problem is not null)
            list.Add(new("📌", "Problem oluşturuldu", problem.CreatedAt, "#6c757d"));
        if (problemAnalysis is not null)
            list.Add(new("🤖", "AI Analizi yapıldı", problemAnalysis.AnalyzedAt, "#6f42c1"));
        if (researchDto?.ResearchedAt is not null)
            list.Add(new("🔍", "Araştırma yapıldı", researchDto.ResearchedAt.Value, "#0284c7"));
        if (opportunity is not null)
            list.Add(new("⭐", "Fırsat skorlandı", opportunity.CreatedAt, "#198754"));
        if (validationDto is not null)
            list.Add(new("✅", "Doğrulama güncellendi", validationDto.CreatedAt, "#0dcaf0"));
        if (solutions is not null && solutions.Any())
            list.Add(new("💡", $"Çözüm önerildi ({solutions.Count()} öneri)", solutions.Min(s => s.CreatedAt), "#0f5132"));
        if (mvpPlanDto is not null)
            list.Add(new("🚀", "MVP Planı oluşturuldu", mvpPlanDto.UpdatedAt ?? mvpPlanDto.CreatedAt, "#4f46e5"));
        if (revenueDto is not null)
            list.Add(new("💰", "Gelir analizi yapıldı", revenueDto.AnalyzedAt, "#059669"));
        if (decisions is not null)
            foreach (var d in decisions)
                list.Add(new("📋", $"Karar verildi ({GetDecisionTypeText(d.DecisionType)})", d.DecisionDate, "#475569"));
        if (problemNotes is not null)
            foreach (var n in problemNotes)
                list.Add(new("📝", $"Not eklendi ({GetNoteTypeText(n.NoteType)})", n.CreatedAt, GetNoteTypeColor(n.NoteType)));

        return list.OrderBy(a => a.Timestamp).ToList();
    }

    /// <summary>
    /// Problem özetini belirlenen formatta panoya kopyalar.
    /// </summary>
    private async Task CopySummary()
    {
        if (problem is null) return;

        var score = opportunity is not null ? $"{opportunity.TotalScore:0.0}/10" : "Puanlanmadı";
        var sector = string.IsNullOrWhiteSpace(problem.Sector) ? "Belirtilmemiş" : problem.Sector;
        var summary = string.IsNullOrWhiteSpace(problemAnalysis?.Summary) ? "-" : problemAnalysis!.Summary;
        var solution = string.IsNullOrWhiteSpace(problemAnalysis?.SolutionTypeSuggestion) ? "-" : problemAnalysis!.SolutionTypeSuggestion;
        var revenueModel = string.IsNullOrWhiteSpace(revenueDto?.RevenueModel) ? "-" : revenueDto!.RevenueModel;

        var text = $"🎯 Problem: {problem.Title}\n" +
                   $"📊 Fırsat Skoru: {score}\n" +
                   $"🏭 Sektör: {sector}\n" +
                   $"📝 Özet: {summary}\n" +
                   $"💡 Çözüm Önerisi: {solution}\n" +
                   $"📈 Gelir Modeli: {revenueModel}";

        try
        {
            await JsRuntime.InvokeVoidAsync("appInterop.copyToClipboard", text);
            copyMessage = "Kopyalandı!";
        }
        catch
        {
            copyMessage = "Kopyalanamadı.";
        }
    }

