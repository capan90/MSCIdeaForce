    /// </summary>
    private async Task FindRelatedProblems()
    {
        if (problem is null) return;

        relatedError = "";
        isFindingRelated = true;
        relatedProblems = null;
        StateHasChanged();
        try
        {
            allProblemsCache = await GetProblemsHandler.HandleAsync();
            var otherTitles = allProblemsCache
                .Where(p => p.Id != Id)
                .Select(p => p.Title)
                .ToList();

            relatedProblems = await AIProvider.FindRelatedProblemsAsync(problem.Title, problem.Description, otherTitles);
        }
        catch (Exception ex)
        {
            relatedError = $"Bağlantılı problemler aranırken bir hata oluştu: {ex.Message}";
        }
        finally
        {
            isFindingRelated = false;
            StateHasChanged();
        }
    }

    // Başlığa göre problem ID'sini bulur (bulunamazsa null)
    private Guid? FindProblemIdByTitle(string title)
    {
        var match = allProblemsCache?.FirstOrDefault(p => string.Equals(p.Title, title, StringComparison.OrdinalIgnoreCase));
        return match?.Id;
