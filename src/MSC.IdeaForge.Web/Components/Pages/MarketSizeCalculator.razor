@page "/market-size"
@rendermode InteractiveServer
@using MSC.IdeaForge.Domain.Interfaces
@using MSC.IdeaForge.Domain.ValueObjects
@inject MSC.IdeaForge.Application.Problems.Queries.GetProblemsHandler GetProblemsHandler
@inject IAIProvider AIProvider
@inject MSC.IdeaForge.Application.Researches.Commands.SaveResearchHandler SaveResearchHandler
@inject MSC.IdeaForge.Application.Researches.Queries.GetResearchByProblemHandler GetResearchByProblemHandler

<PageTitle>Pazar Hesaplayıcı</PageTitle>

<div class="container mt-4" style="max-width: 900px;">
    <div class="mb-4">
        <h1 class="font-weight-bold text-dark mb-1" style="letter-spacing: -1px;">Pazar Büyüklüğü Hesaplayıcı</h1>
        <p class="text-muted mb-0">Seçilen problem için TAM / SAM / SOM pazar büyüklüğünü yapay zeka ile hesaplayın.</p>
    </div>

    <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; background-color: #fff; border: 1px solid #e3e6f0 !important;">
        <div class="card-body p-3">
            @if (!string.IsNullOrEmpty(message))
            {
                <div class="alert @(isError ? "alert-danger" : "alert-success") py-2 mb-3 small">@message</div>
            }
            <div class="row g-2 align-items-end">
                <div class="col-md-8">
                    <label class="form-label small text-muted mb-1 font-weight-bold">Problem Seçin</label>
                    <select class="form-select form-select-sm" value="@selectedProblemId" @onchange="OnProblemSelected">
                        <option value="">-- Problem seçin --</option>
                        @if (problems is not null)
                        {
                            @foreach (var p in problems)
                            {
                                <option value="@p.Id">@p.Title</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    @if (isCalculating)
                    {
                        <button class="btn btn-primary btn-sm w-100 d-flex align-items-center justify-content-center gap-2" disabled>
                            <span class="spinner-border spinner-border-sm" role="status"></span> Hesaplanıyor...
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-primary btn-sm w-100" @onclick="Calculate" disabled="@(selectedProblemId == Guid.Empty)">
                            📊 Pazar Büyüklüğü Hesapla
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (result is not null)
    {
        @* TAM / SAM / SOM huni görünümü *@
        <div class="card shadow-sm border-0 mb-4" style="border-radius: 12px; border: 1px solid #e3e6f0;">
            <div class="card-body p-4">
                <div class="d-flex flex-column align-items-center gap-2 mb-4">
                    @RenderFunnelLevel("TAM", result.TAM, result.TAMDescription, "#1d4ed8", "100%")
                    @RenderFunnelLevel("SAM", result.SAM, result.SAMDescription, "#2563eb", "72%")
                    @RenderFunnelLevel("SOM", result.SOM, result.SOMDescription, "#60a5fa", "46%")
                </div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="p-3 rounded h-100" style="background-color: #f0fdf4;">
                            <h6 class="font-weight-bold text-success mb-1">📈 Büyüme Oranı</h6>
                            <p class="mb-0 text-dark small" style="white-space: pre-line;">@DisplayValue(result.GrowthRate)</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 rounded h-100" style="background-color: #fefce8;">
                            <h6 class="font-weight-bold text-warning mb-1">🔑 Temel Varsayımlar</h6>
                            <p class="mb-0 text-dark small" style="white-space: pre-line;">@DisplayValue(result.KeyAssumptions)</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 rounded h-100" style="background-color: #eff6ff;">
                            <h6 class="font-weight-bold text-primary mb-1">📚 Veri Kaynakları</h6>
                            <p class="mb-0 text-dark small" style="white-space: pre-line;">@DisplayValue(result.DataSources)</p>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end align-items-center gap-3 mt-4">
                    @* Kaydetme sonucu geri bildirimi (butonun yanında görünür) *@
                    @if (!string.IsNullOrEmpty(message))
                    {
                        <span class="small font-weight-bold @(isError ? "text-danger" : "text-success")">@message</span>
                    }
                    <button class="btn btn-success btn-sm px-4" @onclick="SaveToResearch" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                        }
                        else
                        {
                            <span>💾 Araştırmaya Kaydet</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private IEnumerable<MSC.IdeaForge.Application.Problems.DTOs.ProblemDto>? problems;
    private Guid selectedProblemId = Guid.Empty;
    private MarketSizeResult? result;
    private bool isCalculating = false;
    private bool isSaving = false;
    private string message = "";
    private bool isError = false;

    protected override async Task OnInitializedAsync()
    {
        problems = await GetProblemsHandler.HandleAsync();
    }

    private void OnProblemSelected(ChangeEventArgs e)
    {
        result = null;
        message = "";
        selectedProblemId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : Guid.Empty;
    }

    /// <summary>
    /// Seçili problem için pazar büyüklüğünü hesaplar.
    /// </summary>
    private async Task Calculate()
    {
        var problem = problems?.FirstOrDefault(p => p.Id == selectedProblemId);
        if (problem is null) return;

        message = "";
        isError = false;
        isCalculating = true;
        result = null;
        StateHasChanged();
        try
        {
            result = await AIProvider.CalculateMarketSizeAsync(problem.Title, problem.Description, problem.Sector);
        }
        catch (Exception ex)
        {
            message = $"Hesaplama sırasında bir hata oluştu: {ex.Message}";
            isError = true;
        }
        finally
        {
            isCalculating = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Pazar büyüklüğü sonucunu mevcut Research kaydına (Pazar Analizi alanı) kaydeder; diğer alanları korur.
    /// </summary>
    private async Task SaveToResearch()
    {
        if (result is null || selectedProblemId == Guid.Empty) return;

        isSaving = true;
        message = "";
        StateHasChanged();
        try
        {
            // Mevcut araştırma verisini koruyarak Pazar Analizi ve Kaynak alanlarını güncelliyoruz
            var existing = await GetResearchByProblemHandler.HandleAsync(selectedProblemId);

            // İstenen tek satırlık özet formatı
            var marketAnalysis = $"TAM: {result.TAM} | SAM: {result.SAM} | SOM: {result.SOM} | Büyüme: {result.GrowthRate}";

            await SaveResearchHandler.HandleAsync(new MSC.IdeaForge.Application.Researches.Commands.SaveResearchCommand
            {
                ProblemId = selectedProblemId,
                MarketAnalysis = marketAnalysis,
                CompetitorSummary = existing?.CompetitorSummary,
                TechnologyNotes = existing?.TechnologyNotes,
                TrendNotes = existing?.TrendNotes,
                Sources = string.IsNullOrWhiteSpace(existing?.Sources) ? result.DataSources : $"{existing!.Sources}\n{result.DataSources}"
            });

            message = "Pazar büyüklüğü araştırma verisine kaydedildi ✓";
            isError = false;
        }
        catch (Exception ex)
        {
            message = $"Kaydetme sırasında bir hata oluştu: {ex.Message}";
            isError = true;
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    // Huni seviyesini render eder (genişlik azalarak daralan bantlar)
    private RenderFragment RenderFunnelLevel(string label, string value, string desc, string color, string width) => @<div style="width: @width; max-width: 100%;">
        <div class="text-white text-center p-3 shadow-sm" style="background-color: @color; border-radius: 8px;">
            <div class="d-flex justify-content-between align-items-center">
                <span class="font-weight-bold">@label</span>
                <span class="font-weight-bold" style="font-size: 1.1rem;">@DisplayValue(value)</span>
            </div>
            <div class="small opacity-75 mt-1 text-start" style="white-space: pre-line;">@DisplayValue(desc)</div>
        </div>
    </div>;

    private static string DisplayValue(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
}
