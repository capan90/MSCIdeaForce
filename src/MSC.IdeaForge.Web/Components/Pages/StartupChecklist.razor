@page "/startup-checklist"

@using MSC.IdeaForge.Domain.Enums
@using MSC.IdeaForge.Domain.Interfaces
@using MSC.IdeaForge.Application.Checklists.DTOs
@inject MSC.IdeaForge.Application.Problems.Queries.GetProblemsHandler GetProblemsHandler
@inject IAIProvider AIProvider
@inject MSC.IdeaForge.Application.Checklists.Commands.CreateChecklistItemHandler CreateChecklistItemHandler
@inject MSC.IdeaForge.Application.Checklists.Commands.UpdateChecklistItemHandler UpdateChecklistItemHandler
@inject MSC.IdeaForge.Application.Checklists.Commands.DeleteChecklistItemHandler DeleteChecklistItemHandler
@inject MSC.IdeaForge.Application.Checklists.Queries.GetChecklistItemsHandler GetChecklistItemsHandler

<PageTitle>Başlangıç Kontrol Listesi</PageTitle>

<div class="container mt-4" style="max-width: 1000px;">
    <div class="mb-4">
        <h1 class="font-weight-bold text-dark mb-1" style="letter-spacing: -1px;">Başlangıç Kontrol Listesi</h1>
        <p class="text-muted mb-0">Girişiminiz için yapılacaklar listesini yapay zeka ile oluşturun ve takip edin.</p>
    </div>

    <div class="card shadow-sm border-0 mb-3" style="border-radius: 12px; background-color: #fff; border: 1px solid #e3e6f0 !important;">
        <div class="card-body p-3">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger py-2 mb-3 small">@errorMessage</div>
            }
            <div class="row g-2 align-items-end">
                <div class="col-md-8">
                    <label class="form-label small text-muted mb-1 font-weight-bold">Problem Seçin</label>
                    <select class="form-select form-select-sm" value="@selectedProblemId" @onchange="OnProblemSelected">
                        <option value="">-- Problem seçin --</option>
                        @if (problems is not null)
                        {
                            @foreach (var p in problems)
                            {
                                <option value="@p.Id">@p.Title</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    @if (isGenerating)
                    {
                        <button class="btn btn-primary btn-sm w-100 d-flex align-items-center justify-content-center gap-2" disabled>
                            <span class="spinner-border spinner-border-sm" role="status"></span> Oluşturuluyor...
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-primary btn-sm w-100" @onclick="GenerateChecklist" disabled="@(selectedProblemId == Guid.Empty)">
                            🤖 AI ile Checklist Oluştur
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (selectedProblemId != Guid.Empty)
    {
        @* İlerleme çubuğu *@
        <div class="card shadow-sm border-0 mb-3" style="border-radius: 12px; border: 1px solid #e3e6f0;">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="font-weight-bold text-dark small">İlerleme</span>
                    <span class="text-muted small">@CompletedCount / @TotalCount tamamlandı (%@ProgressPercent)</span>
                </div>
                <div class="progress" style="height: 10px; border-radius: 5px;">
                    <div class="progress-bar bg-success" role="progressbar" style="width: @ProgressPercent%;"></div>
                </div>
            </div>
        </div>

        @* Manuel item ekleme formu *@
        <div class="card shadow-sm border-0 mb-3" style="border-radius: 12px; border: 1px solid #e3e6f0;">
            <div class="card-body p-3">
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label small text-muted mb-1">Başlık</label>
                        <input class="form-control form-control-sm" placeholder="Yapılacak..." @bind="newTitle" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted mb-1">Kategori</label>
                        <select class="form-select form-select-sm" @bind="newCategory">
                            @foreach (var c in Enum.GetValues<ChecklistCategory>())
                            {
                                <option value="@c">@GetCategoryText(c)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small text-muted mb-1">Öncelik</label>
                        <select class="form-select form-select-sm" @bind="newPriority">
                            <option value="5">5 - Kritik</option>
                            <option value="4">4 - Yüksek</option>
                            <option value="3">3 - Orta</option>
                            <option value="2">2 - Düşük</option>
                            <option value="1">1 - Çok Düşük</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small text-muted mb-1">Son Tarih</label>
                        <input type="date" class="form-control form-control-sm" @bind="newDueDate" />
                    </div>
                    <div class="col-md-1">
                        <button class="btn btn-outline-primary btn-sm w-100" @onclick="AddManualItem">Ekle</button>
                    </div>
                </div>
            </div>
        </div>

        @* Kategori bazlı gruplu görünüm *@
        @if (items is null)
        {
            <div class="text-center py-4"><div class="spinner-border text-secondary" role="status"></div></div>
        }
        else if (!items.Any())
        {
            <div class="alert alert-light text-center py-4 border shadow-sm" style="border-radius: 8px;">
                Henüz kontrol listesi öğesi yok. AI ile oluşturabilir veya manuel ekleyebilirsiniz.
            </div>
        }
        else
        {
            @foreach (var group in items.GroupBy(i => i.Category).OrderBy(g => g.Key))
            {
                <div class="mb-3">
                    <h6 class="font-weight-bold text-dark mb-2 pb-1" style="border-bottom: 2px solid #e3e6f0;">
                        @GetCategoryText(group.Key) <span class="text-muted small">(@group.Count(i => i.IsCompleted)/@group.Count())</span>
                    </h6>
                    <div class="d-flex flex-column gap-2">
                        @foreach (var item in group.OrderByDescending(i => i.Priority))
                        {
                            <div class="d-flex align-items-start gap-2 p-2 rounded border" style="background-color: @(item.IsCompleted ? "#f0fdf4" : "#fff");">
                                <input type="checkbox" class="form-check-input mt-1" checked="@item.IsCompleted" @onchange="() => ToggleComplete(item)" />
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                        <span class="font-weight-bold small @(item.IsCompleted ? "text-muted text-decoration-line-through" : "text-dark")">@item.Title</span>
                                        <span class="badge @GetPriorityBadgeClass(item.Priority)" style="font-size: 0.68rem;">Öncelik @item.Priority</span>
                                        @if (item.DueDate is not null)
                                        {
                                            <span class="badge bg-light text-dark border" style="font-size: 0.68rem;"><span class="bi bi-calendar"></span> @item.DueDate.Value.ToLocalTime().ToString("yyyy-MM-dd")</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(item.Description))
                                    {
                                        <div class="text-muted small mt-1">@item.Description</div>
                                    }
                                </div>
                                <button class="btn btn-outline-danger btn-sm py-0 px-1" style="font-size: 0.7rem;" @onclick="() => DeleteItem(item.Id)" title="Sil">
                                    <span class="bi bi-trash"></span>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    }
</div>

@code {
    private IEnumerable<MSC.IdeaForge.Application.Problems.DTOs.ProblemDto>? problems;
    private Guid selectedProblemId = Guid.Empty;
    private List<ChecklistItemDto>? items;
    private bool isGenerating = false;
    private string errorMessage = "";

    // Manuel ekleme form alanları
    private string newTitle = "";
    private ChecklistCategory newCategory = ChecklistCategory.Arastirma;
    private int newPriority = 3;
    private DateTime? newDueDate;

    private int TotalCount => items?.Count ?? 0;
    private int CompletedCount => items?.Count(i => i.IsCompleted) ?? 0;
    private int ProgressPercent => TotalCount > 0 ? (int)Math.Round((double)CompletedCount / TotalCount * 100) : 0;

    protected override async Task OnInitializedAsync()
    {
        problems = await GetProblemsHandler.HandleAsync();
    }

    private async Task OnProblemSelected(ChangeEventArgs e)
    {
        errorMessage = "";
        items = null;
        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            selectedProblemId = id;
            await LoadItems();
        }
        else
        {
            selectedProblemId = Guid.Empty;
        }
    }

    private async Task LoadItems()
    {
        items = await GetChecklistItemsHandler.HandleAsync(selectedProblemId);
    }

    /// <summary>
    /// Seçili problem için AI ile checklist oluşturur ve her öğeyi kaydeder.
    /// </summary>
    private async Task GenerateChecklist()
    {
        var problem = problems?.FirstOrDefault(p => p.Id == selectedProblemId);
        if (problem is null) return;

        errorMessage = "";
        isGenerating = true;
        StateHasChanged();
        try
        {
            var suggestions = await AIProvider.GenerateStartupChecklistAsync(problem.Title, problem.Description, problem.Sector);
            foreach (var s in suggestions)
            {
                // Kategori metnini enum'a çeviriyoruz; tanımsızsa Diger kabul ediyoruz
                var category = Enum.TryParse<ChecklistCategory>(s.Category, ignoreCase: true, out var cat) ? cat : ChecklistCategory.Diger;
                await CreateChecklistItemHandler.HandleAsync(new MSC.IdeaForge.Application.Checklists.Commands.CreateChecklistItemCommand
                {
                    Title = s.Title,
                    Description = s.Description,
                    Category = category,
                    Priority = s.Priority,
                    ProblemId = selectedProblemId
                });
            }
            await LoadItems();
        }
        catch (Exception ex)
        {
            errorMessage = $"Checklist oluşturulurken bir hata oluştu: {ex.Message}";
        }
        finally
        {
            isGenerating = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Manuel kontrol listesi öğesi ekler.
    /// </summary>
    private async Task AddManualItem()
    {
        if (string.IsNullOrWhiteSpace(newTitle) || selectedProblemId == Guid.Empty) return;

        await CreateChecklistItemHandler.HandleAsync(new MSC.IdeaForge.Application.Checklists.Commands.CreateChecklistItemCommand
        {
            Title = newTitle,
            Category = newCategory,
            Priority = newPriority,
            ProblemId = selectedProblemId,
            DueDate = newDueDate.HasValue ? DateTime.SpecifyKind(newDueDate.Value, DateTimeKind.Utc) : null
        });

        newTitle = "";
        newDueDate = null;
        await LoadItems();
    }

    /// <summary>
    /// Bir öğenin tamamlanma durumunu değiştirir.
    /// </summary>
    private async Task ToggleComplete(ChecklistItemDto item)
    {
        await UpdateChecklistItemHandler.HandleAsync(new MSC.IdeaForge.Application.Checklists.Commands.UpdateChecklistItemCommand
        {
            ItemId = item.Id,
            IsCompleted = !item.IsCompleted
        });
        await LoadItems();
    }

    private async Task DeleteItem(Guid itemId)
    {
        await DeleteChecklistItemHandler.HandleAsync(new MSC.IdeaForge.Application.Checklists.Commands.DeleteChecklistItemCommand { ItemId = itemId });
        await LoadItems();
    }

    private string GetPriorityBadgeClass(int priority) => priority switch
    {
        >= 5 => "bg-danger text-white",
        4 => "bg-warning text-dark",
        3 => "bg-info text-dark",
        _ => "bg-secondary text-white"
    };

    // Kategori → Türkçe etiket
    private string GetCategoryText(string category) => GetCategoryText(Enum.TryParse<ChecklistCategory>(category, out var c) ? c : ChecklistCategory.Diger);

    private string GetCategoryText(ChecklistCategory category) => category switch
    {
        ChecklistCategory.Arastirma => "Araştırma",
        ChecklistCategory.Dogrulama => "Doğrulama",
        ChecklistCategory.Gelistirme => "Geliştirme",
        ChecklistCategory.Pazarlama => "Pazarlama",
        ChecklistCategory.Hukuk => "Hukuk",
        ChecklistCategory.Finans => "Finans",
        ChecklistCategory.Takim => "Takım",
        ChecklistCategory.Teknik => "Teknik",
        ChecklistCategory.Musteri => "Müşteri",
        ChecklistCategory.Diger => "Diğer",
        _ => category.ToString()
    };
}
