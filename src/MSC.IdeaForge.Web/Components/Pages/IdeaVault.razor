@page "/idea-vault"

@using System.Text.Json
@using MSC.IdeaForge.Domain.Enums
@using MSC.IdeaForge.Application.Problems.DTOs
@inject MSC.IdeaForge.Application.Problems.Queries.GetProblemsHandler GetProblemsHandler
@inject MSC.IdeaForge.Application.Opportunities.Queries.GetOpportunityByProblemHandler GetOpportunityByProblemHandler
@inject MSC.IdeaForge.Application.Problems.Commands.UpdateIdeaStatusHandler UpdateIdeaStatusHandler

<PageTitle>Fikir Kasası</PageTitle>

<div class="container-fluid mt-4" style="max-width: 1200px;">
    @* Sayfa Başlığı *@
    <div class="mb-4">
        <h1 class="font-weight-bold text-dark mb-1" style="letter-spacing: -1px;">Fikir Kasası (Idea Vault)</h1>
        <p class="text-muted mb-0">Tüm fikirleri yaşam döngüsü durumlarına göre yönetin. Durumu dropdown ile değiştirebilirsiniz.</p>
    </div>

    @if (problems is null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Fikirler yükleniyor...</p>
        </div>
    }
    else
    {
        @foreach (var status in statusOrder)
        {
            var group = problems.Where(p => p.IdeaStatus == status.ToString()).ToList();
            <div class="mb-4">
                @* Renk kodlu grup başlığı + sayaç *@
                <div class="d-flex align-items-center gap-2 mb-2 pb-1" style="border-bottom: 2px solid @GetStatusColor(status);">
                    <span class="badge px-3 py-2" style="background-color: @GetStatusColor(status); color: #fff; font-size: 0.9rem;">@GetStatusText(status)</span>
                    <span class="text-muted small">@group.Count fikir</span>
                </div>

                @if (!group.Any())
                {
                    <p class="text-muted small italic mb-0">Bu durumda fikir yok.</p>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var p in group)
                        {
                            <div class="col-md-6 col-lg-4">
                                <div class="card h-100 shadow-sm border-0" style="border-radius: 12px; border-left: 4px solid @GetStatusColor(status) !important;">
                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                                            <a href="/problems/@p.Id" class="font-weight-bold text-dark text-decoration-none" style="line-height: 1.3;">@p.Title</a>
                                            @if (opportunityScores.TryGetValue(p.Id, out var score) && score > 0)
                                            {
                                                <span class="badge @GetScoreBadgeClass(score) text-white" style="font-size: 0.72rem;">@score.ToString("0.0")</span>
                                            }
                                        </div>
                                        <span class="badge bg-light text-dark border mb-2" style="font-size: 0.72rem;">
                                            @(string.IsNullOrEmpty(p.Sector) ? "Sektör yok" : p.Sector)
                                        </span>

                                        @* Durum değiştirme dropdown'u *@
                                        <select class="form-select form-select-sm mt-1" value="@p.IdeaStatus"
                                                @onchange="@(e => ChangeStatus(p.Id, e.Value?.ToString()))" disabled="@(updatingId == p.Id)">
                                            @foreach (var s in statusOrder)
                                            {
                                                <option value="@s.ToString()">@GetStatusText(s)</option>
                                            }
                                        </select>

                                        @* Durum geçmişi *@
                                        @{
                                            var history = ParseHistory(p.IdeaStatusHistory);
                                        }
                                        @if (history.Any())
                                        {
                                            <div class="mt-2 pt-2 border-top">
                                                <span class="text-muted small font-weight-bold d-block mb-1">Durum Geçmişi</span>
                                                @foreach (var h in history.OrderByDescending(h => h.ChangedAt))
                                                {
                                                    <div class="text-muted" style="font-size: 0.72rem;">
                                                        <span class="bi bi-arrow-right-short"></span> @GetStatusText(ParseStatus(h.Status)) — @h.ChangedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private IEnumerable<ProblemDto>? problems;
    private Dictionary<Guid, double> opportunityScores = new();
    private Guid? updatingId;

    // Yaşam döngüsü durum sırası
    private readonly IdeaStatus[] statusOrder = new[]
    {
        IdeaStatus.Raw, IdeaStatus.Analyzed, IdeaStatus.Validated, IdeaStatus.MVPCandidate,
        IdeaStatus.Development, IdeaStatus.Pilot, IdeaStatus.Released, IdeaStatus.Parked,
        IdeaStatus.Archived, IdeaStatus.Killed
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        problems = await GetProblemsHandler.HandleAsync();
        opportunityScores.Clear();
        foreach (var p in problems)
        {
            var opp = await GetOpportunityByProblemHandler.HandleAsync(p.Id);
            opportunityScores[p.Id] = opp?.TotalScore ?? 0;
        }
    }

    /// <summary>
    /// Seçilen fikrin durumunu günceller ve listeyi yeniler.
    /// </summary>
    private async Task ChangeStatus(Guid problemId, string? newStatusText)
    {
        if (!Enum.TryParse<IdeaStatus>(newStatusText, out var newStatus)) return;

        updatingId = problemId;
        try
        {
            await UpdateIdeaStatusHandler.HandleAsync(new MSC.IdeaForge.Application.Problems.Commands.UpdateIdeaStatusCommand
            {
                ProblemId = problemId,
                IdeaStatus = newStatus
            });
            await LoadData();
        }
        finally
        {
            updatingId = null;
        }
    }

    // Durum geçmişi JSON'ını çözümler
    private List<IdeaStatusHistoryEntry> ParseHistory(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return new();
        try
        {
            return JsonSerializer.Deserialize<List<IdeaStatusHistoryEntry>>(json) ?? new();
        }
        catch
        {
            return new();
        }
    }

    private IdeaStatus ParseStatus(string s) => Enum.TryParse<IdeaStatus>(s, out var v) ? v : IdeaStatus.Raw;

    private string GetScoreBadgeClass(double score) => score switch
    {
        >= 8 => "bg-success",
        >= 6 => "bg-warning",
        _ => "bg-danger"
    };

    // Durum → renk kodu
    private string GetStatusColor(IdeaStatus status) => status switch
    {
        IdeaStatus.Raw => "#6c757d",
        IdeaStatus.Analyzed => "#0d6efd",
        IdeaStatus.Validated => "#0dcaf0",
        IdeaStatus.MVPCandidate => "#6f42c1",
        IdeaStatus.Development => "#fd7e14",
        IdeaStatus.Pilot => "#20c997",
        IdeaStatus.Released => "#198754",
        IdeaStatus.Parked => "#ffc107",
        IdeaStatus.Archived => "#343a40",
        IdeaStatus.Killed => "#dc3545",
        _ => "#6c757d"
    };

    // Durum → Türkçe etiket
    private string GetStatusText(IdeaStatus status) => status switch
    {
        IdeaStatus.Raw => "Ham (Raw)",
        IdeaStatus.Analyzed => "Analiz Edildi",
        IdeaStatus.Validated => "Doğrulandı",
        IdeaStatus.MVPCandidate => "MVP Adayı",
        IdeaStatus.Development => "Geliştirme",
        IdeaStatus.Pilot => "Pilot",
        IdeaStatus.Released => "Yayınlandı",
        IdeaStatus.Parked => "Park Edildi",
        IdeaStatus.Archived => "Arşivlendi",
        IdeaStatus.Killed => "İptal Edildi",
        _ => status.ToString()
    };
}
