@code {
    private bool isDarkMode = false;
    private bool isInitialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var val = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "isDarkMode");
                isDarkMode = val == "true";
            }
            catch
            {
                // Prerender safe
            }
            isInitialized = true;
            StateHasChanged();
        }
    }

    private async Task ToggleDarkMode()
    {
        isDarkMode = !isDarkMode;
        await JSRuntime.InvokeVoidAsync("document.body.classList.toggle", "dark-mode");
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "isDarkMode", isDarkMode.ToString().ToLower());
    }
}
