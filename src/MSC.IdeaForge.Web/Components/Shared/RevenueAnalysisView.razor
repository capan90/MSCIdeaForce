@using MSC.IdeaForge.Application.Revenues.DTOs

@* Gelir analizi sonuçlarını kartlar halinde gösteren paylaşılan bileşen. *@
@if (Result is not null)
{
    <div class="row g-3">
        @* Gelir Modeli & Tahminler *@
        <div class="col-12">
            <div class="card shadow-sm border-0" style="border-radius: 12px; border-left: 4px solid #059669 !important;">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                        <div>
                            <span class="text-muted small d-block">Önerilen Gelir Modeli</span>
                            <span class="badge bg-success px-3 py-2" style="font-size: 1rem;">@Result.RevenueModel</span>
                        </div>
                        <div class="text-center">
                            <span class="text-muted small d-block">Aylık Gelir Tahmini</span>
                            <span class="font-weight-bold text-dark">@DisplayValue(Result.MonthlyRevenueEstimate)</span>
                        </div>
                        <div class="text-center">
                            <span class="text-muted small d-block">Yıllık Gelir Tahmini</span>
                            <span class="font-weight-bold text-dark">@DisplayValue(Result.AnnualRevenueEstimate)</span>
                        </div>
                        @if (Result.AnalyzedAt != default)
                        {
                            <div class="text-end">
                                <span class="text-muted small d-block">Analiz Tarihi</span>
                                <span class="text-muted small font-mono">@Result.AnalyzedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Fiyatlandırma Stratejisi *@
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100" style="border-radius: 12px; border-left: 4px solid #0d6efd !important;">
                <div class="card-body p-3">
                    <h6 class="font-weight-bold text-primary mb-2"><span class="bi bi-tag-fill"></span> Fiyatlandırma Stratejisi</h6>
                    <p class="mb-0 text-dark small" style="white-space: pre-line;">@DisplayValue(Result.PricingStrategy)</p>
                </div>
            </div>
        </div>

        @* Hedef Müşteri *@
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100" style="border-radius: 12px; border-left: 4px solid #6f42c1 !important;">
                <div class="card-body p-3">
                    <h6 class="font-weight-bold" style="color: #6f42c1;"><span class="bi bi-people-fill"></span> Hedef Müşteri</h6>
                    <p class="mb-0 text-dark small" style="white-space: pre-line;">@DisplayValue(Result.TargetCustomer)</p>
                </div>
            </div>
        </div>

        @* Satış Kanalları *@
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100" style="border-radius: 12px; border-left: 4px solid #0dcaf0 !important;">
                <div class="card-body p-3">
                    <h6 class="font-weight-bold text-info mb-2"><span class="bi bi-shop"></span> Satış Kanalları</h6>
                    <p class="mb-0 text-dark small" style="white-space: pre-line;">@DisplayValue(Result.SalesChannel)</p>
                </div>
            </div>
        </div>

        @* Ölçeklenebilirlik *@
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100" style="border-radius: 12px; border-left: 4px solid #f6c23e !important;">
                <div class="card-body p-3">
                    <h6 class="font-weight-bold text-warning mb-2"><span class="bi bi-arrows-angle-expand"></span> Ölçeklenebilirlik</h6>
                    <p class="mb-0 text-dark small" style="white-space: pre-line;">@DisplayValue(Result.Scalability)</p>
                </div>
            </div>
        </div>

        @* Riskler *@
        <div class="col-12">
            <div class="card shadow-sm border-0" style="border-radius: 12px; border-left: 4px solid #e74a3b !important;">
                <div class="card-body p-3">
                    <h6 class="font-weight-bold text-danger mb-2"><span class="bi bi-exclamation-triangle-fill"></span> Riskler</h6>
                    <p class="mb-0 text-dark small" style="white-space: pre-line;">@DisplayValue(Result.Risks)</p>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public RevenueAnalysisDto? Result { get; set; }

    // Boş alanlar için tire gösteriyoruz
    private static string DisplayValue(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
}
